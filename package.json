{
  "name": "hyperpanes",
  "version": "0.1.5",
  "description": "A terminal workspace: one window of tiled, labeled, color-framed terminal panes.",
  "author": "",
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "make:icon": "node scripts/make-icon.mjs",
    "make:repo-assets": "node scripts/make-repo-assets.mjs",
    "pack:win": "electron-vite build && electron-builder --win nsis --publish never",
    "bench": "node bench/run.mjs",
    "bench:detect": "node bench/detect.mjs"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.3",
    "ws": "^8.21.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@electron/asar": "^4.2.0",
    "@electron/get": "^5.0.0",
    "temp": {
      "rimraf": "^6.0.0"
    }
  }
}
