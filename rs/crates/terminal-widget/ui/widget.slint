// The reusable terminal-pane UI for the native hyperpanes app.
//
// `TerminalPane` is the Wave-2 deliverable: a self-contained pane that displays the
// terminal `surface` image (rendered by the Rust controller at physical resolution),
// composites the app chrome (rounded corners, drop-shadow, accent border, title chip)
// OVER it for free, captures key input through a FocusScope, and reports geometry changes
// so the controller can reflow the grid. Drop N of these into any layout.
//
// `DemoWindow` is the standalone harness (src/bin/demo.rs) — two live panes side by side.

export struct KeyMsg {
    text: string,
    control: bool,
    alt: bool,
    shift: bool,
}

// A highlight rectangle in the pane's logical-px space (selection / search overlays). The
// controller hit-tests the grid and hands these over; the pane just paints them.
export struct HiRect {
    x: length,
    y: length,
    w: length,
    h: length,
}

// Bare terminal-font text with a soft halo (four background-colour copies behind the glyphs),
// no box — the Slint analogue of the Electron `.hp-toast` `text-shadow` treatment. Used for the
// copy/paste indicator so it reads like the terminal itself over whatever output sits behind it.
component HaloText inherits Rectangle {
    in property <string> text;
    in property <color> fg-color;
    in property <color> halo;
    in property <length> size: 13px;
    width: fg.width;
    height: fg.height;
    for off in [
        { x: -1px, y: 0px }, { x: 1px, y: 0px },
        { x: 0px, y: -1px }, { x: 0px, y: 1px },
    ]: Text {
        x: off.x;
        y: off.y;
        text: root.text;
        color: root.halo;
        font-size: root.size;
        font-family: "Consolas";
        font-weight: 700;
    }
    fg := Text {
        text: root.text;
        color: root.fg-color;
        font-size: root.size;
        font-family: "Consolas";
        font-weight: 700;
    }
}

// A small icon button for the search box (↑ / ↓ / ×), matching the Electron `.hp-search-btn`.
component SearchBtn inherits Rectangle {
    in property <string> label;
    // Scale (1.0 at default zoom) so the search controls grow/shrink with the terminal font.
    in property <float> scale: 1.0;
    callback clicked();
    width: 22px * root.scale;
    height: 22px * root.scale;
    border-radius: 5px * root.scale;
    background: btn-ta.has-hover ? #2a2e42 : transparent;
    btn-ta := TouchArea {
        clicked => { root.clicked(); }
    }
    Text {
        text: root.label;
        color: btn-ta.has-hover ? #c0caf5 : #9aa5ce;
        // Pin a font that carries the ↑ ↓ × glyphs — the default font is missing some,
        // which left buttons rendering as blank/tofu.
        font-family: "Segoe UI Symbol";
        font-size: 13px * root.scale;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component TerminalPane inherits Rectangle {
    // --- inputs (the controller / parent layout drive these) ---
    in property <image> surface;
    in property <string> title: "";
    in property <color> accent: #7aa2f7;
    in property <bool> chrome: true;

    // --- clickable-paths link overlay (driven by the controller after it hit-tests the grid) ---
    // The controller answers `link-moved` by hit-testing the cell under the cursor and, when it
    // lands on a verified path, sets these to draw a hover underline + tooltip. Defaults are inert
    // so a consumer that ignores the link layer (e.g. an older app shell) is unaffected.
    in property <bool> link-visible: false;
    in property <length> link-x;
    in property <length> link-y;
    in property <length> link-w;
    in property <string> link-tip: "";
    in property <length> link-tip-x;
    in property <length> link-tip-y;

    // --- text selection overlay (the controller fills these after a drag hit-test) ---
    in property <[HiRect]> selection-rects;

    // --- copy/paste indicator ("Copied …" / "Pasted …"), bottom-right, terminal-font + halo ---
    in property <string> toast: "";
    in property <color> toast-fg: #c0caf5;
    in property <color> toast-halo: #16161e;

    // --- terminal font size in effect (logical px), driven by the app's zoom / focused-pane
    //     font-size state. The transient indicators (copy/paste toast + the in-pane search box)
    //     scale with it so they grow when the terminal is zoomed in and shrink when zoomed out.
    //     Default = the app's 14px base, so `ind-scale` is 1.0 (no regression) at default zoom.
    in property <length> term-font-px: 14px;
    // Indicator scale relative to the 14px base font (1.0 at default zoom).
    property <float> ind-scale: root.term-font-px / 14px;

    // --- in-pane search (Ctrl+F): the box anchored top-right + the match highlights ---
    in property <bool> search-open: false;
    // Bumped by the controller each time Ctrl+F (re)invokes search — even while the box is
    // already open — so the query input gets (re)focused on a reliable change signal.
    in property <int> search-focus-tick;
    in property <string> search-count: "";   // e.g. "2 / 5" / "No results"
    in property <[HiRect]> search-rects;      // inactive matches in the viewport
    in property <bool> search-active-on: false;
    in property <HiRect> search-active-rect;  // the current match

    // --- outputs (the controller subscribes to these) ---
    // Any mouse-down inside the pane → the app should focus this pane. FROZEN CONTRACT:
    // the `pane-ux` agent connects `on_focus_requested(...)` to route focus here. Keep the
    // exact name. Fires for every button (left/right/middle) so a right-click-to-paste also
    // focuses, mirroring the Electron pane behavior.
    callback focus-requested();
    // A key was pressed while this pane had focus → encode to PTY bytes and write.
    callback key(KeyMsg);
    // The pane's on-screen size changed (logical px) → recompute cols/rows and resize.
    callback geometry-changed(length, length);
    // Pointer moved over the surface (logical px) → hit-test for a path under the cursor.
    callback link-moved(length, length);
    // Pointer left the surface → clear any hover link.
    callback link-exited();
    // Surface clicked (logical px, ctrl/cmd held) → open (plain) or copy (ctrl) the path there.
    // Fired on left-button *release*; the controller no-ops it when the press was a drag.
    callback link-activated(length, length, bool);

    // --- text selection (drag to select; copy-on-release) ---
    // Left button pressed (logical px) → begin a selection anchored here.
    callback selection-begin(length, length);
    // Pointer dragged with the left button down (logical px) → extend the selection head.
    callback selection-update(length, length);
    // Left button released → finish the selection (the controller copies it if it was a drag,
    // else clears it so a plain click stays a click).
    callback selection-end();
    // Right button pressed (or Ctrl+V) → paste the clipboard into this pane's session.
    callback paste-requested();

    // --- in-pane search ---
    // The query text changed (find-as-you-type).
    callback search-edited(string);
    // Step to the next / previous match (Enter / Shift+Enter or the ↑/↓ buttons).
    callback search-next();
    callback search-prev();
    // The search box was dismissed (Esc or ×).
    callback search-closed();

    forward-focus: fs;

    border-radius: root.chrome ? 12px : 0px;
    clip: true;
    background: #16161e;
    drop-shadow-blur: root.chrome ? 28px : 0px;
    drop-shadow-color: #00000099;
    drop-shadow-offset-y: root.chrome ? 8px : 0px;

    changed width => { root.geometry-changed(root.width, root.height); }
    changed height => { root.geometry-changed(root.width, root.height); }
    // Drive query-input focus from reliable change signals (NOT a one-shot `init` on a freshly
    // created element, which doesn't reliably land in Slint): opening focuses the query, closing
    // hands focus back to the terminal, and a re-invoke (`search-focus-tick`) re-focuses it even
    // when the box was already open.
    changed search-open => {
        if (root.search-open) { query.focus(); } else { fs.focus(); }
    }
    changed search-focus-tick => { if (root.search-open) { query.focus(); } }

    // The terminal surface (texture or pixel buffer), clipped to the rounded rect.
    Image {
        source: root.surface;
        width: 100%;
        height: 100%;
        image-fit: fill;
        image-rendering: pixelated;
    }

    // The pane's pointer layer: focus-on-press, drag-to-select, hover hit-testing for clickable
    // paths, and (on release) link open/copy. A pointer cursor signals a live link; otherwise an
    // I-beam, since the surface is selectable text.
    ta := TouchArea {
        mouse-cursor: root.link-visible ? pointer : text;
        moved => {
            // While the button is held, a move is a selection drag; otherwise it's a hover.
            if (self.pressed) {
                root.selection-update(self.mouse-x, self.mouse-y);
            } else {
                root.link-moved(self.mouse-x, self.mouse-y);
            }
        }
        changed has-hover => {
            if (!self.has-hover) { root.link-exited(); }
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                // ANY mouse-down focuses the pane (the frozen `focus-requested` contract).
                root.focus-requested();
                if (e.button == PointerEventButton.left) {
                    fs.focus();
                    root.selection-begin(self.mouse-x, self.mouse-y);
                } else if (e.button == PointerEventButton.right) {
                    // Right-click pastes the clipboard into the pane (focus it first so any
                    // follow-up typing routes here). No native context menu — matches Electron.
                    fs.focus();
                    root.paste-requested();
                }
            }
            if (e.kind == PointerEventKind.up && e.button == PointerEventButton.left) {
                // Finish the selection first (copies it if it was a drag), then — only if it
                // wasn't a drag — let it resolve as a link click.
                root.selection-end();
                root.link-activated(self.mouse-x, self.mouse-y,
                                    e.modifiers.control || e.modifiers.meta);
            }
        }
    }

    // Drag-selection highlight (one rect per row-span), painted over the terminal surface but
    // under the link/search overlays and chrome. A NEUTRAL contrast overlay (a translucent
    // wash of the terminal foreground), NOT the pane accent — so selected text reads clearly
    // and a coloured (e.g. red) pane doesn't tint its selection.
    for r in root.selection-rects: Rectangle {
        x: r.x;
        y: r.y;
        width: r.w;
        height: r.h;
        background: #c0caf5.with-alpha(0.28);
    }

    // Search-match highlights: every visible match dimmed, the active one accented + outlined.
    for r in root.search-rects: Rectangle {
        x: r.x;
        y: r.y;
        width: r.w;
        height: r.h;
        border-radius: 2px;
        background: #e0af68.with-alpha(0.30);
    }
    if root.search-active-on: Rectangle {
        x: root.search-active-rect.x;
        y: root.search-active-rect.y;
        width: root.search-active-rect.w;
        height: root.search-active-rect.h;
        border-radius: 2px;
        background: #ff9e64.with-alpha(0.45);
        border-width: 1px;
        border-color: #ff9e64;
    }

    // Hover underline drawn over the terminal surface, spanning the path's columns.
    if root.link-visible: Rectangle {
        x: root.link-x;
        y: root.link-y;
        width: root.link-w;
        height: 1px;
        background: root.accent;
    }

    // Path tooltip near the cursor (absolute target + the open/copy hint).
    if root.link-tip != "": Rectangle {
        x: min(root.link-tip-x, root.width - self.width - 4px);
        y: min(root.link-tip-y, root.height - self.height - 4px);
        background: #000000d8;
        border-radius: 6px;
        border-width: 1px;
        border-color: #ffffff1f;
        VerticalLayout {
            padding: 6px;
            spacing: 2px;
            Text {
                text: root.link-tip;
                color: #cdd6f4;
                font-size: 11px;
                font-family: "Consolas";
            }
            Text {
                text: "click to open · Ctrl+click to copy";
                color: #7f849c;
                font-size: 10px;
            }
        }
    }

    fs := FocusScope {
        key-pressed(e) => {
            root.key({
                text: e.text,
                control: e.modifiers.control,
                alt: e.modifiers.alt,
                shift: e.modifiers.shift,
            });
            accept
        }
    }

    // Hairline accent border, drawn OVER the terminal.
    if root.chrome: Rectangle {
        border-radius: 12px;
        border-width: 1px;
        border-color: root.accent.with-alpha(0.35);
    }

    // Pane title chip, composited above everything (auto-sized by its layout).
    if (root.chrome && root.title != ""): Rectangle {
        x: 10px;
        y: 8px;
        height: 22px;
        border-radius: 6px;
        background: #000000aa;
        HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            Text {
                vertical-alignment: center;
                text: root.title;
                color: root.accent;
                font-size: 12px;
                font-weight: 600;
            }
        }
    }

    // Copy/paste indicator, bottom-right — bare terminal-font text with a halo (matches Electron).
    if root.toast != "": HaloText {
        x: parent.width - self.width - 10px;
        y: parent.height - self.height - 8px;
        text: root.toast;
        fg-color: root.toast-fg;
        halo: root.toast-halo;
        // "Reads like the terminal itself" → track the terminal font px (≈13px at the 14px
        // base), with a floor so it stays legible when zoomed all the way out.
        size: max(10px, 13px * root.ind-scale);
    }

    // In-pane search box (Ctrl+F), anchored top-right — ports `SearchBox.tsx` / `.hp-search`.
    // Always instantiated (visibility-toggled) rather than `if`-created, so `query` stays in
    // scope for the focus handlers above and focusing it is reliable (an `if`-created input
    // can't be focused from `init`).
    Rectangle {
        visible: root.search-open;
        // Hug the content (input + counter + buttons) at the top-right. Without an explicit
        // width the Rectangle filled the whole pane, pushing `x` negative / off-screen.
        width: boxrow.preferred-width;
        x: parent.width - self.width - 14px;
        y: 6px;
        // Box + text scale with the terminal font (parity with the toast) so the search box
        // grows/shrinks proportionally when the terminal is zoomed.
        height: 30px * root.ind-scale;
        border-radius: 7px * root.ind-scale;
        background: #1a1b26;
        border-width: 1px;
        border-color: #2a2e42;
        drop-shadow-blur: 20px;
        drop-shadow-color: #00000073;
        // Swallow presses so a click in the box doesn't begin a selection on the surface.
        TouchArea {}
        boxrow := HorizontalLayout {
            padding: 4px * root.ind-scale;
            spacing: 3px * root.ind-scale;
            // Query input.
            Rectangle {
                width: 150px * root.ind-scale;
                border-radius: 5px * root.ind-scale;
                background: #16161e;
                border-width: 1px;
                border-color: query.has-focus ? root.accent : #2a2e42;
                query := TextInput {
                    x: 7px * root.ind-scale;
                    width: parent.width - 14px * root.ind-scale;
                    vertical-alignment: center;
                    color: #c0caf5;
                    font-size: 12px * root.ind-scale;
                    font-family: "Consolas";
                    single-line: true;
                    edited => { root.search-edited(self.text); }
                    key-pressed(e) => {
                        if (e.text == Key.Escape) {
                            root.search-closed();
                            accept
                        } else if (e.text == Key.Return) {
                            if (e.modifiers.shift) {
                                root.search-prev();
                            } else {
                                root.search-next();
                            }
                            accept
                        } else {
                            reject
                        }
                    }
                }
            }
            // Match counter.
            Text {
                vertical-alignment: center;
                width: self.preferred-width + 4px;
                text: root.search-count;
                color: #565f89;
                font-size: 11px * root.ind-scale;
                horizontal-alignment: center;
            }
            // Prev / next / close.
            SearchBtn {
                label: "↑";
                scale: root.ind-scale;
                clicked => { root.search-prev(); }
            }
            SearchBtn {
                label: "↓";
                scale: root.ind-scale;
                clicked => { root.search-next(); }
            }
            SearchBtn {
                label: "×";
                scale: root.ind-scale;
                clicked => { root.search-closed(); }
            }
        }
    }
}

export struct PaneVisual {
    surface: image,
    title: string,
    accent: color,
    // clickable-paths hover overlay state (set by the demo after hit-testing).
    link-visible: bool,
    link-x: length,
    link-y: length,
    link-w: length,
    link-tip: string,
    link-tip-x: length,
    link-tip-y: length,
    // drag-selection highlight rects (set by the demo after a selection hit-test).
    selection-rects: [HiRect],
    // copy/paste indicator text (set by the demo; empty = hidden).
    toast: string,
    // in-pane search state (set by the demo from the controller).
    search-open: bool,
    search-count: string,
    search-rects: [HiRect],
    search-active-on: bool,
    search-active-rect: HiRect,
}

export component DemoWindow inherits Window {
    in property <[PaneVisual]> panes;
    in property <string> hud: "";

    // (pane index) — a mouse-down landed in this pane → focus it. Mirrors the per-pane
    // `focus-requested` (frozen) contract the real app wires per-instance.
    callback focus-requested(int);
    // (pane index, key) — routed from whichever pane has focus.
    callback key(int, KeyMsg);
    // (pane index, width, height) — geometry of a pane changed.
    callback geometry-changed(int, length, length);
    // (pane index, x, y) — pointer moved over a pane → hit-test for a clickable path.
    callback link-moved(int, length, length);
    // (pane index) — pointer left a pane → clear its hover link.
    callback link-exited(int);
    // (pane index, x, y, ctrl) — pane clicked → open (plain) or copy (ctrl) the path there.
    callback link-activated(int, length, length, bool);
    // (pane index, x, y) — selection drag began / extended in a pane.
    callback selection-begin(int, length, length);
    callback selection-update(int, length, length);
    // (pane index) — selection drag finished in a pane.
    callback selection-end(int);
    // (pane index) — right-click / Ctrl+V paste requested in a pane.
    callback paste-requested(int);
    // (pane index, query) / (pane index) — in-pane search interactions.
    callback search-edited(int, string);
    callback search-next(int);
    callback search-prev(int);
    callback search-closed(int);

    title: "hyperpanes — terminal-widget demo";
    preferred-width: 1280px;
    preferred-height: 760px;
    background: #0f0f17;

    // Subtle desktop gradient so rounded corners + shadows read distinctly.
    Rectangle {
        background: @linear-gradient(135deg, #12121d 0%, #1a1320 100%);
    }

    HorizontalLayout {
        padding: 16px;
        spacing: 16px;
        for pane[idx] in root.panes: TerminalPane {
            surface: pane.surface;
            title: pane.title;
            accent: pane.accent;
            link-visible: pane.link-visible;
            link-x: pane.link-x;
            link-y: pane.link-y;
            link-w: pane.link-w;
            link-tip: pane.link-tip;
            link-tip-x: pane.link-tip-x;
            link-tip-y: pane.link-tip-y;
            selection-rects: pane.selection-rects;
            toast: pane.toast;
            search-open: pane.search-open;
            search-count: pane.search-count;
            search-rects: pane.search-rects;
            search-active-on: pane.search-active-on;
            search-active-rect: pane.search-active-rect;
            focus-requested => { root.focus-requested(idx); }
            key(m) => { root.key(idx, m); }
            geometry-changed(w, h) => { root.geometry-changed(idx, w, h); }
            link-moved(x, y) => { root.link-moved(idx, x, y); }
            link-exited => { root.link-exited(idx); }
            link-activated(x, y, ctrl) => { root.link-activated(idx, x, y, ctrl); }
            selection-begin(x, y) => { root.selection-begin(idx, x, y); }
            selection-update(x, y) => { root.selection-update(idx, x, y); }
            selection-end => { root.selection-end(idx); }
            paste-requested => { root.paste-requested(idx); }
            search-edited(t) => { root.search-edited(idx, t); }
            search-next => { root.search-next(idx); }
            search-prev => { root.search-prev(idx); }
            search-closed => { root.search-closed(idx); }
        }
    }

    // HUD overlay (FPS / renderer / bytes), top-right, auto-sized.
    if root.hud != "": Rectangle {
        x: parent.width - self.width - 14px;
        y: 10px;
        height: 24px;
        border-radius: 6px;
        background: #000000bb;
        HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            Text {
                vertical-alignment: center;
                text: root.hud;
                color: #9ece6a;
                font-size: 12px;
                font-family: "Consolas";
            }
        }
    }
}
