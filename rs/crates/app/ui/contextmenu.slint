// The cursor-anchored context menu (pane header + tab strip) — the native port of
// src/renderer/components/{ContextMenu,contextMenus,ColorSwatches}.tsx.
//
// Lifts the hamburger PopupWindow look from topbar.slint (Catppuccin card, hover rows,
// ✓ checkmarks, ▸ submenu arrows) and adds: cursor anchoring with viewport clamping, danger
// styling (Close Pane), disabled rows, keyboard-shortcut hints, and three side-flyout submenus
// (Change Color swatches + Show-Frame/Dot toggles · Move to Tab · Layout). Submenus open on
// click (one at a time) and the flyout sits flush to the card's edge (flipping left near the
// right edge). The whole component fills the window: clicks outside the card dismiss it.

import { Theme } from "theme.slint";
import { MenuEntry, CtxTab, LayoutOption } from "types.slint";

// The Reminder flyout's Custom-duration bridge: a PURE parser implemented in Rust (app.rs
// wires it to contextmenu::parse_custom_minutes_now). Returns minutes-from-now (>= 1) or
// -1 when the text doesn't parse. A global (not a ContextMenu callback) so the Rust side
// reaches it without new wiring through app.slint's component tree — the RemindersAdapter
// precedent (it does need re-exporting from app.slint to be visible to Rust codegen).
export global ReminderCustom {
    pure callback parse-minutes(string) -> int;
}

// ===== drawn menu icons =====
// Every leading icon is vector geometry keyed by MenuEntry.icon — NOT a font glyph. The
// previous Segoe MDL2 Assets codepoints (\u{E710}…) and geometric chars (▤▥▦⊞▧) rendered
// as hollow boxes whenever the resolved font lacked them (the recurring Slint-on-Windows
// failure df73005 / the wave3x bell fixed by drawing geometry). Kinds mirror
// theme::menu_icon + theme::layout_icon_kind in Rust:
//   1 new-pane (+) · 2 command-palette (>_) · 3 open-folder · 4 save · 5 preferences
//   10..15 layout minis: auto · single · columns · rows · grid · main-stack

// A "+" (two crossed bars), the New-pane action icon.
component IconPlus inherits Rectangle {
    in property <color> ink;
    width: 14px;
    height: 14px;
    Rectangle { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; width: 1.5px; height: 11px; border-radius: 1px; background: ink; }
    Rectangle { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; height: 1.5px; width: 11px; border-radius: 1px; background: ink; }
}

// A ">_" prompt, the Command-palette action icon.
component IconPrompt inherits Rectangle {
    in property <color> ink;
    width: 14px;
    height: 14px;
    Path {
        width: 100%; height: 100%;
        viewbox-width: 14; viewbox-height: 14;
        stroke: ink; stroke-width: 1.5px; fill: transparent;
        commands: "M 2 3.5 L 6.5 7 L 2 10.5";
    }
    Rectangle { x: 8px; y: 11px; width: 5px; height: 1.5px; border-radius: 1px; background: ink; }
}

// A folder silhouette (stroked) — same path as the sidebar's FolderGlyph.
component IconFolder inherits Path {
    in property <color> ink;
    width: 15px;
    height: 15px;
    viewbox-width: 18;
    viewbox-height: 18;
    stroke: ink;
    stroke-width: 1.5px;
    fill: transparent;
    commands: "M 2.5 14 L 2.5 5 L 7 5 L 8.6 6.8 L 15.5 6.8 L 15.5 14 Z";
}

// A floppy-disk (save): clipped-corner body + label slot + shutter.
component IconSave inherits Path {
    in property <color> ink;
    width: 14px;
    height: 14px;
    viewbox-width: 14;
    viewbox-height: 14;
    stroke: ink;
    stroke-width: 1.3px;
    fill: transparent;
    commands: "M 2 2 L 9.8 2 L 12 4.2 L 12 12 L 2 12 Z M 4.2 2 L 4.2 5 L 9 5 L 9 2 M 4 12 L 4 8.2 L 10 8.2 L 10 12";
}

// Preference sliders (three bars with offset knobs) — the Settings action icon.
component IconSliders inherits Rectangle {
    in property <color> ink;
    width: 14px;
    height: 14px;
    Rectangle { y: 2px;    width: 100%; height: 1.4px; border-radius: 1px; background: ink; }
    Rectangle { y: 6.3px;  width: 100%; height: 1.4px; border-radius: 1px; background: ink; }
    Rectangle { y: 10.6px; width: 100%; height: 1.4px; border-radius: 1px; background: ink; }
    Rectangle { x: 3px;  y: 0.6px; width: 4px; height: 4px; border-radius: 2px; background: ink; }
    Rectangle { x: 8px;  y: 4.9px; width: 4px; height: 4px; border-radius: 2px; background: ink; }
    Rectangle { x: 4.5px; y: 9.2px; width: 4px; height: 4px; border-radius: 2px; background: ink; }
}

// A layout mini: an outlined frame whose inner dividers evoke the preset (the drawn
// replacement for the ⊞ □ ▥ ▤ ▦ ▧ chars). `which` = MenuEntry.icon - 10 (the layout id):
// 0 auto (2×2 cross) · 1 single (empty) · 2 columns (2 vertical) · 3 rows (2 horizontal) ·
// 4 grid (3×3 lattice) · 5 main-stack (main pane + split stack).
component IconLayout inherits Rectangle {
    in property <color> ink;
    in property <int> which;
    width: 14px;
    height: 14px;
    Rectangle {
        x: 0.5px; y: 1.5px;
        width: 13px; height: 11px;
        border-width: 1.2px;
        border-color: ink;
        border-radius: 2px;
        background: transparent;
        property <length> inner-x: 1.2px;
        property <length> inner-w: self.width - 2.4px;
        property <length> inner-y: 1.2px;
        property <length> inner-h: self.height - 2.4px;
        // auto: a centered 2×2 cross
        if root.which == 0 : Rectangle { x: (parent.width - 1.2px) / 2; y: parent.inner-y; width: 1.2px; height: parent.inner-h; background: ink; }
        if root.which == 0 : Rectangle { x: parent.inner-x; y: (parent.height - 1.2px) / 2; width: parent.inner-w; height: 1.2px; background: ink; }
        // columns: two vertical dividers
        if root.which == 2 : Rectangle { x: parent.width * 0.333; y: parent.inner-y; width: 1.2px; height: parent.inner-h; background: ink; }
        if root.which == 2 : Rectangle { x: parent.width * 0.667; y: parent.inner-y; width: 1.2px; height: parent.inner-h; background: ink; }
        // rows: two horizontal dividers
        if root.which == 3 : Rectangle { x: parent.inner-x; y: parent.height * 0.333; width: parent.inner-w; height: 1.2px; background: ink; }
        if root.which == 3 : Rectangle { x: parent.inner-x; y: parent.height * 0.667; width: parent.inner-w; height: 1.2px; background: ink; }
        // grid: a 3×3 lattice
        if root.which == 4 : Rectangle { x: parent.width * 0.333; y: parent.inner-y; width: 1.2px; height: parent.inner-h; background: ink; }
        if root.which == 4 : Rectangle { x: parent.width * 0.667; y: parent.inner-y; width: 1.2px; height: parent.inner-h; background: ink; }
        if root.which == 4 : Rectangle { x: parent.inner-x; y: parent.height * 0.333; width: parent.inner-w; height: 1.2px; background: ink; }
        if root.which == 4 : Rectangle { x: parent.inner-x; y: parent.height * 0.667; width: parent.inner-w; height: 1.2px; background: ink; }
        // main-stack: a main pane left, a 2-way stack right
        if root.which == 5 : Rectangle { x: parent.width * 0.55; y: parent.inner-y; width: 1.2px; height: parent.inner-h; background: ink; }
        if root.which == 5 : Rectangle { x: parent.width * 0.55; y: (parent.height - 1.2px) / 2; width: parent.width * 0.45 - 1.2px; height: 1.2px; background: ink; }
    }
}

// The icon dispatcher: one slot, geometry picked by kind (0 renders nothing).
component MenuIcon inherits Rectangle {
    in property <int> kind;
    in property <color> ink;
    width: 15px;
    if root.kind == 1 : IconPlus    { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink; }
    if root.kind == 2 : IconPrompt  { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink; }
    if root.kind == 3 : IconFolder  { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink; }
    if root.kind == 4 : IconSave    { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink; }
    if root.kind == 5 : IconSliders { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink; }
    if root.kind >= 10 : IconLayout { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink; which: root.kind - 10; }
}

// One menu row: icon · label · shortcut · trailing (✓ / ›). Honors disabled + danger.
component CtxRow inherits Rectangle {
    in property <MenuEntry> e;
    in property <bool> has-sub;
    in property <bool> sub-open;
    out property <bool> hovered: ta.has-hover;
    callback clicked();
    // Fires on hover enter/leave (true/false) so the menu can open a submenu on hover.
    callback hover-changed(bool);
    height: 30px;
    border-radius: 6px;
    background: e.disabled ? transparent
              : (ta.has-hover || root.sub-open)
                  ? (e.danger ? #f38ba822 : Theme.surface2)
                  : transparent;

    HorizontalLayout {
        padding-left: 11px;
        padding-right: 11px;
        spacing: 8px;

        // optional leading icon (hamburger action icon / layout submenu rows) — drawn
        // geometry keyed by e.icon (see MenuIcon above), never a font glyph.
        if e.icon != 0 : MenuIcon {
            kind: e.icon;
            ink: e.disabled ? Theme.faint : Theme.subtext;
        }
        Text {
            text: e.label;
            color: e.disabled ? Theme.faint : (e.danger ? Theme.danger : Theme.text);
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        // keyboard shortcut hint
        Text {
            text: e.shortcut;
            visible: e.shortcut != "";
            color: Theme.faint;
            font-size: 11px;
            vertical-alignment: center;
        }
        // trailing: a drawn ✓ for a checked toggle, a › for a submenu (the ✓ is vector
        // geometry — the default UI font lacks the glyph, same as overlays' Check)
        Rectangle {
            width: (root.has-sub || (e.show-check && e.checked)) ? 12px : 0px;
            if root.has-sub : Text {
                text: "›";
                color: Theme.subtext;
                font-size: 16px;
                vertical-alignment: center;
                horizontal-alignment: center;
                width: 100%;
                height: 100%;
            }
            if !root.has-sub && e.show-check && e.checked : Path {
                x: 0;
                y: (parent.height - self.height) / 2;
                width: 11px;
                height: 9px;
                viewbox-width: 12;
                viewbox-height: 10;
                stroke: Theme.accent;
                stroke-width: 1.6px;
                fill: transparent;
                commands: "M 1 5.5 L 4.5 9 L 11 1";
            }
        }
    }

    ta := TouchArea {
        enabled: !e.disabled;
        clicked => { root.clicked(); }
        changed has-hover => { root.hover-changed(self.has-hover); }
    }
}

// A labelled checkbox row used inside the Change-Color flyout (Show Frame / Show Dot).
component CtxToggle inherits Rectangle {
    in property <string> label;
    in property <bool> on;
    callback toggled(bool);
    height: 26px;
    border-radius: 6px;
    background: ta.has-hover ? Theme.surface2 : transparent;
    HorizontalLayout {
        padding-left: 9px;
        padding-right: 9px;
        spacing: 8px;
        Rectangle {
            width: 15px;
            height: 15px;
            y: (parent.height - self.height) / 2;
            border-radius: 4px;
            border-width: 1px;
            border-color: root.on ? Theme.accent : Theme.border;
            background: root.on ? Theme.accent : transparent;
            // drawn ✓ (the default UI font lacks the glyph)
            if root.on : Path {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 9px;
                height: 7px;
                viewbox-width: 12;
                viewbox-height: 10;
                stroke: #11111b;
                stroke-width: 2px;
                fill: transparent;
                commands: "M 1 5.5 L 4.5 9 L 11 1";
            }
        }
        Text {
            text: root.label;
            color: Theme.text;
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
    ta := TouchArea { clicked => { root.toggled(!root.on); } }
}

// A floating submenu card (the flyout container).
component Flyout inherits Rectangle {
    background: Theme.mantle;
    border-radius: 9px;
    border-width: 1px;
    border-color: Theme.border;
    drop-shadow-blur: 30px;
    drop-shadow-color: Theme.scrim;
    drop-shadow-offset-y: 10px;
}

export component ContextMenu inherits Rectangle {
    // window-logical anchor (the right-click point)
    in property <length> menu-x;
    in property <length> menu-y;
    in property <[MenuEntry]> entries;
    // submenu data (only the relevant ones are populated per menu kind)
    in property <[color]> swatches;
    in property <int> cur-swatch: -1;     // index of the pane's color in `swatches`, or -1
    in property <bool> frame-on;
    in property <bool> dot-on;
    in property <[CtxTab]> tabs;           // Move-to-Tab destinations
    in property <[LayoutOption]> layouts;  // Layout submenu (checkmark on current)

    callback pick(int);          // a plain top-level row
    callback swatch(int);        // a color swatch
    callback swatch-none();      // the "no color" swatch
    callback set-frame(bool);
    callback set-dot(bool);
    callback move-tab(int);      // a Move-to-Tab destination (real tab index)
    callback set-layout(int);    // a Layout option id
    callback dismiss();

    // which submenu row is currently expanded (-1 = none). Reset every open (the `if` in
    // app.slint re-instantiates this component when the menu opens).
    property <int> open-sub: -1;
    // A right-click *chain* (close this menu + reopen the one under the new cursor) keeps the
    // SAME instance alive when one menu kind replaces another (ctx-kind stays non-zero, so the
    // `if` in app.slint doesn't re-instantiate). The anchor is re-pushed on every (re)open, so
    // collapse any open flyout when it moves — the fresh menu never inherits a stale expanded
    // submenu. (The setters only fire `changed` on a real value change, so an open submenu is
    // untouched while the cursor hovers within a stationary menu.)
    changed menu-x => { root.open-sub = -1; }
    changed menu-y => { root.open-sub = -1; }
    // Sentinel "row" the click-away catcher passes to `pick()` to request the right-click chain
    // above. app.rs reads the global cursor and reopens the matching menu. Kept in sync with
    // `CTX_REOPEN_CHAIN_ROW` in app.rs.
    property <int> reopen-chain-row: -987654;
    property <length> menu-w: 250px;
    property <length> est-h: root.entries.length * 30px + 12px;
    // flip flyouts to the left when the card sits in the right of the window.
    property <bool> open-left: root.menu-x > root.width * 0.6;

    // ---- full-window click-away catcher ----
    // Left-click away = plain dismiss (unchanged). A RIGHT-click while a menu is open should
    // CHAIN instead of just swallowing the event: close this menu and open the one under the
    // new cursor in a single action. We can't add a dedicated callback (app.slint is frozen,
    // owned by another track), so we reuse `pick()` with an out-of-range sentinel row — the
    // same encode-on-a-frozen-callback trick app.rs uses for `open-project`. app.rs sees the
    // sentinel, reads the global cursor, hit-tests it, and reopens the matching menu (the (x,y)
    // ride along via the cursor, so the callback needs no params).
    away := TouchArea {
        clicked => { root.dismiss(); }
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right) {
                root.pick(root.reopen-chain-row);
            }
        }
    }

    // ---- the menu card ----
    card := Rectangle {
        x: min(max(root.menu-x, 4px), root.width - root.menu-w - 4px);
        y: min(max(root.menu-y, 4px), max(4px, root.height - root.est-h - 4px));
        width: root.menu-w;
        // hug the rows: size to the column's content, not the parent (fixes the dead
        // gap below the last row). The y-clamp above keeps using `est-h` so a menu near
        // the bottom edge still flips up.
        height: menucol.preferred-height;
        background: Theme.mantle;
        border-radius: 9px;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-blur: 40px;
        drop-shadow-color: Theme.scrim;
        drop-shadow-offset-y: 14px;

        menucol := VerticalLayout {
            padding: 5px;
            spacing: 1px;

            for entry[i] in root.entries : Rectangle {
                height: entry.kind == -1 ? 9px : 30px;

                // separator
                if entry.kind == -1 : Rectangle {
                    y: 4px;
                    height: 1px;
                    background: Theme.border;
                }

                // a real row (item or submenu header)
                if entry.kind != -1 : row := CtxRow {
                    e: entry;
                    has-sub: entry.kind >= 2;
                    sub-open: root.open-sub == i;
                    // Submenus (Layout ▸ etc.) open on hover; hovering a plain row closes any
                    // open submenu. Acting only on the rising edge (h) means moving the pointer
                    // off the row into its flyout does NOT close it — the flyout sits flush to
                    // the row's edge, so there's no plain-row hover in between (no flicker).
                    hover-changed(h) => {
                        if (h) {
                            root.open-sub = entry.kind >= 2 ? i : -1;
                        }
                    }
                    clicked => {
                        if (entry.kind >= 2) {
                            root.open-sub = i;
                        } else {
                            root.pick(i);
                        }
                    }
                }

                // ---- Change Color flyout ----
                if entry.kind == 2 && root.open-sub == i : Flyout {
                    x: root.open-left ? -self.width + 2px : parent.width - 2px;
                    y: -4px;
                    width: 232px;
                    height: vbox-color.preferred-height;
                    vbox-color := VerticalLayout {
                        padding: 8px;
                        spacing: 6px;
                        // swatch row: a "no color" chip + the palette slots
                        HorizontalLayout {
                            spacing: 5px;
                            alignment: start;
                            Rectangle {
                                width: 20px;
                                height: 20px;
                                border-radius: 5px;
                                border-width: 1px;
                                border-color: (!root.frame-on && !root.dot-on) ? Theme.text : Theme.border;
                                // "no color" — a Photoshop-style red diagonal slash.
                                Path {
                                    width: 100%;
                                    height: 100%;
                                    viewbox-width: 20;
                                    viewbox-height: 20;
                                    stroke: Theme.danger;
                                    stroke-width: 1.6px;
                                    commands: "M 4 16 L 16 4";
                                }
                                TouchArea { clicked => { root.swatch-none(); } }
                            }
                            for c[ci] in root.swatches : Rectangle {
                                width: 20px;
                                height: 20px;
                                border-radius: 5px;
                                background: c;
                                border-width: (ci == root.cur-swatch && root.frame-on) ? 2px : 0px;
                                border-color: Theme.text;
                                TouchArea { clicked => { root.swatch(ci); } }
                            }
                        }
                        CtxToggle { label: "Show Frame"; on: root.frame-on; toggled(v) => { root.set-frame(v); } }
                        CtxToggle { label: "Show Dot"; on: root.dot-on; toggled(v) => { root.set-dot(v); } }
                    }
                }

                // ---- Move to Tab flyout ----
                if entry.kind == 3 && root.open-sub == i : Flyout {
                    x: root.open-left ? -self.width + 2px : parent.width - 2px;
                    y: -4px;
                    width: 200px;
                    height: vbox-tab.preferred-height;
                    vbox-tab := VerticalLayout {
                        padding: 5px;
                        spacing: 1px;
                        for tb in root.tabs : CtxRow {
                            e: { label: tb.label, shortcut: "", icon: 0, kind: 0, checked: false, show-check: false, disabled: false, danger: false };
                            clicked => { root.move-tab(tb.idx); }
                        }
                    }
                }

                // ---- Reminder flyout (quick offsets + an inline Custom duration) ----
                if entry.kind == 5 && root.open-sub == i : Flyout {
                    x: root.open-left ? -self.width + 2px : parent.width - 2px;
                    y: -4px;
                    width: 208px;
                    height: vbox-remind.preferred-height;
                    // pick(custom-remind-base + minutes) smuggles the Custom minutes
                    // through the frozen pick(int) channel — kept in sync with
                    // CTX_CUSTOM_REMIND_BASE in contextmenu.rs.
                    property <int> custom-remind-base: 1000000;
                    vbox-remind := VerticalLayout {
                        padding: 5px;
                        spacing: 1px;
                        // The quick offsets dispatch through hidden command slots appended
                        // PAST the visible rows (see pane_menu's b.extra) — row order here
                        // must match that append order.
                        for off[j] in ["In 15 min", "In 1 hour", "In 3 hours", "Tomorrow 9 AM"] : CtxRow {
                            e: { label: off, shortcut: "", icon: 0, kind: 0, checked: false, show-check: false, disabled: false, danger: false };
                            clicked => { root.pick(root.entries.length + j); }
                        }
                        Rectangle {
                            height: 9px;
                            Rectangle { y: 4px; height: 1px; background: Theme.border; }
                        }
                        // Custom…: type a duration (45 · 90m · 1h30 · 14:30), Enter parks.
                        // Validity is re-checked per keystroke via the Rust parser; the
                        // border tints accent (good) / danger (won't submit).
                        crow := Rectangle {
                            property <int> parsed: -1;
                            height: 30px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: ci.text == "" ? Theme.border
                                        : crow.parsed > 0 ? Theme.accent : Theme.danger;
                            HorizontalLayout {
                                padding-left: 9px;
                                padding-right: 9px;
                                Rectangle {
                                    clip: true;
                                    if ci.text == "" : Text {
                                        text: "Custom: 45 · 1h30 · 14:30";
                                        width: 100%;
                                        height: 100%;
                                        color: Theme.faint;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                    ci := TextInput {
                                        width: 100%;
                                        height: 100%;
                                        color: Theme.text;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        single-line: true;
                                        init => { self.focus(); }
                                        edited => { crow.parsed = ReminderCustom.parse-minutes(self.text); }
                                        accepted => {
                                            if (crow.parsed > 0) {
                                                root.pick(custom-remind-base + crow.parsed);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // ---- Layout flyout (drawn icon · label · "— resolved" hint · radio ✓) ----
                if entry.kind == 4 && root.open-sub == i : Flyout {
                    x: root.open-left ? -self.width + 2px : parent.width - 2px;
                    y: -4px;
                    width: 232px;
                    height: vbox-layout.preferred-height;
                    vbox-layout := VerticalLayout {
                        padding: 5px;
                        spacing: 1px;
                        for lo in root.layouts : CtxRow {
                            e: { label: lo.label, shortcut: lo.hint, icon: 10 + lo.id, kind: 0, checked: lo.active, show-check: true, disabled: false, danger: false };
                            clicked => { root.set-layout(lo.id); }
                        }
                    }
                }
            }
        }
    }
}
