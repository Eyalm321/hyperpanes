// The cursor-anchored context menu (pane header + tab strip) — the native port of
// src/renderer/components/{ContextMenu,contextMenus,ColorSwatches}.tsx.
//
// Lifts the hamburger PopupWindow look from topbar.slint (Catppuccin card, hover rows,
// ✓ checkmarks, ▸ submenu arrows) and adds: cursor anchoring with viewport clamping, danger
// styling (Close Pane), disabled rows, keyboard-shortcut hints, and three side-flyout submenus
// (Change Color swatches + Show-Frame/Dot toggles · Move to Tab · Layout). Submenus open on
// click (one at a time) and the flyout sits flush to the card's edge (flipping left near the
// right edge). The whole component fills the window: clicks outside the card dismiss it.

import { Theme } from "theme.slint";
import { MenuEntry, CtxTab, LayoutOption } from "types.slint";

// The Reminder flyout's Custom-duration bridge: a PURE parser implemented in Rust (app.rs
// wires it to contextmenu::parse_custom_minutes_now). Returns minutes-from-now (>= 1) or
// -1 when the text doesn't parse. A global (not a ContextMenu callback) so the Rust side
// reaches it without new wiring through app.slint's component tree — the RemindersAdapter
// precedent (it does need re-exporting from app.slint to be visible to Rust codegen).
export global ReminderCustom {
    pure callback parse-minutes(string) -> int;
}

// One menu row: glyph · label · shortcut · trailing (✓ / ▸). Honors disabled + danger.
component CtxRow inherits Rectangle {
    in property <MenuEntry> e;
    in property <bool> has-sub;
    in property <bool> sub-open;
    out property <bool> hovered: ta.has-hover;
    callback clicked();
    // Fires on hover enter/leave (true/false) so the menu can open a submenu on hover.
    callback hover-changed(bool);
    // The hamburger menu's action icons are Segoe MDL2 Assets glyphs in the Unicode
    // Private-Use Area, which render *only* in the icon font; the geometric layout glyphs
    // (▤▥▦…) render in any UI font. Mirror theme::menu_glyph so the row picks the font per
    // glyph (an empty family = the default UI font).
    property <bool> mdl2-glyph:
           e.glyph == "\u{E710}"   // New pane (Add)
        || e.glyph == "\u{E756}"   // Command palette (CommandPrompt)
        || e.glyph == "\u{ED25}"   // Open workspace (OpenFolderHorizontal)
        || e.glyph == "\u{E74E}"   // Save workspace (Save)
        || e.glyph == "\u{E713}";  // Preferences (Setting)
    height: 30px;
    border-radius: 6px;
    background: e.disabled ? transparent
              : (ta.has-hover || root.sub-open)
                  ? (e.danger ? #f38ba822 : Theme.surface2)
                  : transparent;

    HorizontalLayout {
        padding-left: 11px;
        padding-right: 11px;
        spacing: 8px;

        // optional leading glyph (hamburger action icon / layout submenu header)
        Text {
            text: e.glyph;
            visible: e.glyph != "";
            font-family: root.mdl2-glyph ? "Segoe MDL2 Assets" : "";
            color: e.disabled ? Theme.faint : Theme.subtext;
            font-size: 12px;
            vertical-alignment: center;
        }
        Text {
            text: e.label;
            color: e.disabled ? Theme.faint : (e.danger ? Theme.danger : Theme.text);
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        // keyboard shortcut hint
        Text {
            text: e.shortcut;
            visible: e.shortcut != "";
            color: Theme.faint;
            font-size: 11px;
            vertical-alignment: center;
        }
        // trailing: a ✓ for a checked toggle, a › for a submenu
        Text {
            text: root.has-sub ? "›" : ((e.show-check && e.checked) ? "✓" : "");
            color: root.has-sub ? Theme.subtext : Theme.accent;
            font-size: root.has-sub ? 16px : 12px;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        enabled: !e.disabled;
        clicked => { root.clicked(); }
        changed has-hover => { root.hover-changed(self.has-hover); }
    }
}

// A labelled checkbox row used inside the Change-Color flyout (Show Frame / Show Dot).
component CtxToggle inherits Rectangle {
    in property <string> label;
    in property <bool> on;
    callback toggled(bool);
    height: 26px;
    border-radius: 6px;
    background: ta.has-hover ? Theme.surface2 : transparent;
    HorizontalLayout {
        padding-left: 9px;
        padding-right: 9px;
        spacing: 8px;
        Rectangle {
            width: 15px;
            height: 15px;
            y: (parent.height - self.height) / 2;
            border-radius: 4px;
            border-width: 1px;
            border-color: root.on ? Theme.accent : Theme.border;
            background: root.on ? Theme.accent : transparent;
            Text {
                text: root.on ? "✓" : "";
                color: #11111b;
                font-size: 11px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }
        Text {
            text: root.label;
            color: Theme.text;
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
    ta := TouchArea { clicked => { root.toggled(!root.on); } }
}

// A floating submenu card (the flyout container).
component Flyout inherits Rectangle {
    background: Theme.mantle;
    border-radius: 9px;
    border-width: 1px;
    border-color: Theme.border;
    drop-shadow-blur: 30px;
    drop-shadow-color: Theme.scrim;
    drop-shadow-offset-y: 10px;
}

export component ContextMenu inherits Rectangle {
    // window-logical anchor (the right-click point)
    in property <length> menu-x;
    in property <length> menu-y;
    in property <[MenuEntry]> entries;
    // submenu data (only the relevant ones are populated per menu kind)
    in property <[color]> swatches;
    in property <int> cur-swatch: -1;     // index of the pane's color in `swatches`, or -1
    in property <bool> frame-on;
    in property <bool> dot-on;
    in property <[CtxTab]> tabs;           // Move-to-Tab destinations
    in property <[LayoutOption]> layouts;  // Layout submenu (checkmark on current)

    callback pick(int);          // a plain top-level row
    callback swatch(int);        // a color swatch
    callback swatch-none();      // the "no color" swatch
    callback set-frame(bool);
    callback set-dot(bool);
    callback move-tab(int);      // a Move-to-Tab destination (real tab index)
    callback set-layout(int);    // a Layout option id
    callback dismiss();

    // which submenu row is currently expanded (-1 = none). Reset every open (the `if` in
    // app.slint re-instantiates this component when the menu opens).
    property <int> open-sub: -1;
    // A right-click *chain* (close this menu + reopen the one under the new cursor) keeps the
    // SAME instance alive when one menu kind replaces another (ctx-kind stays non-zero, so the
    // `if` in app.slint doesn't re-instantiate). The anchor is re-pushed on every (re)open, so
    // collapse any open flyout when it moves — the fresh menu never inherits a stale expanded
    // submenu. (The setters only fire `changed` on a real value change, so an open submenu is
    // untouched while the cursor hovers within a stationary menu.)
    changed menu-x => { root.open-sub = -1; }
    changed menu-y => { root.open-sub = -1; }
    // Sentinel "row" the click-away catcher passes to `pick()` to request the right-click chain
    // above. app.rs reads the global cursor and reopens the matching menu. Kept in sync with
    // `CTX_REOPEN_CHAIN_ROW` in app.rs.
    property <int> reopen-chain-row: -987654;
    property <length> menu-w: 250px;
    property <length> est-h: root.entries.length * 30px + 12px;
    // flip flyouts to the left when the card sits in the right of the window.
    property <bool> open-left: root.menu-x > root.width * 0.6;

    // ---- full-window click-away catcher ----
    // Left-click away = plain dismiss (unchanged). A RIGHT-click while a menu is open should
    // CHAIN instead of just swallowing the event: close this menu and open the one under the
    // new cursor in a single action. We can't add a dedicated callback (app.slint is frozen,
    // owned by another track), so we reuse `pick()` with an out-of-range sentinel row — the
    // same encode-on-a-frozen-callback trick app.rs uses for `open-project`. app.rs sees the
    // sentinel, reads the global cursor, hit-tests it, and reopens the matching menu (the (x,y)
    // ride along via the cursor, so the callback needs no params).
    away := TouchArea {
        clicked => { root.dismiss(); }
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right) {
                root.pick(root.reopen-chain-row);
            }
        }
    }

    // ---- the menu card ----
    card := Rectangle {
        x: min(max(root.menu-x, 4px), root.width - root.menu-w - 4px);
        y: min(max(root.menu-y, 4px), max(4px, root.height - root.est-h - 4px));
        width: root.menu-w;
        // hug the rows: size to the column's content, not the parent (fixes the dead
        // gap below the last row). The y-clamp above keeps using `est-h` so a menu near
        // the bottom edge still flips up.
        height: menucol.preferred-height;
        background: Theme.mantle;
        border-radius: 9px;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-blur: 40px;
        drop-shadow-color: Theme.scrim;
        drop-shadow-offset-y: 14px;

        menucol := VerticalLayout {
            padding: 5px;
            spacing: 1px;

            for entry[i] in root.entries : Rectangle {
                height: entry.kind == -1 ? 9px : 30px;

                // separator
                if entry.kind == -1 : Rectangle {
                    y: 4px;
                    height: 1px;
                    background: Theme.border;
                }

                // a real row (item or submenu header)
                if entry.kind != -1 : row := CtxRow {
                    e: entry;
                    has-sub: entry.kind >= 2;
                    sub-open: root.open-sub == i;
                    // Submenus (Layout ▸ etc.) open on hover; hovering a plain row closes any
                    // open submenu. Acting only on the rising edge (h) means moving the pointer
                    // off the row into its flyout does NOT close it — the flyout sits flush to
                    // the row's edge, so there's no plain-row hover in between (no flicker).
                    hover-changed(h) => {
                        if (h) {
                            root.open-sub = entry.kind >= 2 ? i : -1;
                        }
                    }
                    clicked => {
                        if (entry.kind >= 2) {
                            root.open-sub = i;
                        } else {
                            root.pick(i);
                        }
                    }
                }

                // ---- Change Color flyout ----
                if entry.kind == 2 && root.open-sub == i : Flyout {
                    x: root.open-left ? -self.width + 2px : parent.width - 2px;
                    y: -4px;
                    width: 232px;
                    height: vbox-color.preferred-height;
                    vbox-color := VerticalLayout {
                        padding: 8px;
                        spacing: 6px;
                        // swatch row: a "no color" chip + the palette slots
                        HorizontalLayout {
                            spacing: 5px;
                            alignment: start;
                            Rectangle {
                                width: 20px;
                                height: 20px;
                                border-radius: 5px;
                                border-width: 1px;
                                border-color: (!root.frame-on && !root.dot-on) ? Theme.text : Theme.border;
                                // "no color" — a Photoshop-style red diagonal slash.
                                Path {
                                    width: 100%;
                                    height: 100%;
                                    viewbox-width: 20;
                                    viewbox-height: 20;
                                    stroke: Theme.danger;
                                    stroke-width: 1.6px;
                                    commands: "M 4 16 L 16 4";
                                }
                                TouchArea { clicked => { root.swatch-none(); } }
                            }
                            for c[ci] in root.swatches : Rectangle {
                                width: 20px;
                                height: 20px;
                                border-radius: 5px;
                                background: c;
                                border-width: (ci == root.cur-swatch && root.frame-on) ? 2px : 0px;
                                border-color: Theme.text;
                                TouchArea { clicked => { root.swatch(ci); } }
                            }
                        }
                        CtxToggle { label: "Show Frame"; on: root.frame-on; toggled(v) => { root.set-frame(v); } }
                        CtxToggle { label: "Show Dot"; on: root.dot-on; toggled(v) => { root.set-dot(v); } }
                    }
                }

                // ---- Move to Tab flyout ----
                if entry.kind == 3 && root.open-sub == i : Flyout {
                    x: root.open-left ? -self.width + 2px : parent.width - 2px;
                    y: -4px;
                    width: 200px;
                    height: vbox-tab.preferred-height;
                    vbox-tab := VerticalLayout {
                        padding: 5px;
                        spacing: 1px;
                        for tb in root.tabs : CtxRow {
                            e: { label: tb.label, shortcut: "", glyph: "", kind: 0, checked: false, show-check: false, disabled: false, danger: false };
                            clicked => { root.move-tab(tb.idx); }
                        }
                    }
                }

                // ---- Reminder flyout (quick offsets + an inline Custom duration) ----
                if entry.kind == 5 && root.open-sub == i : Flyout {
                    x: root.open-left ? -self.width + 2px : parent.width - 2px;
                    y: -4px;
                    width: 208px;
                    height: vbox-remind.preferred-height;
                    // pick(custom-remind-base + minutes) smuggles the Custom minutes
                    // through the frozen pick(int) channel — kept in sync with
                    // CTX_CUSTOM_REMIND_BASE in contextmenu.rs.
                    property <int> custom-remind-base: 1000000;
                    vbox-remind := VerticalLayout {
                        padding: 5px;
                        spacing: 1px;
                        // The quick offsets dispatch through hidden command slots appended
                        // PAST the visible rows (see pane_menu's b.extra) — row order here
                        // must match that append order.
                        for off[j] in ["In 15 min", "In 1 hour", "In 3 hours", "Tomorrow 9 AM"] : CtxRow {
                            e: { label: off, shortcut: "", glyph: "", kind: 0, checked: false, show-check: false, disabled: false, danger: false };
                            clicked => { root.pick(root.entries.length + j); }
                        }
                        Rectangle {
                            height: 9px;
                            Rectangle { y: 4px; height: 1px; background: Theme.border; }
                        }
                        // Custom…: type a duration (45 · 90m · 1h30 · 14:30), Enter parks.
                        // Validity is re-checked per keystroke via the Rust parser; the
                        // border tints accent (good) / danger (won't submit).
                        crow := Rectangle {
                            property <int> parsed: -1;
                            height: 30px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: ci.text == "" ? Theme.border
                                        : crow.parsed > 0 ? Theme.accent : Theme.danger;
                            HorizontalLayout {
                                padding-left: 9px;
                                padding-right: 9px;
                                Rectangle {
                                    clip: true;
                                    if ci.text == "" : Text {
                                        text: "Custom: 45 · 1h30 · 14:30";
                                        width: 100%;
                                        height: 100%;
                                        color: Theme.faint;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                    ci := TextInput {
                                        width: 100%;
                                        height: 100%;
                                        color: Theme.text;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        single-line: true;
                                        init => { self.focus(); }
                                        edited => { crow.parsed = ReminderCustom.parse-minutes(self.text); }
                                        accepted => {
                                            if (crow.parsed > 0) {
                                                root.pick(custom-remind-base + crow.parsed);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // ---- Layout flyout (glyph · label · "— resolved" hint · radio ✓) ----
                if entry.kind == 4 && root.open-sub == i : Flyout {
                    x: root.open-left ? -self.width + 2px : parent.width - 2px;
                    y: -4px;
                    width: 232px;
                    height: vbox-layout.preferred-height;
                    vbox-layout := VerticalLayout {
                        padding: 5px;
                        spacing: 1px;
                        for lo in root.layouts : CtxRow {
                            e: { label: lo.label, shortcut: lo.hint, glyph: lo.glyph, kind: 0, checked: lo.active, show-check: true, disabled: false, danger: false };
                            clicked => { root.set-layout(lo.id); }
                        }
                    }
                }
            }
        }
    }
}
