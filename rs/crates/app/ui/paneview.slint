// The pane area: absolutely-positions the active tab's `TerminalPane`s at the
// rects the Rust controller computes, draws the focus ring + draggable resize
// dividers over them, and reserves an overlay slot for Wave-2 panels.

import { Theme } from "theme.slint";
import { PaneItem, DividerItem, PaletteItem, PrefOption, FramePaletteOption } from "types.slint";
import { TerminalPane, KeyMsg } from "@widgets";

// A draggable resize seam. Reports the cursor's offset from the seam centre each
// move; the controller converts that to a size-fraction delta and re-tiles, which
// re-centres the handle under the cursor (so the drag is self-correcting).
component DividerHandle inherits Rectangle {
    in property <DividerItem> desc;
    callback drag(int, bool, bool, length, length);

    x: desc.x;
    y: desc.y;
    width: desc.w;
    height: desc.h;

    // hairline, brightens on hover/drag
    Rectangle {
        width: desc.vertical ? 1px : parent.width;
        height: desc.vertical ? parent.height : 1px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: ta.has-hover || ta.pressed ? Theme.brand : #ffffff14;
        animate background { duration: 90ms; }
    }

    ta := TouchArea {
        mouse-cursor: desc.vertical ? ew-resize : ns-resize;
        moved => {
            root.drag(desc.index, desc.main, desc.vertical,
                      self.mouse-x - root.width / 2, self.mouse-y - root.height / 2);
        }
    }
}

// Vector pane-header icons (font-independent, so they always render).
component IconZoom inherits Path {
    in property <color> ink;
    width: 14px; height: 14px;
    viewbox-width: 16; viewbox-height: 16;
    stroke: ink; stroke-width: 1.6px; fill: transparent;
    // diagonal double-headed arrow (⤢ maximize-in-window)
    commands: "M 5 11 L 11 5 M 7.5 5 L 11 5 L 11 8.5 M 8.5 11 L 5 11 L 5 7.5";
}

component IconFull inherits Path {
    in property <color> ink;
    width: 14px; height: 14px;
    viewbox-width: 16; viewbox-height: 16;
    stroke: ink; stroke-width: 1.6px; fill: transparent;
    // corner brackets (⛶ fullscreen)
    commands: "M 4 7 L 4 4 L 7 4 M 9 4 L 12 4 L 12 7 M 12 9 L 12 12 L 9 12 M 7 12 L 4 12 L 4 9";
}

component IconX inherits Path {
    in property <color> ink;
    width: 14px; height: 14px;
    viewbox-width: 16; viewbox-height: 16;
    stroke: ink; stroke-width: 1.6px; fill: transparent;
    commands: "M 5 5 L 11 11 M 11 5 L 5 11";
}

// A pane-header button (`.hp-pane-btn`). kind: 0 zoom · 1 fullscreen · 2 close.
component PaneBtn inherits Rectangle {
    in property <int> kind;
    in property <bool> active: false;
    in property <bool> danger: false;
    callback clicked;
    width: 18px;
    height: 18px;
    border-radius: 4px;
    background: root.active ? Theme.accent
              : ta.has-hover ? (root.danger ? #f38ba833 : Theme.surface2)
              : transparent;
    property <color> ink: root.active ? #11111b
             : (ta.has-hover && root.danger) ? #f38ba8
             : ta.has-hover ? Theme.text
             : Theme.subtext;

    if root.kind == 0 : IconZoom {
        x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink;
    }
    if root.kind == 1 : IconFull {
        x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink;
    }
    if root.kind == 2 : IconX {
        x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink;
    }

    ta := TouchArea { clicked => { root.clicked(); } }
}

// ---- single-layout pane taskbar (the native port of PaneTaskbar.tsx) ----

// One pane button in the strip: a colour dot + the pane label (+ an "exited" badge). The
// active button is the currently-shown pane (group.focusedId). Left-click shows the pane,
// middle-click closes it, right-click opens the pane menu (the `inTaskbar` variant).
component TaskItem inherits Rectangle {
    in property <PaneItem> p;
    callback show();
    callback close();
    callback context(length, length);

    min-width: 78px;
    max-width: 220px;
    horizontal-stretch: 0;
    height: 26px;
    border-radius: 6px;
    background: root.p.focused ? Theme.surface2 : (ta.has-hover ? Theme.surface : transparent);
    border-width: root.p.focused ? 1px : 0px;
    border-color: root.p.accent;

    HorizontalLayout {
        padding-left: 9px;
        padding-right: 9px;
        spacing: 6px;
        // colour dot (pane.color)
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: root.p.accent;
            }
        }
        Text {
            text: root.p.title == "" ? "pane" : root.p.title;
            color: root.p.focused ? Theme.text : Theme.subtext;
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        // "exited" badge (shown if the pane's shell has exited)
        if root.p.exited : VerticalLayout {
            alignment: center;
            Rectangle {
                background: #f38ba822;
                border-radius: 4px;
                HorizontalLayout {
                    padding-left: 5px;
                    padding-right: 5px;
                    Text {
                        text: "exited";
                        color: Theme.danger;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    ta := TouchArea {
        clicked => { root.show(); }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.middle) {
                root.close();
            }
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                root.context(self.absolute-position.x + self.mouse-x,
                             self.absolute-position.y + self.mouse-y);
            }
        }
    }
}

component PaneTaskbar inherits Rectangle {
    in property <[PaneItem]> panes;
    callback show(int);
    callback close(int);
    callback context(int, length, length);

    height: 34px;
    background: Theme.mantle;
    // top hairline
    Rectangle { y: 0; height: 1px; background: Theme.border; }

    HorizontalLayout {
        padding: 4px;
        padding-left: 6px;
        padding-right: 6px;
        spacing: 4px;
        alignment: start;
        for pane[idx] in root.panes : TaskItem {
            p: pane;
            show => { root.show(idx); }
            close => { root.close(idx); }
            context(x, y) => { root.context(idx, x, y); }
        }
    }
}

export component PaneView inherits Rectangle {
    in property <[PaneItem]> panes;
    in property <[DividerItem]> dividers;
    in property <bool> zoomed: false;
    in property <bool> fullscreen: false;
    // Single-layout pane taskbar: show the bottom strip (Rust gates it to layout==single,
    // panes>1, not fullscreen). The strip reuses the `panes` model.
    in property <bool> taskbar-visible: false;
    // Wave-2 appearance prefs applied to the panes themselves.
    in property <bool> show-frame: true;
    in property <bool> show-dot: true;
    // Wave-2 overlay/panel slot (0 none · 1 palette · 2 prefs · 3 sidebar).
    in property <int> overlay-kind: 0;
    in property <[PaletteItem]> palette;
    in property <int> palette-sel: 0;
    in property <[PrefOption]> pref-families;
    in property <string> pref-font-label;
    in property <bool> pref-font-custom: false;
    in property <string> pref-font-custom-value: "";
    in property <string> pref-preview-font;
    in property <color> pref-preview-accent;
    in property <color> pref-preview-bg;
    in property <color> pref-preview-fg;
    in property <color> pref-preview-green;
    in property <color> pref-preview-blue;
    in property <color> pref-preview-dim;
    in property <[PrefOption]> pref-themes;
    in property <string> pref-theme-label;
    in property <[FramePaletteOption]> pref-palettes;
    in property <[PrefOption]> pref-shells;
    in property <bool> pref-clickable: true;
    in property <string> pref-editor: "";
    in property <bool> prefs-confirm: false;
    in property <int> pref-fontpx: 14;
    in property <bool> pref-frame: true;
    in property <bool> pref-dot: true;
    // ---- drag / tear-off slot preview (area-relative logical px) ----
    in property <length> drop-rect-x: 0px;
    in property <length> drop-rect-y: 0px;
    in property <length> drop-rect-w: 0px;
    in property <length> drop-rect-h: 0px;
    in property <int> drop-rect-edge: 0;   // 0 left · 1 right · 2 top · 3 bottom
    in property <bool> drop-rect-active: false;

    callback pane-grab(int);
    callback pane-context(int, length, length);   // right-click the header → open the pane menu
    callback taskbar-context(int, length, length); // right-click a taskbar button → pane menu (inTaskbar)
    callback key(int, KeyMsg);
    callback focus-pane(int);
    callback area-resized(length, length);
    callback divider-drag(int, bool, bool, length, length);
    callback pane-zoom(int);
    callback pane-fullscreen(int);
    callback pane-close(int);
    // pane-header inline rename (double-click the header label).
    callback begin-rename-pane(int);
    callback rename-pane(int, string);
    // clickable-paths: surface geometry (for hit-testing) + hover/click reports.
    callback pane-geometry(int, length, length);
    callback pane-link-moved(int, length, length);
    callback pane-link-exited(int);
    callback pane-link-activated(int, length, length, bool);
    // Ctrl+wheel over a pane body → zoom the terminal font (±1 px per notch).
    callback pane-font-zoom(int);
    // Plain wheel over a pane body → scroll the scrollback viewport (±lines).
    callback pane-scroll(int, float);
    // text selection (drag to select; copy-on-release) routed from the focused pane.
    callback pane-selection-begin(int, length, length);
    callback pane-selection-update(int, length, length);
    callback pane-selection-end(int);
    // right-click in a pane body → paste the clipboard into that pane's session.
    callback pane-paste(int);
    // in-pane search box (opened from the pane menu's "Search…")
    callback pane-search-edited(int, string);
    callback pane-search-next(int);
    callback pane-search-prev(int);
    callback pane-search-closed(int);
    // Wave-2 overlay callbacks (each maps to a Command in the controller).
    callback palette-query(string);
    callback palette-nav(int);
    callback palette-activate();
    callback palette-pick(int);
    callback pref-action(int, int);
    callback pref-text(int, string);
    callback pref-done();
    callback pref-confirm(int);
    callback overlay-dismiss();

    background: Theme.bg;
    clip: true;

    VerticalLayout {
        spacing: 0px;

        area := Rectangle {
            vertical-stretch: 1;
            changed width => { root.area-resized(self.width, self.height); }
            changed height => { root.area-resized(self.width, self.height); }

        // Electron `.hp-pane`: 7px radius, 1px border (accent when focused), the
        // pane bg, no drop shadow — a 26px header bar (title + zoom/fullscreen/
        // close) over a padded body that holds the chrome-off terminal surface.
        for pane[idx] in root.panes : Rectangle {
            x: pane.x;
            y: pane.y;
            width: pane.w;
            height: pane.h;
            visible: pane.visible;
            background: Theme.bg;
            border-radius: 7px;
            // Frame border: a project/coloured pane (pane.show-frame on) draws its accent
            // border; a clean pane shows none, except an accent focus ring so the focused
            // pane is still visible (mirrors PaneFrame's `frameOn ? color : accent-ring`).
            border-width: pane.show-frame ? 1px : (pane.focused ? 1px : 0px);
            border-color: pane.show-frame
                ? (pane.focused ? pane.accent : Theme.border)
                : (pane.focused ? Theme.accent : transparent);
            clip: true;

            VerticalLayout {
                // ---- header (.hp-pane-header) ----
                Rectangle {
                    height: 26px;
                    // Header tint: a faint wash of the pane's accent when its frame is on
                    // (a git-project / manually-coloured pane). A clean pane shows no tint —
                    // matching the Electron `background: frameOn ? ${color}1a` header.
                    Rectangle {
                        background: pane.show-frame ? pane.accent.with-alpha(0.10) : transparent;
                    }
                    // bottom hairline
                    Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
                    // header click focuses the pane (sits under the buttons); a press also
                    // arms a drag — the drag pump promotes it past the threshold (else it
                    // stays a plain click).
                    TouchArea {
                        // The open/closed-hand cursor over this header is driven from Win32
                        // (window.rs) so it can be a real hand + persist across the tear-off.
                        clicked => { root.focus-pane(idx); tp.focus(); }
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                                root.pane-grab(idx);
                            }
                            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right) {
                                root.pane-context(idx, self.absolute-position.x + self.mouse-x,
                                                       self.absolute-position.y + self.mouse-y);
                            }
                        }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 6px;
                        // accent color dot (per-pane toggle; on for project panes)
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                background: pane.accent;
                                visible: pane.show-dot;
                            }
                        }
                        // ---- editable label + secondary line (subtitle / shell title) ----
                        // Double-click to rename (mirrors the Electron EditableLabel); a
                        // left-press here ALSO arms the pane drag (see lta below), so the
                        // whole header except the buttons is a drag handle.
                        Rectangle {
                            horizontal-stretch: 1;
                            clip: true;
                            // Title + secondary line laid out SIDE BY SIDE (the title at its
                            // natural width, the subtitle filling the rest and eliding). The
                            // shell's OSC title (e.g. pwsh's exe path) is noise — like Electron
                            // it is NOT shown inline; only a real / ambient-AI subtitle appears.
                            HorizontalLayout {
                                alignment: start;
                                spacing: 8px;
                                visible: !pane.editing;
                                Text {
                                    text: pane.title;
                                    color: pane.focused ? Theme.text : Theme.subtext;
                                    font-size: 11px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                    horizontal-alignment: left;
                                    // Elide a long title (e.g. an auto-title that defaulted to a
                                    // huge command) so it can't blow up the header min-width and
                                    // push the buttons off / cover the drag strip.
                                    overflow: elide;
                                }
                                // shell-type badge: a dim, smaller label right after the title
                                // in the same row (e.g. `claude` ‹dim›pwsh›). Shown only when
                                // the controller resolved a shell program for the pane.
                                if pane.shell-type != "" : Text {
                                    text: pane.shell-type;
                                    color: Theme.subtext;
                                    opacity: 0.6;
                                    font-size: 9px;
                                    vertical-alignment: center;
                                    horizontal-alignment: left;
                                    overflow: elide;
                                }
                                if pane.subtitle != "" : Text {
                                    text: pane.subtitle;
                                    color: Theme.subtext;
                                    font-size: 9px;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                    horizontal-alignment: left;
                                    overflow: elide;
                                }
                                // ambient-AI "what you're doing" line (typewriter-revealed by
                                // the controller), shown only when no manual subtitle wins.
                                if pane.subtitle == "" && pane.ai-subtitle != "" : Text {
                                    text: pane.ai-subtitle;
                                    color: Theme.accent;
                                    font-size: 9px;
                                    font-italic: true;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                    horizontal-alignment: left;
                                    overflow: elide;
                                }
                            }
                            // single-click focuses; double-click opens the inline editor.
                            // A child TouchArea swallows pointer events in Slint, and this one
                            // covers most of the header (the label stretches), so it must
                            // DELEGATE a left-press to the same pane-grab as the header
                            // TouchArea behind it — otherwise drag-to-rearrange only works in
                            // the slivers outside the label (#5). Arming is movement-gated by
                            // the drag pump, so click-to-focus and double-click-to-rename
                            // still resolve normally.
                            lta := TouchArea {
                                enabled: !pane.editing;
                                clicked => { root.focus-pane(idx); tp.focus(); }
                                double-clicked => { root.begin-rename-pane(idx); }
                                pointer-event(ev) => {
                                    if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                                        root.pane-grab(idx);
                                    }
                                    if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right) {
                                        root.pane-context(idx, self.absolute-position.x + self.mouse-x,
                                                               self.absolute-position.y + self.mouse-y);
                                    }
                                }
                            }
                            // inline rename editor (absolute overlay → never reflows chrome)
                            if pane.editing : Rectangle {
                                background: Theme.bg;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: Theme.accent;
                                height: 20px;
                                y: (parent.height - self.height) / 2;
                                lti := TextInput {
                                    x: 5px;
                                    width: parent.width - 10px;
                                    height: parent.height;
                                    text: pane.title;
                                    color: Theme.text;
                                    font-size: 11px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                    single-line: true;
                                    init => { lti.select-all(); lti.focus(); }
                                    accepted => { root.rename-pane(idx, self.text); }
                                }
                            }
                        }
                        // each wrapped so it centres vertically against the title
                        VerticalLayout {
                            alignment: center;
                            PaneBtn {
                                kind: 0;
                                active: root.zoomed && pane.focused;
                                clicked => { root.pane-zoom(idx); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            PaneBtn {
                                kind: 1;
                                active: root.fullscreen && pane.focused;
                                clicked => { root.pane-fullscreen(idx); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            PaneBtn {
                                kind: 2;
                                danger: true;
                                clicked => { root.pane-close(idx); }
                            }
                        }
                    }
                }

                // ---- body (.hp-pane-body, padding 2 0 2 4) ----
                Rectangle {
                    vertical-stretch: 1;
                    // Ctrl+wheel zooms the terminal font (parity with editors/terminals). The
                    // TerminalPane's own pointer area doesn't handle scroll, so the event bubbles
                    // up to this ancestor TouchArea; plain (no-Ctrl) scrolls are rejected so they
                    // fall through unchanged. Wheel up → zoom in, down → zoom out.
                    TouchArea {
                        scroll-event(e) => {
                            if (e.modifiers.control || e.modifiers.meta) {
                                if (e.delta-y > 0) {
                                    root.pane-font-zoom(1);
                                } else if (e.delta-y < 0) {
                                    root.pane-font-zoom(-1);
                                }
                                return accept;
                            }
                            return reject;
                        }
                    tp := TerminalPane {
                        x: 4px;
                        y: 2px;
                        width: parent.width - 4px;
                        height: parent.height - 4px;
                        surface: pane.surface;
                        accent: pane.accent;
                        chrome: false;
                        // clickable-path hover overlay (controller-driven after hit-testing)
                        link-visible: pane.link-visible;
                        link-x: pane.link-x;
                        link-y: pane.link-y;
                        link-w: pane.link-w;
                        link-tip: pane.link-tip;
                        link-tip-x: pane.link-tip-x;
                        link-tip-y: pane.link-tip-y;
                        // in-pane search box (controller-driven; opened from the pane menu)
                        search-open: pane.search-open;
                        search-count: pane.search-count;
                        // bump → (re)focus the query input (reliable across an already-open box)
                        search-focus-tick: pane.search-focus-seq;
                        // match highlights painted over the terminal (controller-driven, per tick)
                        search-rects: pane.search-rects;
                        search-active-on: pane.search-active-on;
                        search-active-rect: pane.search-active-rect;
                        // drag-to-select highlight rects (controller-driven, per tick)
                        selection-rects: pane.selection-rects;
                        // transient bottom-right indicator (copy/paste + Ctrl-zoom font %)
                        toast: pane.toast;
                        // live terminal font px → toast + search box scale with zoom
                        term-font-px: pane.font-px;
                        selection-begin(x, y) => { root.pane-selection-begin(idx, x, y); }
                        selection-update(x, y) => { root.pane-selection-update(idx, x, y); }
                        selection-end => { root.pane-selection-end(idx); }
                        paste-requested => { root.pane-paste(idx); }
                        search-edited(q) => { root.pane-search-edited(idx, q); }
                        search-next => { root.pane-search-next(idx); }
                        search-prev => { root.pane-search-prev(idx); }
                        search-closed => { root.pane-search-closed(idx); }
                        key(m) => { root.key(idx, m); }
                        geometry-changed(w, h) => { root.pane-geometry(idx, w, h); }
                        scroll-requested(d) => { root.pane-scroll(idx, d); }
                        link-moved(x, y) => { root.pane-link-moved(idx, x, y); }
                        link-exited => { root.pane-link-exited(idx); }
                        // Click anywhere in the pane body (incl. blank terminal area) focuses
                        // it. Today the widget reports every left-down through `link-activated`
                        // (the focus side-effect below), so clicking blank space already
                        // focuses pane `idx`.
                        //
                        // FROZEN CONTRACT (lands at fan-in): the terminal-io track adds a
                        // dedicated `focus-requested` callback to TerminalPane, fired on
                        // mouse-down. Once it's on the widget, uncomment the line below — it's
                        // the canonical focus wire and is robust even if `link-activated`
                        // narrows to real links only:
                        //   focus-requested => { root.focus-pane(idx); }
                        link-activated(x, y, ctrl) => {
                            root.focus-pane(idx);
                            root.pane-link-activated(idx, x, y, ctrl);
                        }
                    }
                    }
                }
            }
        }

        // idle glow: an accent-tinted glow on the pane FRAME once it has gone output-quiet
        // (the AI-pane quiescence effect). `pane.glow` is the animated opacity the controller
        // computes each tick (firefly/pulse/blink/solid); 0 = no glow. Confined to the frame —
        // a bright ring on the border plus a softer inner ring for bloom — so it never bleeds
        // a halo over neighbouring panes or the terminal content.
        for pane[idx] in root.panes : Rectangle {
            visible: pane.visible && pane.glow > 0.01;
            x: pane.x;
            y: pane.y;
            width: pane.w;
            height: pane.h;
            border-radius: 7px;
            border-width: 2px;
            border-color: pane.accent.with-alpha(pane.glow);
            // softer inner ring, inset so the whole effect stays within the pane footprint.
            Rectangle {
                x: 2px;
                y: 2px;
                width: parent.width - 4px;
                height: parent.height - 4px;
                border-radius: 5px;
                border-width: 1px;
                border-color: pane.accent.with-alpha(pane.glow * 0.45);
            }
        }

        // resize seams, drawn over the panes
        for d in root.dividers : DividerHandle {
            desc: d;
            drag(i, main, vert, dx, dy) => { root.divider-drag(i, main, vert, dx, dy); }
        }

        // drag/tear-off slot preview: a tinted highlight over the hovered tile + a thick
        // accent bar on the near edge marking exactly where the pane will land.
        if root.drop-rect-active : Rectangle {
            x: root.drop-rect-x;
            y: root.drop-rect-y;
            width: root.drop-rect-w;
            height: root.drop-rect-h;
            // alpha in the COLOR, not element opacity (which would also dim the border).
            background: Theme.brand.with-alpha(0.16);
            border-radius: 7px;
            border-width: 2.5px;
            border-color: Theme.brand;
            // near-edge marker (left/right → vertical bar; top/bottom → horizontal bar)
            Rectangle {
                background: Theme.brand;
                border-radius: 2px;
                width: (root.drop-rect-edge == 0 || root.drop-rect-edge == 1) ? 4px : parent.width;
                height: (root.drop-rect-edge == 0 || root.drop-rect-edge == 1) ? parent.height : 4px;
                x: root.drop-rect-edge == 1 ? parent.width - self.width
                 : root.drop-rect-edge == 0 ? 0px
                 : 0px;
                y: root.drop-rect-edge == 3 ? parent.height - self.height
                 : 0px;
            }
        }

        // empty-state hint
        if root.panes.length == 0 : Text {
            text: "starting shell…";
            color: #44444f;
            font-size: 14px;
        }
        }   // end `area`

        // single-layout pane taskbar (hidden panes strip) — sits below the pane area so the
        // panes reflow above it (area-resized fires with the reduced height).
        if root.taskbar-visible : PaneTaskbar {
            panes: root.panes;
            show(i) => { root.focus-pane(i); }
            close(i) => { root.pane-close(i); }
            context(i, x, y) => { root.taskbar-context(i, x, y); }
        }
    }

    // (The Wave-2 overlay — command palette / preferences — is mounted at the app root
    //  now, so its frosted scrim covers the top bar + sidebar too; see app.slint.)
}
