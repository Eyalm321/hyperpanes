// The pane area: absolutely-positions the active tab's `TerminalPane`s at the
// rects the Rust controller computes, draws the focus ring + draggable resize
// dividers over them, and reserves an overlay slot for Wave-2 panels.

import { Theme } from "theme.slint";
import { PaneItem, DividerItem, PaletteItem, PrefOption, FramePaletteOption } from "types.slint";
import { OverlayLayer } from "overlays.slint";
import { TerminalPane, KeyMsg } from "@widgets";

// A draggable resize seam. Reports the cursor's offset from the seam centre each
// move; the controller converts that to a size-fraction delta and re-tiles, which
// re-centres the handle under the cursor (so the drag is self-correcting).
component DividerHandle inherits Rectangle {
    in property <DividerItem> desc;
    callback drag(int, bool, bool, length, length);

    x: desc.x;
    y: desc.y;
    width: desc.w;
    height: desc.h;

    // hairline, brightens on hover/drag
    Rectangle {
        width: desc.vertical ? 1px : parent.width;
        height: desc.vertical ? parent.height : 1px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: ta.has-hover || ta.pressed ? Theme.brand : #ffffff14;
        animate background { duration: 90ms; }
    }

    ta := TouchArea {
        mouse-cursor: desc.vertical ? ew-resize : ns-resize;
        moved => {
            root.drag(desc.index, desc.main, desc.vertical,
                      self.mouse-x - root.width / 2, self.mouse-y - root.height / 2);
        }
    }
}

// Vector pane-header icons (font-independent, so they always render).
component IconZoom inherits Path {
    in property <color> ink;
    width: 14px; height: 14px;
    viewbox-width: 16; viewbox-height: 16;
    stroke: ink; stroke-width: 1.6px; fill: transparent;
    // diagonal double-headed arrow (⤢ maximize-in-window)
    commands: "M 5 11 L 11 5 M 7.5 5 L 11 5 L 11 8.5 M 8.5 11 L 5 11 L 5 7.5";
}

component IconFull inherits Path {
    in property <color> ink;
    width: 14px; height: 14px;
    viewbox-width: 16; viewbox-height: 16;
    stroke: ink; stroke-width: 1.6px; fill: transparent;
    // corner brackets (⛶ fullscreen)
    commands: "M 4 7 L 4 4 L 7 4 M 9 4 L 12 4 L 12 7 M 12 9 L 12 12 L 9 12 M 7 12 L 4 12 L 4 9";
}

component IconX inherits Path {
    in property <color> ink;
    width: 14px; height: 14px;
    viewbox-width: 16; viewbox-height: 16;
    stroke: ink; stroke-width: 1.6px; fill: transparent;
    commands: "M 5 5 L 11 11 M 11 5 L 5 11";
}

// A pane-header button (`.hp-pane-btn`). kind: 0 zoom · 1 fullscreen · 2 close.
component PaneBtn inherits Rectangle {
    in property <int> kind;
    in property <bool> active: false;
    in property <bool> danger: false;
    callback clicked;
    width: 18px;
    height: 18px;
    border-radius: 4px;
    background: root.active ? Theme.accent
              : ta.has-hover ? (root.danger ? #f38ba833 : Theme.surface2)
              : transparent;
    property <color> ink: root.active ? #11111b
             : (ta.has-hover && root.danger) ? #f38ba8
             : ta.has-hover ? Theme.text
             : Theme.subtext;

    if root.kind == 0 : IconZoom {
        x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink;
    }
    if root.kind == 1 : IconFull {
        x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink;
    }
    if root.kind == 2 : IconX {
        x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; ink: root.ink;
    }

    ta := TouchArea { clicked => { root.clicked(); } }
}

export component PaneView inherits Rectangle {
    in property <[PaneItem]> panes;
    in property <[DividerItem]> dividers;
    in property <bool> zoomed: false;
    in property <bool> fullscreen: false;
    // Wave-2 appearance prefs applied to the panes themselves.
    in property <bool> show-frame: true;
    in property <bool> show-dot: true;
    // Wave-2 overlay/panel slot (0 none · 1 palette · 2 prefs · 3 sidebar).
    in property <int> overlay-kind: 0;
    in property <[PaletteItem]> palette;
    in property <int> palette-sel: 0;
    in property <[PrefOption]> pref-families;
    in property <string> pref-font-label;
    in property <[FramePaletteOption]> pref-palettes;
    in property <[PrefOption]> pref-shells;
    in property <bool> pref-clickable: true;
    in property <string> pref-editor: "";
    in property <int> pref-fontpx: 14;
    in property <bool> pref-frame: true;
    in property <bool> pref-dot: true;
    // ---- drag / tear-off slot preview (area-relative logical px) ----
    in property <length> drop-rect-x: 0px;
    in property <length> drop-rect-y: 0px;
    in property <length> drop-rect-w: 0px;
    in property <length> drop-rect-h: 0px;
    in property <int> drop-rect-edge: 0;   // 0 left · 1 right · 2 top · 3 bottom
    in property <bool> drop-rect-active: false;

    callback pane-grab(int);
    callback key(int, KeyMsg);
    callback focus-pane(int);
    callback area-resized(length, length);
    callback divider-drag(int, bool, bool, length, length);
    callback pane-zoom(int);
    callback pane-fullscreen(int);
    callback pane-close(int);
    // clickable-paths: surface geometry (for hit-testing) + hover/click reports.
    callback pane-geometry(int, length, length);
    callback pane-link-moved(int, length, length);
    callback pane-link-exited(int);
    callback pane-link-activated(int, length, length, bool);
    // Wave-2 overlay callbacks (each maps to a Command in the controller).
    callback palette-query(string);
    callback palette-nav(int);
    callback palette-activate();
    callback palette-pick(int);
    callback pref-action(int, int);
    callback pref-text(int, string);
    callback overlay-dismiss();

    background: Theme.bg;
    clip: true;

    area := Rectangle {
        changed width => { root.area-resized(self.width, self.height); }
        changed height => { root.area-resized(self.width, self.height); }

        // Electron `.hp-pane`: 7px radius, 1px border (accent when focused), the
        // pane bg, no drop shadow — a 26px header bar (title + zoom/fullscreen/
        // close) over a padded body that holds the chrome-off terminal surface.
        for pane[idx] in root.panes : Rectangle {
            x: pane.x;
            y: pane.y;
            width: pane.w;
            height: pane.h;
            visible: pane.visible;
            background: Theme.bg;
            border-radius: 7px;
            // Frame border: accent when focused; hidden entirely when the frame pref
            // is off (a hairline border still separates focused panes).
            border-width: root.show-frame ? 1px : (pane.focused ? 1px : 0px);
            border-color: root.show-frame
                ? (pane.focused ? pane.accent : Theme.border)
                : (pane.focused ? Theme.accent : transparent);
            clip: true;

            VerticalLayout {
                // ---- header (.hp-pane-header) ----
                Rectangle {
                    height: 26px;
                    // bottom hairline
                    Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
                    // header click focuses the pane (sits under the buttons); a press also
                    // arms a drag — the drag pump promotes it past the threshold (else it
                    // stays a plain click).
                    TouchArea {
                        // The open/closed-hand cursor over this header is driven from Win32
                        // (window.rs) so it can be a real hand + persist across the tear-off.
                        clicked => { root.focus-pane(idx); tp.focus(); }
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                                root.pane-grab(idx);
                            }
                        }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 6px;
                        // accent color dot (toggleable via Preferences)
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                background: pane.accent;
                                visible: root.show-dot;
                            }
                        }
                        Text {
                            text: pane.title;
                            color: pane.focused ? Theme.text : Theme.subtext;
                            font-size: 11px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                        // each wrapped so it centres vertically against the title
                        VerticalLayout {
                            alignment: center;
                            PaneBtn {
                                kind: 0;
                                active: root.zoomed && pane.focused;
                                clicked => { root.pane-zoom(idx); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            PaneBtn {
                                kind: 1;
                                active: root.fullscreen && pane.focused;
                                clicked => { root.pane-fullscreen(idx); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            PaneBtn {
                                kind: 2;
                                danger: true;
                                clicked => { root.pane-close(idx); }
                            }
                        }
                    }
                }

                // ---- body (.hp-pane-body, padding 2 0 2 4) ----
                Rectangle {
                    vertical-stretch: 1;
                    tp := TerminalPane {
                        x: 4px;
                        y: 2px;
                        width: parent.width - 4px;
                        height: parent.height - 4px;
                        surface: pane.surface;
                        accent: pane.accent;
                        chrome: false;
                        // clickable-path hover overlay (controller-driven after hit-testing)
                        link-visible: pane.link-visible;
                        link-x: pane.link-x;
                        link-y: pane.link-y;
                        link-w: pane.link-w;
                        link-tip: pane.link-tip;
                        link-tip-x: pane.link-tip-x;
                        link-tip-y: pane.link-tip-y;
                        key(m) => { root.key(idx, m); }
                        geometry-changed(w, h) => { root.pane-geometry(idx, w, h); }
                        link-moved(x, y) => { root.pane-link-moved(idx, x, y); }
                        link-exited => { root.pane-link-exited(idx); }
                        link-activated(x, y, ctrl) => {
                            root.focus-pane(idx);
                            root.pane-link-activated(idx, x, y, ctrl);
                        }
                    }
                }
            }
        }

        // resize seams, drawn over the panes
        for d in root.dividers : DividerHandle {
            desc: d;
            drag(i, main, vert, dx, dy) => { root.divider-drag(i, main, vert, dx, dy); }
        }

        // drag/tear-off slot preview: a tinted highlight over the hovered tile + a thick
        // accent bar on the near edge marking exactly where the pane will land.
        if root.drop-rect-active : Rectangle {
            x: root.drop-rect-x;
            y: root.drop-rect-y;
            width: root.drop-rect-w;
            height: root.drop-rect-h;
            // alpha in the COLOR, not element opacity (which would also dim the border).
            background: Theme.brand.with-alpha(0.16);
            border-radius: 7px;
            border-width: 2.5px;
            border-color: Theme.brand;
            // near-edge marker (left/right → vertical bar; top/bottom → horizontal bar)
            Rectangle {
                background: Theme.brand;
                border-radius: 2px;
                width: (root.drop-rect-edge == 0 || root.drop-rect-edge == 1) ? 4px : parent.width;
                height: (root.drop-rect-edge == 0 || root.drop-rect-edge == 1) ? parent.height : 4px;
                x: root.drop-rect-edge == 1 ? parent.width - self.width
                 : root.drop-rect-edge == 0 ? 0px
                 : 0px;
                y: root.drop-rect-edge == 3 ? parent.height - self.height
                 : 0px;
            }
        }

        // empty-state hint
        if root.panes.length == 0 : Text {
            text: "starting shell…";
            color: #44444f;
            font-size: 14px;
        }
    }

    // ===== Wave-2 overlay/panel slot =====
    // A full-area scrim + the OverlayLayer that hosts the command palette, preferences
    // dialog, and sidebar. Shown whenever `overlay-kind != 0`; a scrim click dismisses.
    // Mounted here so the slot lives in the tree and Wave-2 work never restructures the
    // pane-area layout.
    if root.overlay-kind != 0 : Rectangle {
        // Frosted-glass backdrop (Electron's `.hp-frosted-backdrop`). Slint has no true
        // backdrop blur, so this is a tinted, mostly-opaque dark "glass" approximation.
        background: #0b0c12cc;
        // scrim click dismisses the overlay (the panels eat their own clicks)
        TouchArea { clicked => { root.overlay-dismiss(); } }
        OverlayLayer {
            width: 100%;
            height: 100%;
            kind: root.overlay-kind;
            palette: root.palette;
            palette-sel: root.palette-sel;
            families: root.pref-families;
            font-label: root.pref-font-label;
            frame-palettes: root.pref-palettes;
            shells: root.pref-shells;
            font-px: root.pref-fontpx;
            show-frame: root.pref-frame;
            show-dot: root.pref-dot;
            clickable-paths: root.pref-clickable;
            editor-command: root.pref-editor;
            palette-query(q) => { root.palette-query(q); }
            palette-nav(d) => { root.palette-nav(d); }
            palette-activate => { root.palette-activate(); }
            palette-pick(i) => { root.palette-pick(i); }
            pref-action(k, a) => { root.pref-action(k, a); }
            pref-text(k, v) => { root.pref-text(k, v); }
            dismiss => { root.overlay-dismiss(); }
        }
    }
}
