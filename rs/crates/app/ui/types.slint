// Data rows shared between the Rust controller and the .slint views. The Rust
// side computes every geometry (logical px) and pushes these as models.

// One tiled pane: the rendered terminal surface + its placement + chrome state.
export struct PaneItem {
    surface: image,
    title: string,
    // optional secondary line under the label (user subtitle / ambient-AI line).
    subtitle: string,
    accent: color,
    // resolved per-pane chrome (the per-pane override already folded over the global pref
    // by the controller): a clean new pane is frame/dot OFF; a git-project pane is ON.
    show-frame: bool,
    show-dot: bool,
    // true while this pane's label is being edited inline (double-click the header).
    editing: bool,
    x: length,
    y: length,
    w: length,
    h: length,
    visible: bool,
    focused: bool,
    // idle-glow opacity (0 = no glow): the animated alpha of the pane's accent ring once
    // it has been output-quiet past the idle threshold (driven by the controller per tick).
    glow: float,
    // clickable-path hover overlay (driven by the controller after hit-testing the grid).
    link-visible: bool,
    link-x: length,
    link-y: length,
    link-w: length,
    link-tip: string,
    link-tip-x: length,
    link-tip-y: length,
    // in-pane search box (opened from the pane menu's "Search…"): whether it's showing + the
    // match counter text (e.g. "2 / 5").
    search-open: bool,
    search-count: string,
    // transient bottom-right indicator: copy/paste confirmations + the Ctrl-zoom font "%".
    toast: string,
    // the terminal font size in effect (logical px) — the live zoom / focused-pane font-size
    // state. Drives the widget's `term-font-px` so the toast + search box scale with zoom.
    font-px: length,
    // Whether the pane's shell has exited (drives the single-layout taskbar's "exited"
    // badge). The native app removes a pane the moment its session exits, so this is
    // structurally always false today — kept for Electron parity / a future status model.
    exited: bool,
}

// One tab (workspace group) chip in the strip.
export struct TabItem {
    title: string,
    active: bool,
}

// A draggable resize seam (vertical column / horizontal row / main-stack main).
export struct DividerItem {
    x: length,
    y: length,
    w: length,
    h: length,
    vertical: bool,
    // boundary after pane `index` (kind Size); -1 for the main-stack divider.
    index: int,
    main: bool,
}

// One entry in the layout-picker menu.
export struct LayoutOption {
    id: int,        // matches the Rust Layout discriminant order
    label: string,
    glyph: string,
    active: bool,
    // optional dim hint shown to the right (e.g. the "— grid" the Automatic row resolves
    // to right now in the application menu's Layout submenu); "" = none.
    hint: string,
}

// ===== Wave-2 overlay rows =====

// One visible command-palette row (already filtered + ranked by Rust).
export struct PaletteItem {
    title: string,
    subtitle: string,
}

// One git-project row in the sidebar panel.
export struct ProjectItem {
    name: string,
    color: color,
}

// One option in a preferences picker (font family). `active` marks the current value.
export struct PrefOption {
    id: int,
    label: string,
    active: bool,
}

// One row in the Preferences → Keybindings editor (the EFFECTIVE keymap — overrides over
// defaults): a stable `id` (keys the rebind/reset callbacks), a human label, the chord as
// `<kbd>`-chip parts (e.g. ["Ctrl","Shift","P"]), its category, whether it's the first row of
// that category (so the view draws the group heading above it), whether the user has
// overridden it (shows a reset affordance), and whether it's currently capturing a new chord.
export struct KeybindingItem {
    id: string,
    label: string,
    parts: [string],
    category: string,
    group-first: bool,
    overridden: bool,
    capturing: bool,
    // The user cleared this binding's chord (or it was stolen by another): show "Unbound".
    unbound: bool,
    // A non-rebindable documentation row (the "Focus pane by number → Alt 1…9" line): rendered
    // as static <kbd> pills with no rebind/reset affordances.
    static-row: bool,
}

// ===== context menus (pane header / tab strip) =====

// One row of a cursor-anchored context menu. Built fresh by the controller on each right-click
// so its gating + checkmarks are live. `kind`: -1 separator · 0 plain item · 2 Change-Color
// submenu · 3 Move-to-Tab submenu · 4 Layout submenu.
export struct MenuEntry {
    label: string,
    shortcut: string,
    glyph: string,
    kind: int,
    checked: bool,
    show-check: bool,
    disabled: bool,
    danger: bool,
}

// One destination row in the pane menu's "Move to Tab" submenu (label + the real tab index).
export struct CtxTab {
    label: string,
    idx: int,
}

// One frame-palette choice in the Appearance picker: a label plus its 8 slot colors,
// shown as chips. `active` marks the current palette.
export struct FramePaletteOption {
    id: int,
    label: string,
    active: bool,
    colors: [color],
}
