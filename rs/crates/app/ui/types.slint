// Data rows shared between the Rust controller and the .slint views. The Rust
// side computes every geometry (logical px) and pushes these as models.

import { HiRect } from "@widgets";

// One tiled pane: the rendered terminal surface + its placement + chrome state.
export struct PaneItem {
    surface: image,
    title: string,
    // optional secondary line under the label (user subtitle / ambient-AI line).
    subtitle: string,
    // ambient-AI summary line, already truncated to the typewriter-revealed prefix by the
    // controller. Shown only when there's no manual `subtitle` and the pane isn't muted.
    ai-subtitle: string,
    // a SHORT shell-type label (e.g. "pwsh", "cmd", "bash", "wsl") derived once at pane
    // creation from the resolved spawn shell program; rendered dim after the title, in the
    // same header row. "" = unknown (e.g. a re-hosted pane) → not shown.
    shell-type: string,
    accent: color,
    // resolved per-pane chrome (the per-pane override already folded over the global pref
    // by the controller): a clean new pane is frame/dot OFF; a git-project pane is ON.
    show-frame: bool,
    show-dot: bool,
    // true while this pane's label is being edited inline (double-click the header).
    editing: bool,
    x: length,
    y: length,
    w: length,
    h: length,
    visible: bool,
    focused: bool,
    // idle-glow opacity (0 = no glow): the animated alpha of the pane's accent ring once
    // it has been output-quiet past the idle threshold (driven by the controller per tick).
    glow: float,
    // clickable-path hover overlay (driven by the controller after hit-testing the grid).
    link-visible: bool,
    link-x: length,
    link-y: length,
    link-w: length,
    link-tip: string,
    link-tip-x: length,
    link-tip-y: length,
    // drag-to-select highlight rects (one per row-span), hit-tested by the controller from the
    // pane's surface size + font cell metrics; painted over the terminal surface by the widget.
    selection-rects: [HiRect],
    // in-pane search box (opened from the pane menu's "Search…"): whether it's showing + the
    // match counter text (e.g. "2 / 5").
    search-open: bool,
    search-count: string,
    // A monotonically increasing counter bumped every time the search box is (re)invoked
    // (Ctrl+F), even while already open. The widget watches it to (re)focus the query input —
    // a reliable signal that survives the box already being open (unlike a one-shot `init`).
    search-focus-seq: int,
    // Search match highlights projected into the viewport (logical px, hit-tested by the
    // controller from the pane surface): every visible match dimmed, plus the active match drawn
    // distinctly. Without these the box found matches + showed the counter but painted nothing.
    search-rects: [HiRect],
    search-active-on: bool,
    search-active-rect: HiRect,
    // transient bottom-right indicator: copy/paste confirmations + the Ctrl-zoom font "%".
    toast: string,
    // the terminal font size in effect (logical px) — the live zoom / focused-pane font-size
    // state. Drives the widget's `term-font-px` so the toast + search box scale with zoom.
    font-px: length,
    // Whether the pane's shell has exited (drives the single-layout taskbar's "exited"
    // badge). The native app removes a pane the moment its session exits, so this is
    // structurally always false today — kept for Electron parity / a future status model.
    exited: bool,
}

// One tab (workspace group) chip in the strip.
export struct TabItem {
    title: string,
    active: bool,
}

// A draggable resize seam (vertical column / horizontal row / main-stack main).
export struct DividerItem {
    x: length,
    y: length,
    w: length,
    h: length,
    vertical: bool,
    // boundary after pane `index` (kind Size); -1 for the main-stack divider.
    index: int,
    main: bool,
}

// One entry in the layout-picker menu.
export struct LayoutOption {
    id: int,        // matches the Rust Layout discriminant order
    label: string,
    glyph: string,
    active: bool,
    // optional dim hint shown to the right (e.g. the "— grid" the Automatic row resolves
    // to right now in the application menu's Layout submenu); "" = none.
    hint: string,
}

// ===== Wave-2 overlay rows =====

// One visible command-palette row (already filtered + ranked by Rust).
export struct PaletteItem {
    title: string,
    subtitle: string,
}

// One git worktree under a project in the sidebar tree. `branch` is the short label
// (branch name, or "(detached …)" / "(bare)"); `is-main` marks the main checkout, whose
// trash affordance is shown disabled (git refuses `worktree remove` on it). `locked` mirrors
// git's porcelain `locked` flag — git also refuses a plain remove of a locked worktree, so
// its trash is disabled too; `prunable` (stale / missing working dir) is shown as an
// annotation only.
export struct WorktreeRow {
    path: string,
    branch: string,
    is-main: bool,
    locked: bool,
    prunable: bool,
}

// One agent session under a project in the sidebar tree — a row in the History segment.
// `id` is the session id passed to the harness resume command (`claude --resume <id>` for
// Claude); `source` is the harness label ("Claude" today — generic so other harnesses can
// plug in); `summary` is a one-line description (a `summary` transcript line, else the
// first user message); `when` is a relative-time label ("2h ago"); `count` is the
// transcript message count. Built app-side by `sidebar::claude_sessions_for` over
// `core::claude_history`. Declared before `ProjectItem` because that struct references it
// (Slint resolves struct types top-to-bottom within a file — no forward references).
export struct ClaudeSessionItem {
    id: string,
    source: string,
    summary: string,
    when: string,
    count: int,
}

// UI → controller side-channel for the per-project history UI (the Worktrees|History
// segmented bar + the history search box). Slint bumps `seq` after writing the edited
// row's index and its full (segment, query) pair; the controller polls `seq` each pump
// tick, folds the pair into its per-project session-state map (keyed by repo path) and
// re-projects. Polling a global (instead of a new callback) keeps the sidebar
// self-contained — no new app-level callback wiring, mirroring the DELETE-BASE smuggling
// the worktree delete already uses.
export global HistoryUi {
    in-out property <int> seq: 0;
    in-out property <int> proj: -1;       // project row index of the last edit
    in-out property <int> segment: 0;     // 0 = Worktrees, 1 = History
    in-out property <string> query: "";   // history search text
}

// One git-project row in the sidebar panel — now the top level of a two-level tree: the
// project header plus its enumerated `worktrees` (populated by the controller only while
// the flyout is open). Expand/collapse is local UI state in the row itself.
export struct ProjectItem {
    name: string,
    color: color,
    worktrees: [WorktreeRow],
    // This project's recent agent sessions (newest-first), populated by the projection
    // (paneview.rs) from `sidebar::claude_sessions_for` — already FILTERED by `query`.
    sessions: [ClaudeSessionItem],
    // Whether the project has ANY history at all (unfiltered) — gates the Worktrees|History
    // segmented bar. Kept separate from `sessions.length` so a query that matches nothing
    // doesn't collapse the bar (and the search box) out from under the user.
    has-history: bool,
    // The selected segment (0 = Worktrees, 1 = History) — persisted per-project for the app
    // session by the controller (survives the flyout closing and reopening).
    segment: int,
    // The current history search query (persisted alongside `segment`); restores the search
    // box text when the row is recreated.
    query: string,
}

// One option in a preferences picker (font family). `active` marks the current value.
export struct PrefOption {
    id: int,
    label: string,
    active: bool,
}

// One row in the Preferences → Keybindings editor (the EFFECTIVE keymap — overrides over
// defaults): a stable `id` (keys the rebind/reset callbacks), a human label, the chord as
// `<kbd>`-chip parts (e.g. ["Ctrl","Shift","P"]), its category, whether it's the first row of
// that category (so the view draws the group heading above it), whether the user has
// overridden it (shows a reset affordance), and whether it's currently capturing a new chord.
export struct KeybindingItem {
    id: string,
    label: string,
    parts: [string],
    category: string,
    group-first: bool,
    overridden: bool,
    capturing: bool,
    // The user cleared this binding's chord (or it was stolen by another): show "Unbound".
    unbound: bool,
    // A non-rebindable documentation row (the "Focus pane by number → Alt 1…9" line): rendered
    // as static <kbd> pills with no rebind/reset affordances.
    static-row: bool,
}

// ===== context menus (pane header / tab strip) =====

// One row of a cursor-anchored context menu. Built fresh by the controller on each right-click
// so its gating + checkmarks are live. `kind`: -1 separator · 0 plain item · 2 Change-Color
// submenu · 3 Move-to-Tab submenu · 4 Layout submenu.
export struct MenuEntry {
    label: string,
    shortcut: string,
    glyph: string,
    kind: int,
    checked: bool,
    show-check: bool,
    disabled: bool,
    danger: bool,
}

// One destination row in the pane menu's "Move to Tab" submenu (label + the real tab index).
export struct CtxTab {
    label: string,
    idx: int,
}

// One frame-palette choice in the Appearance picker: a label plus its 8 slot colors,
// shown as chips. `active` marks the current palette.
export struct FramePaletteOption {
    id: int,
    label: string,
    active: bool,
    colors: [color],
}
