// Wave-2 overlay panels (Seam #3): the command palette and preferences dialog that
// mount into PaneView's overlay slot. One `OverlayLayer` fills the scrim area and shows
// exactly one panel based on `kind`:
//
//   kind 1 = command palette  (centred search card)
//   kind 2 = preferences      (centred settings card)
//
// (The projects sidebar is no longer an overlay — it's a persistent right-edge rail; see
//  sidebar.slint.)
//
// All state is owned by the Rust controller; this is pure projection + callbacks that
// each map to a `Command`. Keyboard focus is grabbed by the palette query input so the
// chords/text route here (not the panes) while open.

import { Theme } from "theme.slint";
import { PaletteItem, PrefOption, FramePaletteOption, KeybindingItem } from "types.slint";

// A drawn checkmark (vector, so it renders regardless of the UI font's glyph coverage),
// used to mark the active option in the pickers. Same Path-with-commands pattern the window
// controls use (the default UI font lacks the ✓/▾ glyphs).
component Check inherits Path {
    in property <color> ink: Theme.accent;
    width: 12px;
    height: 10px;
    viewbox-width: 12;
    viewbox-height: 10;
    stroke: root.ink;
    stroke-width: 1.6px;
    fill: transparent;
    commands: "M 1 5.5 L 4.5 9 L 11 1";
}

// A drawn chevron for the dropdown buttons; points up while the popup is open.
component Chevron inherits Path {
    in property <color> ink: Theme.subtext;
    in property <bool> up: false;
    width: 12px;
    height: 8px;
    viewbox-width: 12;
    viewbox-height: 8;
    stroke: root.ink;
    stroke-width: 1.6px;
    fill: transparent;
    commands: root.up ? "M 1 6.5 L 6 1.5 L 11 6.5" : "M 1 1.5 L 6 6.5 L 11 1.5";
}

// A small labelled toggle switch (frame/dot prefs).
component PrefToggle inherits Rectangle {
    in property <string> label;
    in property <bool> on;
    callback toggled(bool);
    height: 30px;
    HorizontalLayout {
        spacing: 10px;
        Text {
            text: root.label;
            color: Theme.text;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        VerticalLayout {
            alignment: center;
            track := Rectangle {
                width: 40px;
                height: 22px;
                border-radius: 11px;
                background: root.on ? Theme.accent : Theme.surface2;
                animate background { duration: 120ms; }
                Rectangle {
                    width: 16px;
                    height: 16px;
                    border-radius: 8px;
                    background: #ffffff;
                    y: (parent.height - self.height) / 2;
                    x: root.on ? parent.width - self.width - 3px : 3px;
                    animate x { duration: 120ms; easing: ease-out; }
                }
                TouchArea { clicked => { root.toggled(!root.on); } }
            }
        }
    }
}

// A category row in the preferences left-nav rail (mirrors Electron's `.hp-prefs-tab`).
component NavItem inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked;
    height: 32px;
    border-radius: 6px;
    background: root.active ? Theme.surface2 : (ta.has-hover ? Theme.surface : transparent);
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        Text {
            text: root.label;
            color: root.active ? Theme.text : Theme.subtext;
            font-size: 12px;
            font-weight: root.active ? 600 : 400;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// A live mini-terminal preview for the Appearance section (mirrors Electron's
// `TerminalPreview`). It's a styled sample — not a live pty — that reflects the drafted
// font family/size, frame-palette accent, frame border, and color dot, so the options are
// visible before Done. (Terminal color theme + idle-glow aren't wired in the native widget
// yet, so the preview doesn't reflect those — TODO(phase5).)
component AppearancePreview inherits Rectangle {
    in property <image> surface;   // the rendered locked-terminal image
    in property <color> accent;
    in property <bool> show-frame;
    in property <bool> show-dot;
    in property <color> bg;
    // idle-glow demo opacity (0 = none): when > 0 the frame glows in the accent, so the
    // AI-features tab can preview the chosen effect live (firefly/pulse/blink/solid).
    in property <float> glow: 0;
    border-radius: 8px;
    background: root.bg;
    border-width: root.show-frame ? 1px : 0px;
    border-color: root.accent.with-alpha(0.55);
    clip: true;
    VerticalLayout {
        // header chip
        Rectangle {
            height: 26px;
            background: root.bg.darker(0.2);
            Rectangle { y: parent.height - 1px; height: 1px; background: #ffffff14; }
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: root.accent;
                        visible: root.show-dot;
                    }
                }
                Text {
                    text: "preview";
                    color: root.accent;
                    font-size: 11px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }
        }
        // the real, locked terminal surface (rendered by the controller in the drafted font
        // + theme) — the self-playing Tetris animation + font-preview HUD. Stretched to fill
        // the whole panel (the grid aspect is tuned to the column, so the blocks stay close
        // to square).
        Rectangle {
            background: root.bg;
            clip: true;
            Image {
                x: 4px;
                y: 4px;
                width: parent.width - 8px;
                height: parent.height - 8px;
                source: root.surface;
                image-fit: fill;
                image-rendering: pixelated;
            }
        }
    }
    // idle-glow demo ring on the frame (same look as a real glowing pane), driven by `glow`.
    Rectangle {
        visible: root.glow > 0.01;
        border-radius: 8px;
        border-width: 2px;
        border-color: root.accent.with-alpha(root.glow);
        Rectangle {
            x: 2px;
            y: 2px;
            width: parent.width - 4px;
            height: parent.height - 4px;
            border-radius: 6px;
            border-width: 1px;
            border-color: root.accent.with-alpha(root.glow * 0.45);
        }
    }
}

// A dropdown (select) for the terminal font family — a button showing the current font that
// opens a popup list of all installed monospace fonts. Mirrors Electron's `<select>`.
component FontDropdown inherits Rectangle {
    in property <[PrefOption]> options;
    in property <string> current-label;
    callback selected(int);
    height: 32px;
    border-radius: 7px;
    border-width: 1px;
    border-color: Theme.border;
    background: ta.has-hover ? Theme.surface : Theme.bg;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        Text {
            text: root.current-label;
            color: Theme.text;
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        VerticalLayout {
            alignment: center;
            // Points up while the dropdown is open, down when closed — driven by the
            // PopupWindow.is-open property (our slint fork; slint-ui/slint#12000).
            Chevron { up: popup.is-open; }
        }
    }
    ta := TouchArea { clicked => { popup.show(); } }
    popup := PopupWindow {
        // Default close-on-click: clicking an option or anywhere outside dismisses the popup.
        // The chevron binds to `popup.is-open`, so it flips back down on every close path.
        x: 0;
        y: parent.height + 4px;
        width: root.width;
        Rectangle {
            background: Theme.mantle;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 24px;
            drop-shadow-color: Theme.scrim;
            drop-shadow-offset-y: 8px;
            VerticalLayout {
                padding: 4px;
                for opt[i] in root.options : Rectangle {
                    height: 28px;
                    border-radius: 5px;
                    background: opt.active ? Theme.surface2 : (ita.has-hover ? Theme.surface : transparent);
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 6px;
                        Text {
                            text: opt.label;
                            color: Theme.text;
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        VerticalLayout {
                            alignment: center;
                            width: 14px;
                            if opt.active : Check {}
                        }
                    }
                    ita := TouchArea { clicked => { root.selected(opt.id); popup.close(); } }
                }
            }
        }
    }
}

// A small pill button (font ± and family chips).
component Pill inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked;
    height: 28px;
    min-width: 28px;
    border-radius: 6px;
    background: root.active ? Theme.accent : (ta.has-hover ? Theme.surface2 : Theme.surface);
    border-width: 1px;
    border-color: root.active ? Theme.accent : Theme.border;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        Text {
            text: root.label;
            color: root.active ? #11111b : Theme.text;
            font-size: 12px;
            font-weight: root.active ? 700 : 400;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// A single keycap chip in the keybindings editor (the native port of the renderer's `<kbd>`).
// `accent` tints it when the chord has been overridden by the user.
component Kbd inherits Rectangle {
    in property <string> text;
    in property <bool> accent: false;
    border-radius: 5px;
    background: root.accent ? Theme.accent.with-alpha(0.18) : Theme.surface2;
    border-width: 1px;
    border-color: root.accent ? Theme.accent : Theme.border;
    HorizontalLayout {
        padding-left: 7px;
        padding-right: 7px;
        padding-top: 3px;
        padding-bottom: 3px;
        Text {
            text: root.text;
            color: Theme.text;
            font-size: 11px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// The keybindings-editor action glyphs, drawn as vector Paths (like Check/Chevron) so they
// render regardless of the UI font's glyph coverage (it lacks ✎/↺/×, same as ✓/▾).
component IconEdit inherits Path {        // pencil — "rebind"
    in property <color> ink: Theme.subtext;
    width: 14px;
    height: 14px;
    viewbox-width: 16;
    viewbox-height: 16;
    stroke: root.ink;
    stroke-width: 1.4px;
    fill: transparent;
    // centered in the 16 viewbox so it vertically aligns with the reset icon beside it.
    commands: "M 4 10 L 11 3 L 13 5 L 6 12 Z M 4 10 L 3 13 L 6 12 Z";
}
component IconReset inherits Path {       // stroked circular arrow (Feather rotate-cw) — "reset to default"
    in property <color> ink: Theme.subtext;
    width: 14px;
    height: 14px;
    viewbox-width: 24;
    viewbox-height: 24;
    stroke: root.ink;
    stroke-width: 2px;       // ≈1.2px at 14px — matches the pencil's stroke weight
    fill: transparent;
    // a single thin circular arrow with one arrowhead (centerline stroke, not a filled glyph).
    commands: "M 23 4 v 6 h -6 M 20.49 15 a 9 9 0 1 1 -2.12 -9.36 L 23 10";
}
component IconCancel inherits Path {      // X — "cancel recording"
    in property <color> ink: Theme.subtext;
    width: 12px;
    height: 12px;
    viewbox-width: 16;
    viewbox-height: 16;
    stroke: root.ink;
    stroke-width: 1.6px;
    fill: transparent;
    commands: "M 4 4 L 12 12 M 12 4 L 4 12";
}
component IconUnbind inherits Path {      // ⊘ circle-slash — "unbind (no shortcut)"
    in property <color> ink: Theme.subtext;
    width: 14px;
    height: 14px;
    viewbox-width: 24;
    viewbox-height: 24;
    stroke: root.ink;
    stroke-width: 2px;
    fill: transparent;
    commands: "M 5 12 a 7 7 0 1 0 14 0 a 7 7 0 1 0 -14 0 M 7.05 7.05 L 16.95 16.95";
}

export component OverlayLayer inherits Rectangle {
    // 0 none · 1 palette · 2 prefs
    in property <int> kind: 0;

    // palette
    in property <[PaletteItem]> palette;
    in property <int> palette-sel: 0;
    callback palette-query(string);
    callback palette-nav(int);       // ±1
    callback palette-activate();
    callback palette-pick(int);      // hover/click row i

    // preferences
    in property <[PrefOption]> families;
    in property <string> font-label;
    in property <bool> font-custom: false;
    in property <string> font-custom-value: "";
    in property <image> preview-surface;
    in property <color> preview-accent;
    in property <color> preview-bg;
    in property <float> preview-glow: 0;   // animated idle-glow demo opacity (AI-features tab)
    in property <[PrefOption]> themes;
    in property <string> theme-label;
    in property <[FramePaletteOption]> frame-palettes;
    in property <[PrefOption]> shells;
    in property <string> shell-label;
    // idle-glow (AI-pane quiescence glow)
    in property <bool> idle-alert: true;
    in property <[PrefOption]> idle-effects;
    in property <string> idle-effect-label;
    in property <int> idle-seconds: 10;
    // ambient-AI (local Ollama) — engine status mirror + field seeds.
    in property <bool> ai-enabled: false;
    in property <string> ai-host: "";
    in property <string> ai-model: "";
    in property <string> ai-status: "";
    // keybindings editor (effective keymap; editable)
    in property <[KeybindingItem]> keybindings;
    in property <bool> keybinds-overridden: false;  // any binding overridden → show "Reset all"
    in property <string> kb-conflict: "";            // label of the clashing binding while recording
    in property <int> font-px: 14;
    in property <bool> show-frame: true;
    in property <bool> show-dot: true;
    in property <bool> clickable-paths: true;
    in property <string> editor-command: "";
    in property <bool> prefs-confirm: false;  // showing the unsaved-changes prompt
    callback pref-action(int, int);  // (kind, arg) — see state::Setting mapping
    callback pref-text(int, string); // (kind, value) — string-valued settings
    callback pref-done();            // commit the appearance draft + close (Done / Save)
    callback pref-confirm(int);      // 0 keep · 1 discard · 2 save
    // keybindings editor
    callback pref-rebind(string);                    // start capturing binding `id`
    callback pref-capture(bool, bool, bool, string); // (ctrl, alt, shift, key-text)
    callback pref-cancel-rebind();                   // stop capturing without binding (✎→× / Esc)
    callback pref-unbind(string);                    // clear binding `id`'s chord (→ Unbound)
    callback pref-reset-binding(string);             // reset binding `id` to default
    callback pref-reset-all-bindings();

    callback dismiss();

    // ===== command palette =====
    if root.kind == 1 : Rectangle {
        width: 560px;
        height: min(440px, parent.height - 80px);
        x: (parent.width - self.width) / 2;
        y: 90px;
        background: Theme.mantle;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-blur: 48px;
        drop-shadow-color: Theme.scrim;
        drop-shadow-offset-y: 18px;
        clip: true;
        // stop scrim clicks behind the card from dismissing
        TouchArea {}

        VerticalLayout {
            padding: 8px;
            spacing: 6px;

            // query input
            Rectangle {
                height: 38px;
                border-radius: 8px;
                background: Theme.bg;
                border-width: 1px;
                border-color: Theme.accent;
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    qi := TextInput {
                        color: Theme.text;
                        font-size: 14px;
                        vertical-alignment: center;
                        single-line: true;
                        init => { qi.focus(); }
                        edited => { root.palette-query(self.text); }
                        key-pressed(e) => {
                            if (e.text == Key.UpArrow) { root.palette-nav(-1); return EventResult.accept; }
                            if (e.text == Key.DownArrow) { root.palette-nav(1); return EventResult.accept; }
                            if (e.text == Key.Return) { root.palette-activate(); return EventResult.accept; }
                            if (e.text == Key.Escape) { root.dismiss(); return EventResult.accept; }
                            return EventResult.reject;
                        }
                    }
                }
                // placeholder
                Text {
                    x: 12px;
                    text: "Type a command…";
                    color: Theme.faint;
                    font-size: 14px;
                    vertical-alignment: center;
                    visible: qi.text == "";
                }
            }

            // results list (clipped; query narrows quickly)
            Rectangle {
                vertical-stretch: 1;
                clip: true;
                VerticalLayout {
                    alignment: start;
                    spacing: 1px;
                    if root.palette.length == 0 : Text {
                        text: "No matching commands";
                        color: Theme.faint;
                        font-size: 13px;
                        height: 40px;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                    for row[i] in root.palette : Rectangle {
                        height: 34px;
                        border-radius: 7px;
                        background: i == root.palette-sel ? Theme.surface2 : transparent;
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 8px;
                            Text {
                                text: row.title;
                                color: Theme.text;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: row.subtitle;
                                color: Theme.faint;
                                font-size: 11px;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                        }
                        ta := TouchArea {
                            clicked => { root.palette-pick(i); root.palette-activate(); }
                            moved => { root.palette-pick(i); }
                        }
                    }
                }
            }
        }
    }

    // ===== preferences =====
    // Structured to mirror Electron's `PreferencesDialog` section grouping (Appearance,
    // then Terminal). Only settings whose underlying feature exists in the native build
    // are rendered; deferred ones are marked `TODO(phase5)` (no dead controls). The card
    // auto-sizes to its content (no scroll machinery needed at this size).
    if root.kind == 2 : prefs := Rectangle {
        width: min(820px, parent.width - 40px);
        height: min(600px, parent.height - 60px);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Theme.mantle;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-blur: 64px;
        drop-shadow-color: Theme.scrim;
        drop-shadow-offset-y: 24px;
        clip: true;
        // selected category: 0 = Appearance · 1 = Terminal
        property <int> sel: 0;
        TouchArea {}

        HorizontalLayout {
            // ---- left category rail (mirrors Electron `.hp-prefs-tabs`) ----
            Rectangle {
                width: 168px;
                background: Theme.bg;
                Rectangle { x: parent.width - 1px; width: 1px; background: Theme.border; }
                VerticalLayout {
                    padding: 12px;
                    spacing: 2px;
                    Text {
                        text: "Preferences";
                        color: Theme.text;
                        font-size: 13px;
                        font-weight: 600;
                        height: 34px;
                        vertical-alignment: center;
                    }
                    NavItem { label: "Appearance"; active: prefs.sel == 0; clicked => { prefs.sel = 0; } }
                    NavItem { label: "Terminal"; active: prefs.sel == 1; clicked => { prefs.sel = 1; } }
                    NavItem { label: "AI features"; active: prefs.sel == 2; clicked => { prefs.sel = 2; } }
                    NavItem { label: "Keybindings"; active: prefs.sel == 3; clicked => { prefs.sel = 3; } }
                    Rectangle { vertical-stretch: 1; }
                }
            }
            // ---- center column: scrolling controls + pinned footer ----
            VerticalLayout {
                horizontal-stretch: 1;
                Rectangle {
                    vertical-stretch: 1;
                    clip: true;
                    Flickable {
                        width: 100%;
                        height: 100%;
                        viewport-width: self.width;
                        viewport-height: pbody.preferred-height;
                        pbody := VerticalLayout {
                        padding: 16px;
                        spacing: 12px;
                        alignment: start;

                        // ===================== Appearance =====================
                        if prefs.sel == 0 : VerticalLayout {
                            spacing: 12px;

            // ---- frame color palette (pane dot + border) ----
            Text { text: "Frame color palette"; color: Theme.faint; font-size: 11px; }
            VerticalLayout {
                spacing: 4px;
                for opt[i] in root.frame-palettes : Rectangle {
                    height: 30px;
                    border-radius: 7px;
                    border-width: 1px;
                    border-color: opt.active ? Theme.accent : Theme.border;
                    background: opt.active ? Theme.surface2 : (pta.has-hover ? Theme.surface : transparent);
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 8px;
                        Text {
                            text: opt.label;
                            color: Theme.text;
                            font-size: 12px;
                            vertical-alignment: center;
                            width: 86px;
                        }
                        // 8 color chips
                        HorizontalLayout {
                            spacing: 3px;
                            horizontal-stretch: 1;
                            alignment: start;
                            for c in opt.colors : VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 14px;
                                    height: 14px;
                                    border-radius: 3px;
                                    background: c;
                                }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            width: 14px;
                            if opt.active : Check {}
                        }
                    }
                    pta := TouchArea { clicked => { root.pref-action(4, opt.id); } }
                }
            }

            // ---- terminal font family ----
            Text { text: "Terminal font"; color: Theme.faint; font-size: 11px; }
            FontDropdown {
                options: root.families;
                current-label: root.font-label;
                selected(id) => { root.pref-action(0, id); }
            }
            // Custom font path field — shown only in "Custom…" mode (mirrors the renderer).
            if root.font-custom : Rectangle {
                height: 32px;
                border-radius: 7px;
                background: Theme.bg;
                border-width: 1px;
                border-color: Theme.border;
                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    fci := TextInput {
                        color: Theme.text;
                        font-size: 12px;
                        vertical-alignment: center;
                        single-line: true;
                        init => { fci.text = root.font-custom-value; }
                        edited => { root.pref-text(8, self.text); }
                    }
                }
                Text {
                    x: 10px;
                    text: "font file path, e.g. C:/Fonts/MyFont.ttf";
                    color: Theme.faint;
                    font-size: 12px;
                    vertical-alignment: center;
                    visible: fci.text == "";
                }
            }

            // ---- terminal color theme ----
            Text { text: "Color theme"; color: Theme.faint; font-size: 11px; }
            FontDropdown {
                options: root.themes;
                current-label: root.theme-label;
                selected(id) => { root.pref-action(9, id); }
            }

            // ---- font size ----
            HorizontalLayout {
                spacing: 10px;
                Text {
                    text: "Font size";
                    color: Theme.text;
                    font-size: 13px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Pill { label: "−"; clicked => { root.pref-action(1, -1); } }
                Rectangle {
                    width: 48px;
                    Text {
                        text: root.font-px + " px";
                        color: Theme.text;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                Pill { label: "+"; clicked => { root.pref-action(1, 1); } }
            }

            // ---- frame / dot toggles ----
            PrefToggle {
                label: "Pane frame border";
                on: root.show-frame;
                toggled(v) => { root.pref-action(2, v ? 1 : 0); }
            }
            PrefToggle {
                label: "Pane color dot";
                on: root.show-dot;
                toggled(v) => { root.pref-action(3, v ? 1 : 0); }
            }

                        } // end Appearance panel

                        // ===================== Terminal =====================
                        if prefs.sel == 1 : VerticalLayout {
                            spacing: 12px;

            // ---- default shell (applies to new panes & restarts) ----
            Text { text: "Default shell"; color: Theme.faint; font-size: 11px; }
            FontDropdown {
                options: root.shells;
                current-label: root.shell-label;
                selected(id) => { root.pref-action(5, id); }
            }

            // ---- clickable file paths (click opens · Ctrl+click copies) ----
            PrefToggle {
                label: "Clickable file paths";
                on: root.clickable-paths;
                toggled(v) => { root.pref-action(6, v ? 1 : 0); }
            }
            // Editor command — only shown when clickable paths are on (mirrors the renderer).
            if root.clickable-paths : VerticalLayout {
                spacing: 4px;
                Text {
                    text: "Editor command";
                    color: Theme.faint;
                    font-size: 11px;
                }
                Rectangle {
                    height: 32px;
                    border-radius: 7px;
                    background: Theme.bg;
                    border-width: 1px;
                    border-color: Theme.border;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        eci := TextInput {
                            color: Theme.text;
                            font-size: 12px;
                            vertical-alignment: center;
                            single-line: true;
                            init => { eci.text = root.editor-command; }
                            edited => { root.pref-text(7, self.text); }
                        }
                    }
                    Text {
                        x: 10px;
                        text: "blank = OS default";
                        color: Theme.faint;
                        font-size: 12px;
                        vertical-alignment: center;
                        visible: eci.text == "";
                    }
                }
            }

            // TODO(phase5): scrollback (history lines) — needs a terminal-widget history buffer
            //   (TermGrid keeps a fixed viewport buffer today). The setting is already persisted.
            // TODO(phase5): Control API section (agents/MCP) — the loopback control server isn't
            //   wired into the native shell yet.
            // Ambient AI (local Ollama) now lives in the AI features tab.

                        } // end Terminal panel

                        // ===================== AI features =====================
                        if prefs.sel == 2 : VerticalLayout {
                            spacing: 12px;

            // ---- Ambient AI (local Ollama "what you're doing" subtitles) ----
            Text { text: "Ambient AI"; color: Theme.faint; font-size: 11px; }
            PrefToggle {
                label: "Ambient AI subtitles";
                on: root.ai-enabled;
                toggled(v) => { root.pref-action(13, v ? 1 : 0); }
            }
            Text {
                text: "a local model labels what each pane is doing (default off, private)";
                color: Theme.faint;
                font-size: 11px;
            }
            // Host / model / status only matter once it's enabled.
            if root.ai-enabled : VerticalLayout {
                spacing: 8px;
                Text { text: "Ollama base URL"; color: Theme.faint; font-size: 11px; }
                Rectangle {
                    height: 32px;
                    border-radius: 7px;
                    background: Theme.bg;
                    border-width: 1px;
                    border-color: Theme.border;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        ahost := TextInput {
                            color: Theme.text;
                            font-size: 12px;
                            vertical-alignment: center;
                            single-line: true;
                            init => { ahost.text = root.ai-host; }
                            edited => { root.pref-text(13, self.text); }
                        }
                    }
                    Text {
                        x: 10px;
                        text: "http://192.168.0.11:11434";
                        color: Theme.faint;
                        font-size: 12px;
                        vertical-alignment: center;
                        visible: ahost.text == "";
                    }
                }
                Text { text: "Model"; color: Theme.faint; font-size: 11px; }
                Rectangle {
                    height: 32px;
                    border-radius: 7px;
                    background: Theme.bg;
                    border-width: 1px;
                    border-color: Theme.border;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        amodel := TextInput {
                            color: Theme.text;
                            font-size: 12px;
                            vertical-alignment: center;
                            single-line: true;
                            init => { amodel.text = root.ai-model; }
                            edited => { root.pref-text(14, self.text); }
                        }
                    }
                    Text {
                        x: 10px;
                        text: "gemma3:4b";
                        color: Theme.faint;
                        font-size: 12px;
                        vertical-alignment: center;
                        visible: amodel.text == "";
                    }
                }
                HorizontalLayout {
                    spacing: 6px;
                    Text { text: "Status:"; color: Theme.faint; font-size: 11px; vertical-alignment: center; }
                    Text { text: root.ai-status; color: Theme.subtext; font-size: 11px; vertical-alignment: center; }
                }
            }

            Rectangle { height: 1px; background: Theme.border; }

            Text { text: "Idle glow"; color: Theme.faint; font-size: 11px; }
            // Mirrors Electron's "Idle glow for AI panes" — only an agent pane (one whose
            // shell title names claude/aider/etc.) glows once it goes output-quiet.
            PrefToggle {
                label: "Idle glow for AI panes";
                on: root.idle-alert;
                toggled(v) => { root.pref-action(10, v ? 1 : 0); }
            }
            Text {
                text: "soft glow when an agent (claude, etc.) goes quiet";
                color: Theme.faint;
                font-size: 11px;
            }
            // Effect + threshold only matter when the glow is on.
            if root.idle-alert : VerticalLayout {
                spacing: 12px;
                Text { text: "Glow effect"; color: Theme.faint; font-size: 11px; }
                FontDropdown {
                    options: root.idle-effects;
                    current-label: root.idle-effect-label;
                    selected(id) => { root.pref-action(11, id); }
                }
                HorizontalLayout {
                    spacing: 10px;
                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        Text {
                            text: "Idle after";
                            color: Theme.text;
                            font-size: 13px;
                        }
                        Text {
                            text: "silence before an agent pane glows";
                            color: Theme.faint;
                            font-size: 11px;
                        }
                    }
                    Pill { label: "−"; clicked => { root.pref-action(12, -1); } }
                    Rectangle {
                        width: 56px;
                        Text {
                            text: root.idle-seconds + "s";
                            color: Theme.text;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    Pill { label: "+"; clicked => { root.pref-action(12, 1); } }
                }
            }

                        } // end AI features panel

                        // ===================== Keybindings =====================
                        // Editable list of the EFFECTIVE keymap (overrides over defaults),
                        // grouped by category and shown as <kbd> chips — styled like the
                        // Electron Preferences › Keybindings tab. Click a row to capture a new
                        // chord; an overridden row shows a Reset; "Reset all" clears every
                        // override. The override always wins in the live key router.
                        if prefs.sel == 3 : VerticalLayout {
                            spacing: 2px;

                            // header: hint + Reset all (only when something is overridden)
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: "Click a shortcut to rebind it";
                                    color: Theme.faint;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                if root.keybinds-overridden : Pill {
                                    label: "Reset all";
                                    clicked => { root.pref-reset-all-bindings(); }
                                }
                            }

                            for kb[i] in root.keybindings : VerticalLayout {
                                spacing: 2px;
                                // group heading above the first row of each category
                                if kb.group-first : Text {
                                    text: kb.category;
                                    color: Theme.faint;
                                    font-size: 11px;
                                    font-weight: 600;
                                }
                                Rectangle {
                                    height: 36px;
                                    border-radius: 6px;
                                    border-width: kb.capturing ? 1px : 0px;
                                    border-color: Theme.accent;
                                    background: kb.capturing ? Theme.surface2 : transparent;
                                    HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        spacing: 8px;
                                        Text {
                                            text: kb.label;
                                            color: kb.static-row ? Theme.subtext : Theme.text;
                                            font-size: 13px;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                            overflow: elide;
                                        }

                                        // ---- combo field: recording prompt OR clickable <kbd> chips ----
                                        if kb.capturing : VerticalLayout {
                                            alignment: center;
                                            Text {
                                                text: root.kb-conflict != "" ? "Used by " + root.kb-conflict : "Press keys…";
                                                color: root.kb-conflict != "" ? Theme.danger : Theme.accent;
                                                font-size: 12px;
                                                font-weight: 600;
                                                vertical-alignment: center;
                                            }
                                        }
                                        if !kb.capturing : combo := Rectangle {
                                            border-radius: 6px;
                                            background: (!kb.static-row && cta.has-hover) ? Theme.surface : transparent;
                                            VerticalLayout {
                                                alignment: center;
                                                HorizontalLayout {
                                                    padding-left: 4px;
                                                    padding-right: 4px;
                                                    spacing: 4px;
                                                    alignment: end;
                                                    // static doc row: Alt 1…9 (no rebind/reset)
                                                    if kb.static-row : Kbd { text: "Alt"; }
                                                    if kb.static-row : Kbd { text: "1"; }
                                                    if kb.static-row : Text {
                                                        text: "…";
                                                        color: Theme.subtext;
                                                        font-size: 11px;
                                                        vertical-alignment: center;
                                                    }
                                                    if kb.static-row : Kbd { text: "9"; }
                                                    // editable rows: "Unbound" or the chord chips
                                                    if !kb.static-row && kb.unbound : Text {
                                                        text: "Unbound";
                                                        color: Theme.faint;
                                                        font-size: 11px;
                                                        font-italic: true;
                                                        vertical-alignment: center;
                                                    }
                                                    if !kb.static-row && !kb.unbound : HorizontalLayout {
                                                        spacing: 4px;
                                                        alignment: end;
                                                        for part in kb.parts : Kbd {
                                                            text: part;
                                                            accent: kb.overridden;
                                                        }
                                                    }
                                                }
                                            }
                                            cta := TouchArea {
                                                clicked => {
                                                    if (!kb.static-row) { root.pref-rebind(kb.id); }
                                                }
                                            }
                                        }

                                        // ---- ⊘ unbind (while recording only) ----
                                        if kb.capturing : VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 22px;
                                                height: 22px;
                                                border-radius: 5px;
                                                background: uta.has-hover ? Theme.surface2 : transparent;
                                                IconUnbind {
                                                    ink: uta.has-hover ? Theme.danger : Theme.subtext;
                                                }
                                                uta := TouchArea { clicked => { root.pref-unbind(kb.id); } }
                                            }
                                        }
                                        // ---- ✎ rebind / × cancel (editable rows only) ----
                                        if !kb.static-row : VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 22px;
                                                height: 22px;
                                                border-radius: 5px;
                                                background: eta.has-hover ? Theme.surface2 : transparent;
                                                if kb.capturing : IconCancel {
                                                    ink: eta.has-hover ? Theme.text : Theme.subtext;
                                                }
                                                if !kb.capturing : IconEdit {
                                                    ink: eta.has-hover ? Theme.text : Theme.subtext;
                                                }
                                                eta := TouchArea {
                                                    clicked => {
                                                        if (kb.capturing) {
                                                            root.pref-cancel-rebind();
                                                        } else {
                                                            root.pref-rebind(kb.id);
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                        // ---- ↺ reset to default (editable rows only) ----
                                        if !kb.static-row : VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 22px;
                                                height: 22px;
                                                border-radius: 5px;
                                                background: rta.has-hover ? Theme.surface2 : transparent;
                                                IconReset {
                                                    ink: rta.has-hover ? Theme.text : Theme.subtext;
                                                }
                                                rta := TouchArea { clicked => { root.pref-reset-binding(kb.id); } }
                                            }
                                        }
                                    }

                                    // While capturing, grab the keyboard and forward each combo
                                    // to the controller (which builds the chord + saves it). A
                                    // bare modifier is swallowed so it doesn't prematurely bind.
                                    if kb.capturing : FocusScope {
                                        init => { self.focus(); }
                                        key-pressed(e) => {
                                            if (e.text == Key.Control || e.text == Key.Shift
                                                || e.text == Key.Alt || e.text == Key.Meta) {
                                                return EventResult.accept;
                                            }
                                            root.pref-capture(
                                                e.modifiers.control || e.modifiers.meta,
                                                e.modifiers.alt,
                                                e.modifiers.shift,
                                                e.text);
                                            return EventResult.accept;
                                        }
                                    }
                                }
                            }
                        } // end Keybindings panel
                        } // close scrolling body layout (pbody)
                    } // close Flickable
                }
                // ---- footer (Done) ----
                Rectangle {
                    height: 56px;
                    Rectangle { width: 100%; height: 1px; background: Theme.border; }
                    HorizontalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Rectangle { horizontal-stretch: 1; }
                        Pill {
                            label: "Done";
                            active: true;
                            clicked => { root.pref-done(); }
                        }
                    }
                }
            }
            // ---- right preview column (Appearance + AI features only) ----
            // A tall, persistent preview pane. On Appearance it shows the drafted terminal
            // look; on AI features the frame glows with the selected idle effect so you can
            // see firefly/pulse/blink/solid before applying. Hidden on Terminal/Keybindings
            // (the center column then takes the full width).
            if prefs.sel == 0 || prefs.sel == 2 : Rectangle {
                width: 180px;
                background: Theme.mantle;
                Rectangle { x: 0; width: 1px; background: Theme.border; }
                VerticalLayout {
                    padding: 16px;
                    spacing: 8px;
                    Text {
                        text: prefs.sel == 2 ? "Idle glow preview" : "Preview";
                        color: Theme.faint;
                        font-size: 11px;
                    }
                    AppearancePreview {
                        vertical-stretch: 1;
                        surface: root.preview-surface;
                        accent: root.preview-accent;
                        show-frame: root.show-frame;
                        show-dot: root.show-dot;
                        bg: root.preview-bg;
                        // glow only on the AI-features tab (Appearance previews the look, not the glow).
                        glow: prefs.sel == 2 ? root.preview-glow : 0;
                    }
                }
            }
        }

        // ---- unsaved appearance changes prompt (Esc / scrim click with edits) ----
        if root.prefs-confirm : Rectangle {
            background: #00000099;
            TouchArea {} // eat clicks behind the modal
            Rectangle {
                width: 380px;
                height: confirm-body.preferred-height;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                background: Theme.mantle;
                border-radius: 12px;
                border-width: 1px;
                border-color: Theme.border;
                drop-shadow-blur: 48px;
                drop-shadow-color: Theme.scrim;
                drop-shadow-offset-y: 18px;
                confirm-body := VerticalLayout {
                    padding: 18px;
                    spacing: 12px;
                    Text {
                        text: "Unsaved appearance changes";
                        color: Theme.text;
                        font-size: 14px;
                        font-weight: 700;
                    }
                    Text {
                        text: "You changed appearance settings but haven't applied them. Save the changes or discard them?";
                        color: Theme.subtext;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle { horizontal-stretch: 1; }
                        Pill { label: "Keep editing"; clicked => { root.pref-confirm(0); } }
                        Pill { label: "Discard"; clicked => { root.pref-confirm(1); } }
                        Pill { label: "Save"; active: true; clicked => { root.pref-confirm(2); } }
                    }
                }
            }
        }
    }
}
