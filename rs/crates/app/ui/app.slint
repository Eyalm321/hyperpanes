// The hyperpanes multi-tab workspace shell (Phase 3, Wave 1).
//
//   frameless Window  →  TopBar  (brand · tab strip · hud · tools · window controls)
//                     →  PaneView (active tab's tiled TerminalPanes + resize dividers
//                                  + Wave-2 overlay slot)
//
// All state is owned by the Rust controller (src/*.rs). It pushes models (`panes`,
// `tabs`, `dividers`, `layouts`) and scalar props down, and subscribes to the
// callbacks below — every one of which the controller turns into a `Command`
// dispatched against the central `State` (see ARCHITECTURE.md).

import { Theme } from "theme.slint";
import { PaneItem, TabItem, DividerItem, LayoutOption, PaletteItem, ProjectItem, PrefOption, FramePaletteOption, KeybindingItem, MenuEntry, CtxTab } from "types.slint";
import { TopBar } from "topbar.slint";
import { PaneView } from "paneview.slint";
import { OverlayLayer } from "overlays.slint";
import { SidebarRail } from "sidebar.slint";
import { ContextMenu } from "contextmenu.slint";
import { KeyMsg } from "@widgets";

// Re-export the row structs so the Rust side (slint::include_modules!) can build them.
export { PaneItem, TabItem, DividerItem, LayoutOption, PaletteItem, ProjectItem, PrefOption, KeybindingItem, MenuEntry, CtxTab, KeyMsg }

export component AppWindow inherits Window {
    title: "hyperpanes";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 480px;
    min-height: 320px;
    default-font-size: 14px;
    background: Theme.bg;

    // ---- models (driven from Rust) ----
    in property <[PaneItem]> panes;
    in property <[TabItem]> tabs;
    in property <[DividerItem]> dividers;
    in property <[LayoutOption]> layouts;
    // ---- scalars ----
    in property <int> editing-tab: -1;
    in property <string> layout-glyph: "\u{E80A}";
    in property <string> hud: "";
    in property <bool> zoomed: false;
    in property <bool> fullscreen: false;
    // Our own OS-maximized flag (synced from Win32). Named `win-maximized` to avoid colliding
    // with Slint 1.17's new builtin `Window.maximized`, which we don't use (custom frameless window).
    in property <bool> win-maximized: false;
    // Briefly true after entering fullscreen → flashes the "hold Esc to exit" hint.
    in property <bool> fullscreen-hint: false;
    // True while Esc is held → keeps the hint up and fills its progress bar.
    in property <bool> esc-holding: false;
    // ---- Wave-2 appearance prefs ----
    in property <bool> show-frame: true;
    in property <bool> show-dot: true;
    // ---- Wave-2 overlay panels (0 none · 1 palette · 2 prefs · 3 sidebar) ----
    in property <int> overlay-kind: 0;
    in property <[PaletteItem]> palette;
    in property <int> palette-sel: 0;
    in property <[PrefOption]> pref-families;
    in property <string> pref-font-label;
    in property <bool> pref-font-custom: false;
    in property <string> pref-font-custom-value: "";
    in property <image> pref-preview-surface;
    in property <color> pref-preview-accent;
    in property <color> pref-preview-bg;
    in property <float> pref-preview-glow;
    in property <[PrefOption]> pref-themes;
    in property <string> pref-theme-label;
    in property <[FramePaletteOption]> pref-palettes;
    in property <[PrefOption]> pref-shells;
    in property <string> pref-shell-label;
    // idle-glow prefs
    in property <bool> pref-idle-alert: true;
    in property <[PrefOption]> pref-idle-effects;
    in property <string> pref-idle-effect-label;
    in property <int> pref-idle-seconds: 10;
    // keybindings editor (effective keymap; editable)
    in property <[KeybindingItem]> pref-keybindings;
    in property <bool> pref-keybinds-overridden: false;
    in property <string> pref-kb-conflict: "";
    in property <bool> pref-clickable: true;
    in property <string> pref-editor: "";
    in property <int> pref-fontpx: 14;
    // appearance DRAFT mirrors (dialog shows these; the panes use show-frame/show-dot)
    in property <bool> pref-frame: true;
    in property <bool> pref-dot: true;
    in property <bool> prefs-confirm: false;
    // ---- right-edge sidebar rail ----
    in property <[ProjectItem]> projects;
    in property <bool> show-sidebar: true;   // rail visible (gated; hidden in fullscreen)
    in property <bool> sidebar-open: false;  // projects flyout expanded
    // ---- context menus (pane header / tab strip) ----
    in property <int> ctx-kind: 0;           // 0 none · 1 pane · 2 tab
    in property <length> ctx-x: 0px;         // anchor (window-logical)
    in property <length> ctx-y: 0px;
    in property <[MenuEntry]> ctx-entries;
    in property <[color]> ctx-swatches;      // Change-Color palette slots
    in property <int> ctx-cur-swatch: -1;    // pane's color index in ctx-swatches, or -1
    in property <bool> ctx-frame: false;
    in property <bool> ctx-dot: false;
    in property <[CtxTab]> ctx-tabs;         // Move-to-Tab destinations
    in property <[LayoutOption]> ctx-layouts; // Layout submenu (for the target tab)
    // ---- Wave-2 drag / tear-off previews (driven by the drag pump) ----
    in property <bool> drop-win-active: false;    // this window is a cross-window tear target
    in property <bool> drop-strip-active: false;  // the tab strip is a drop target
    in property <length> drop-tab-x: 0px;         // tab insertion caret x (window coords)
    in property <bool> drop-tab-active: false;
    in property <int> drop-tab-idx: -1;           // existing tab a dragged pane hovers (spring)
    in property <length> drop-rect-x: 0px;        // hovered pane slot (area-relative)
    in property <length> drop-rect-y: 0px;
    in property <length> drop-rect-w: 0px;
    in property <length> drop-rect-h: 0px;
    in property <int> drop-rect-edge: 0;          // 0 left · 1 right · 2 top · 3 bottom
    in property <bool> drop-rect-active: false;

    // ---- outputs (Rust subscribes; each maps to a Command) ----
    callback key(int, KeyMsg);
    callback focus-pane(int);
    callback area-resized(length, length);
    callback divider-drag(int, bool, bool, length, length);
    callback pane-zoom(int);
    callback pane-fullscreen(int);
    callback pane-close(int);
    // pane-header inline rename (double-click the header label)
    callback begin-rename-pane(int);
    callback rename-pane(int, string);
    // clickable paths (terminal links)
    callback pane-geometry(int, length, length);
    callback pane-link-moved(int, length, length);
    callback pane-link-exited(int);
    callback pane-link-activated(int, length, length, bool);
    // in-pane search (opened from the pane context menu)
    callback pane-search-edited(int, string);
    callback pane-search-next(int);
    callback pane-search-prev(int);
    callback pane-search-closed(int);
    // tabs
    callback select-tab(int);
    callback close-tab(int);
    callback new-tab();
    callback begin-rename(int);
    callback rename-tab(int, string);
    // multi-window
    callback new-window();
    callback move-pane-new-window();
    // drag / tear-off (Wave 2)
    callback pane-grab(int);                 // a pane header was pressed (arm a drag)
    callback tab-grab(int);                  // a tab was pressed (arm a reorder)
    callback tab-geom(int, length, length);  // report a tab's window-x + width
    // panes / layout
    callback new-pane();
    callback close-focused();
    callback set-layout(int);
    callback toggle-zoom();
    callback toggle-fullscreen();
    // window controls (→ Win32)
    callback start-drag();
    callback min-window();
    callback max-window();
    callback close-window();
    // Wave-2 overlay callbacks (each maps to a Command)
    callback palette-query(string);
    callback palette-nav(int);
    callback palette-activate();
    callback palette-pick(int);
    callback pref-action(int, int);
    callback pref-text(int, string);
    callback pref-done();
    callback pref-confirm(int);
    // keybindings editor: start capturing a rebind, deliver a captured chord, reset one / all.
    callback pref-rebind(string);                  // start capturing binding `id`
    callback pref-capture(bool, bool, bool, string); // (ctrl, alt, shift, key-text)
    callback pref-cancel-rebind();                  // stop capturing without binding
    callback pref-reset-binding(string);           // reset binding `id` to default
    callback pref-reset-all-bindings();
    callback overlay-dismiss();
    // ---- sidebar rail ----
    callback open-project(int);
    callback toggle-projects();
    callback recolor-project(int, int);   // row, swatch
    callback rename-project(int, string);
    callback remove-project(int);
    // top-bar menu → overlays
    callback open-palette();
    callback open-prefs();
    callback toggle-sidebar();
    // ---- context menus ----
    callback pane-context(int, length, length);   // right-click pane `i` at (x, y)
    callback tab-context(int, length, length);    // right-click tab `i` at (x, y)
    callback ctx-pick(int);        // a plain top-level menu row
    callback ctx-swatch(int);      // Change-Color swatch
    callback ctx-swatch-none();    // Change-Color "no color"
    callback ctx-frame-set(bool);
    callback ctx-dot-set(bool);
    callback ctx-move-tab(int);    // Move-to-Tab destination (real tab index)
    callback ctx-layout(int);      // Layout option id
    callback ctx-dismiss();

    VerticalLayout {
        spacing: 0px;

        // The top bar hides in OS fullscreen (chrome-free terminal).
        if !root.fullscreen : TopBar {
            tabs: root.tabs;
            editing-tab: root.editing-tab;
            layouts: root.layouts;
            zoomed: root.zoomed;
            fullscreen: root.fullscreen;
            maximized: root.win-maximized;
            drop-strip-active: root.drop-strip-active;
            drop-tab-x: root.drop-tab-x;
            drop-tab-active: root.drop-tab-active;
            drop-tab-idx: root.drop-tab-idx;

            tab-grab(i) => { root.tab-grab(i); }
            tab-geom(i, x, w) => { root.tab-geom(i, x, w); }
            select-tab(i) => { root.select-tab(i); }
            close-tab(i) => { root.close-tab(i); }
            tab-context(i, x, y) => { root.tab-context(i, x, y); }
            new-tab => { root.new-tab(); }
            begin-rename(i) => { root.begin-rename(i); }
            rename-tab(i, t) => { root.rename-tab(i, t); }
            new-window => { root.new-window(); }
            move-pane-new-window => { root.move-pane-new-window(); }
            set-layout(l) => { root.set-layout(l); }
            new-pane => { root.new-pane(); }
            open-palette => { root.open-palette(); }
            open-prefs => { root.open-prefs(); }
            toggle-sidebar => { root.toggle-sidebar(); }
            toggle-zoom => { root.toggle-zoom(); }
            toggle-fullscreen => { root.toggle-fullscreen(); }
            start-drag => { root.start-drag(); }
            min-window => { root.min-window(); }
            max-window => { root.max-window(); }
            close-window => { root.close-window(); }
        }

        // The pane area + the persistent right-edge sidebar rail sit side by side. The
        // rail is a real sibling of the panes (not an overlay): it never dims them, and
        // its projects flyout opens leftward over the pane area.
        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0px;

            PaneView {
                horizontal-stretch: 1;
                panes: root.panes;
                dividers: root.dividers;
                zoomed: root.zoomed;
                fullscreen: root.fullscreen;
                show-frame: root.show-frame;
                show-dot: root.show-dot;
                drop-rect-x: root.drop-rect-x;
                drop-rect-y: root.drop-rect-y;
                drop-rect-w: root.drop-rect-w;
                drop-rect-h: root.drop-rect-h;
                drop-rect-edge: root.drop-rect-edge;
                drop-rect-active: root.drop-rect-active;

                pane-grab(i) => { root.pane-grab(i); }
                pane-context(i, x, y) => { root.pane-context(i, x, y); }
                key(i, m) => { root.key(i, m); }
                focus-pane(i) => { root.focus-pane(i); }
                area-resized(w, h) => { root.area-resized(w, h); }
                divider-drag(i, main, vert, dx, dy) => { root.divider-drag(i, main, vert, dx, dy); }
                pane-zoom(i) => { root.pane-zoom(i); }
                pane-fullscreen(i) => { root.pane-fullscreen(i); }
                pane-close(i) => { root.pane-close(i); }
                begin-rename-pane(i) => { root.begin-rename-pane(i); }
                rename-pane(i, t) => { root.rename-pane(i, t); }
                pane-geometry(i, w, h) => { root.pane-geometry(i, w, h); }
                pane-link-moved(i, x, y) => { root.pane-link-moved(i, x, y); }
                pane-link-exited(i) => { root.pane-link-exited(i); }
                pane-link-activated(i, x, y, ctrl) => { root.pane-link-activated(i, x, y, ctrl); }
                pane-search-edited(i, q) => { root.pane-search-edited(i, q); }
                pane-search-next(i) => { root.pane-search-next(i); }
                pane-search-prev(i) => { root.pane-search-prev(i); }
                pane-search-closed(i) => { root.pane-search-closed(i); }
            }

            // Shown whenever the setting is on AND not fullscreen (mirrors
            // `!fullscreenPaneId && showSidebar && <Sidebar/>`).
            if root.show-sidebar && !root.fullscreen : SidebarRail {
                projects: root.projects;
                projects-open: root.sidebar-open;
                new-pane => { root.new-pane(); }
                toggle-projects => { root.toggle-projects(); }
                open-project(i) => { root.open-project(i); }
                recolor-project(i, s) => { root.recolor-project(i, s); }
                rename-project(i, t) => { root.rename-project(i, t); }
                remove-project(i) => { root.remove-project(i); }
            }
        }
    }

    // ===== Wave-2 overlay (command palette / preferences) =====
    // Mounted at the window root so its frosted scrim covers the top bar + sidebar too,
    // making their buttons non-interactive while open. The scrim is split so the top-right
    // window-control buttons (min/max/close) stay clickable — it covers the whole window
    // EXCEPT that corner. The card(s) center in the window, above the scrim.
    if root.overlay-kind != 0 : Rectangle {
        // top-bar row, minus the window-control corner (0-height in fullscreen).
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width - (root.fullscreen ? 0px : 132px);
            height: root.fullscreen ? 0px : 32px;
            background: #0b0c12cc;
            TouchArea { clicked => { root.overlay-dismiss(); } }
        }
        // everything below the top bar (pane area + sidebar rail).
        Rectangle {
            x: 0;
            y: root.fullscreen ? 0px : 32px;
            width: parent.width;
            height: parent.height - (root.fullscreen ? 0px : 32px);
            background: #0b0c12cc;
            TouchArea { clicked => { root.overlay-dismiss(); } }
        }
        OverlayLayer {
            width: 100%;
            height: 100%;
            kind: root.overlay-kind;
            palette: root.palette;
            palette-sel: root.palette-sel;
            families: root.pref-families;
            font-label: root.pref-font-label;
            font-custom: root.pref-font-custom;
            font-custom-value: root.pref-font-custom-value;
            preview-surface: root.pref-preview-surface;
            preview-accent: root.pref-preview-accent;
            preview-bg: root.pref-preview-bg;
            preview-glow: root.pref-preview-glow;
            themes: root.pref-themes;
            theme-label: root.pref-theme-label;
            frame-palettes: root.pref-palettes;
            shells: root.pref-shells;
            shell-label: root.pref-shell-label;
            idle-alert: root.pref-idle-alert;
            idle-effects: root.pref-idle-effects;
            idle-effect-label: root.pref-idle-effect-label;
            idle-seconds: root.pref-idle-seconds;
            keybindings: root.pref-keybindings;
            keybinds-overridden: root.pref-keybinds-overridden;
            kb-conflict: root.pref-kb-conflict;
            font-px: root.pref-fontpx;
            show-frame: root.pref-frame;
            show-dot: root.pref-dot;
            clickable-paths: root.pref-clickable;
            editor-command: root.pref-editor;
            prefs-confirm: root.prefs-confirm;
            palette-query(q) => { root.palette-query(q); }
            palette-nav(d) => { root.palette-nav(d); }
            palette-activate => { root.palette-activate(); }
            palette-pick(i) => { root.palette-pick(i); }
            pref-action(k, a) => { root.pref-action(k, a); }
            pref-text(k, v) => { root.pref-text(k, v); }
            pref-done => { root.pref-done(); }
            pref-confirm(a) => { root.pref-confirm(a); }
            pref-rebind(id) => { root.pref-rebind(id); }
            pref-capture(c, a, s, t) => { root.pref-capture(c, a, s, t); }
            pref-cancel-rebind => { root.pref-cancel-rebind(); }
            pref-reset-binding(id) => { root.pref-reset-binding(id); }
            pref-reset-all-bindings => { root.pref-reset-all-bindings(); }
            dismiss => { root.overlay-dismiss(); }
        }
    }

    // ===== context menu (pane header / tab strip) =====
    // Mounted at the window root so it overlays the top bar, panes + sidebar and its click-away
    // catcher covers the whole window. Recreated each open (so its submenu state resets).
    if root.ctx-kind != 0 : ContextMenu {
        width: 100%;
        height: 100%;
        menu-x: root.ctx-x;
        menu-y: root.ctx-y;
        entries: root.ctx-entries;
        swatches: root.ctx-swatches;
        cur-swatch: root.ctx-cur-swatch;
        frame-on: root.ctx-frame;
        dot-on: root.ctx-dot;
        tabs: root.ctx-tabs;
        layouts: root.ctx-layouts;
        pick(i) => { root.ctx-pick(i); }
        swatch(i) => { root.ctx-swatch(i); }
        swatch-none => { root.ctx-swatch-none(); }
        set-frame(v) => { root.ctx-frame-set(v); }
        set-dot(v) => { root.ctx-dot-set(v); }
        move-tab(i) => { root.ctx-move-tab(i); }
        set-layout(i) => { root.ctx-layout(i); }
        dismiss => { root.ctx-dismiss(); }
    }

    // ===== cross-window tear-off target glow =====
    // A bright inset border drawn over the whole window while it's the live target of a
    // pane being torn in from another window (click-through — the drag pump owns input).
    if root.drop-win-active : Rectangle {
        background: Theme.brand.with-alpha(0.06);
        border-width: 2.5px;
        border-color: Theme.brand;
        border-radius: 8px;
    }

    // ===== fullscreen "Hold Esc to exit" hint (ported 1:1 from the Electron app) =====
    // Boxless: bare terminal-coloured text + an "Esc" key chip above a thin
    // progress track whose fill grows while Esc is held. Shown on entering
    // fullscreen (a brief flash) and again whenever Esc is being held.
    if root.fullscreen : Rectangle {
        // Fixed size — a sizeless Rectangle in a Window fills it (which would
        // centre the content mid-screen), so pin width/height and place it.
        width: 280px;
        height: 38px;
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 28px;
        opacity: (root.fullscreen-hint || root.esc-holding) ? 1.0 : 0.0;
        animate opacity { duration: 220ms; easing: ease-out; }

        VerticalLayout {
            alignment: center;
            spacing: 7px;

            // text line (centred row)
            HorizontalLayout {
                alignment: center;
                spacing: 5px;
                Text {
                    text: "Hold";
                    color: #cdd6f4;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                Rectangle {
                    background: #cdd6f424;          // foreground @ ~14% alpha
                    border-radius: 5px;
                    HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 6px;
                        padding-top: 1px;
                        padding-bottom: 1px;
                        Text {
                            text: "Esc";
                            color: #cdd6f4;
                            font-size: 12px;
                            font-weight: 700;
                        }
                    }
                }
                Text {
                    text: "to exit fullscreen";
                    color: #cdd6f4;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }

            // progress track (168×3, centred row) + fill that grows over the hold
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 168px;
                    height: 3px;
                    border-radius: 2px;
                    background: #cdd6f424;
                    clip: true;
                    Rectangle {
                        x: 0;
                        height: parent.height;
                        border-radius: 2px;
                        background: #cdd6f4;
                        width: root.esc-holding ? parent.width : 0px;
                        animate width {
                            duration: root.esc-holding ? 600ms : 150ms;
                            easing: linear;
                        }
                    }
                }
            }
        }
    }
}
