// The hyperpanes single-window MVP shell.
//
//   frameless Window  →  custom icon-only top bar (drag region + min/max/close + tab + tools)
//                     →  a pane area that absolutely-positions N reusable `TerminalPane`s
//                        at the rects the Rust side computes from `core::layout::compute_tiles`.
//
// The Rust controller (`src/main.rs`) drives everything: it fills `panes` (each carries its
// already-computed logical-px rect + the rendered terminal `surface`), routes `key` to the
// focused pane's session, and turns the top-bar callbacks into Win32 window ops.

import { TerminalPane, KeyMsg } from "@widgets";

// One tiled pane: the rendered terminal surface + its placement (logical px) + chrome state.
export struct PaneItem {
    surface: image,
    title: string,
    accent: color,
    x: length,
    y: length,
    w: length,
    h: length,
    visible: bool,
    focused: bool,
}

// A flat icon button for the top bar (window controls + tools).
component IconButton inherits Rectangle {
    in property <string> label;
    in property <color> ink: #c8c8d4;
    in property <color> hover-bg: #ffffff1a;
    in property <length> glyph-size: 14px;
    // Empty → the default UI font; window controls use "Segoe MDL2 Assets".
    in property <string> glyph-font: "";
    callback clicked;

    width: 44px;
    background: ta.has-hover ? hover-bg : transparent;
    animate background { duration: 90ms; }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        horizontal-alignment: center;
        vertical-alignment: center;
        color: root.ink;
        font-size: root.glyph-size;
        font-family: root.glyph-font;
        font-weight: 600;
    }
}

export component AppWindow inherits Window {
    title: "hyperpanes";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 480px;
    min-height: 320px;
    default-font-size: 14px;
    background: #0c0c12;

    // ---- inputs (driven from Rust) ----
    in property <[PaneItem]> panes;
    in property <string> tab-title: "shell";
    in property <string> layout-name: "auto";
    in property <string> hud: "";

    // ---- outputs (Rust subscribes) ----
    callback key(int, KeyMsg);          // (pane index, key) from the focused pane
    callback focus-pane(int);           // a pane was clicked → focus it
    callback area-resized(length, length);
    callback new-pane();
    callback close-focused();
    callback cycle-layout();
    // window controls (→ Win32)
    callback start-drag();
    callback min-window();
    callback max-window();
    callback close-window();

    VerticalLayout {
        spacing: 0px;

        // ===== custom top bar =====
        Rectangle {
            height: 40px;
            background: @linear-gradient(180deg, #1a1a26 0%, #14141d 100%);

            // Whole-bar drag region (sits UNDER the buttons; plain items above don't grab,
            // so empty bar space falls through to here).
            TouchArea {
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                        root.start-drag();
                    }
                }
                double-clicked => { root.max-window(); }
            }

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 4px;
                spacing: 8px;

                // brand dot + name
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 100px;
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Rectangle {
                                width: 10px; height: 10px; border-radius: 5px;
                                y: (parent.height - self.height) / 2;
                                background: #7aa2f7;
                            }
                            Text {
                                text: "hyperpanes";
                                color: #e6e6f0;
                                font-size: 13px;
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // single tab chip
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        height: 24px;
                        background: #2a2a3a;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: #3a3a50;
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            Text {
                                text: root.tab-title;
                                color: #c8c8d4;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // flexible spacer
                Rectangle { horizontal-stretch: 1; }

                // hud (fps / renderer)
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: root.hud;
                        color: #5a5a6a;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                // tools: layout cycle, new pane, close pane (Segoe MDL2 Assets glyphs)
                IconButton {
                    label: "\u{E80A}";        // GridView — cycle layout
                    glyph-font: "Segoe MDL2 Assets";
                    glyph-size: 13px;
                    clicked => { root.cycle-layout(); }
                }
                IconButton {
                    label: "\u{E710}";        // Add — new pane
                    glyph-font: "Segoe MDL2 Assets";
                    glyph-size: 13px;
                    clicked => { root.new-pane(); }
                }
                IconButton {
                    label: "\u{E711}";        // Cancel — close focused pane
                    glyph-font: "Segoe MDL2 Assets";
                    glyph-size: 12px;
                    ink: #b0b0bc;
                    clicked => { root.close-focused(); }
                }

                // small separator before window controls
                Rectangle { width: 8px; }

                // window controls (Segoe MDL2 Assets: Chrome Minimize / Maximize / Close)
                IconButton {
                    label: "\u{E921}";
                    glyph-font: "Segoe MDL2 Assets";
                    glyph-size: 10px;
                    clicked => { root.min-window(); }
                }
                IconButton {
                    label: "\u{E922}";
                    glyph-font: "Segoe MDL2 Assets";
                    glyph-size: 10px;
                    clicked => { root.max-window(); }
                }
                IconButton {
                    label: "\u{E8BB}";
                    glyph-font: "Segoe MDL2 Assets";
                    glyph-size: 10px;
                    hover-bg: #e0445a;
                    clicked => { root.close-window(); }
                }
            }
        }

        // ===== pane area =====
        area := Rectangle {
            vertical-stretch: 1;
            background: #0c0c12;
            clip: true;

            changed width => { root.area-resized(self.width, self.height); }
            changed height => { root.area-resized(self.width, self.height); }

            for pane[idx] in root.panes: Rectangle {
                x: pane.x;
                y: pane.y;
                width: pane.w;
                height: pane.h;
                visible: pane.visible;

                tp := TerminalPane {
                    width: 100%;
                    height: 100%;
                    surface: pane.surface;
                    title: pane.title;
                    accent: pane.accent;
                    key(m) => { root.key(idx, m); }
                }

                // focus ring over the focused pane
                if pane.focused: Rectangle {
                    border-width: 2px;
                    border-radius: 12px;
                    border-color: pane.accent;
                }

                // click-to-focus: on TOP of the pane so we can both notify Rust and
                // forward focus into the terminal's FocusScope.
                TouchArea {
                    clicked => {
                        root.focus-pane(idx);
                        tp.focus();
                    }
                }
            }

            // empty-state hint (no panes yet)
            if root.panes.length == 0: Text {
                text: "starting shell…";
                color: #44444f;
                font-size: 14px;
            }
        }
    }
}
