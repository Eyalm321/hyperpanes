// The right-edge sidebar rail — the native port of `components/Sidebar.tsx`.
//
//   ┌──┐  a slim (44px), PERSISTENT, icon-only rail living to the RIGHT of the pane
//   │＋│  area (a sibling, not an overlay — no scrim, never dims the panes). Gated by
//   │📁│  `show-sidebar` (and hidden in fullscreen) up in app.slint.
//   └──┘
//   ＋  quick-pane: opens a default pane.
//   📁  projects: a count badge + an IN-RAIL expansion. Clicking widens the whole rail
//       (the width binding lives in app.slint) to reveal a projects section to the LEFT of
//       the icon column — in-place, NOT a floating overlay. The section is a TWO-LEVEL
//       TREE: project rows (chevron ▸/▾ + color dot + name) → expand to show
//       that project's git worktrees, each with a trash icon. Trash → an in-sidebar
//       Cancel/Confirm popup (Esc=cancel / Enter=confirm). Project rows also: left-click the
//       name opens the repo in a pane; right-click → recolor / rename / remove (from history).
//
// All project/worktree data is computed by the Rust controller and pushed via `projects`
// (each `ProjectItem` carries its `worktrees`). Expand/collapse is local UI state per row.
// The worktree-delete request travels back through the existing `open-project(int)` callback
// with an out-of-range encoded index (DELETE_BASE + proj*STRIDE + wt) so the sidebar stays
// self-contained — no new app-level wiring.

import { Theme } from "theme.slint";
import { ProjectItem, WorktreeRow } from "types.slint";

// "+" quick-pane glyph (two crossed bars — font-independent).
component PlusGlyph inherits Rectangle {
    in property <color> ink;
    width: 16px;
    height: 16px;
    Rectangle { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; width: 1.7px; height: 13px; border-radius: 1px; background: ink; }
    Rectangle { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; height: 1.7px; width: 13px; border-radius: 1px; background: ink; }
}

// A folder silhouette (stroked).
component FolderGlyph inherits Path {
    in property <color> ink;
    width: 18px;
    height: 18px;
    viewbox-width: 18;
    viewbox-height: 18;
    stroke: ink;
    stroke-width: 1.5px;
    fill: transparent;
    commands: "M 2.5 14 L 2.5 5 L 7 5 L 8.6 6.8 L 15.5 6.8 L 15.5 14 Z";
}

// A trash-can glyph (stroked): lid + handle + can body. Font-independent.
component TrashGlyph inherits Path {
    in property <color> ink;
    width: 14px;
    height: 14px;
    viewbox-width: 14;
    viewbox-height: 14;
    stroke: ink;
    stroke-width: 1.3px;
    fill: transparent;
    // lid line, handle, then the can body with two inner streaks.
    commands: "M 2 3.5 L 12 3.5 M 5.3 3.5 L 5.6 2 L 8.4 2 L 8.7 3.5 M 3.2 3.5 L 3.9 12.5 L 10.1 12.5 L 10.8 3.5 M 5.7 5.6 L 5.9 10.4 M 8.3 5.6 L 8.1 10.4";
}

// One recolor swatch in the project context menu.
component Swatch inherits Rectangle {
    in property <color> hue;
    callback picked();
    width: 18px;
    height: 18px;
    border-radius: 4px;
    background: hue;
    border-width: sa.has-hover ? 2px : 0px;
    border-color: Theme.text;
    sa := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.picked(); }
    }
}

// The project row right-click menu: recolor swatches + an inline rename field + remove.
component ProjectMenu inherits PopupWindow {
    in property <string> pname;
    callback recolor(int);       // palette swatch index 0..7
    callback rename(string);
    callback remove();
    // anchored just below-left of the row's left edge.
    x: 10px;
    y: 26px;
    width: 220px;
    height: 158px;

    Rectangle {
        background: Theme.mantle;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-blur: 30px;
        drop-shadow-color: Theme.scrim;
        drop-shadow-offset-y: 10px;

        VerticalLayout {
            padding: 8px;
            spacing: 7px;

            Text { text: "Change Color"; color: Theme.subtext; font-size: 10px; font-weight: 700; }
            HorizontalLayout {
                spacing: 5px;
                Swatch { hue: #e5484d; picked => { root.recolor(0); root.close(); } }
                Swatch { hue: #f5a623; picked => { root.recolor(1); root.close(); } }
                Swatch { hue: #30a46c; picked => { root.recolor(2); root.close(); } }
                Swatch { hue: #3b82f6; picked => { root.recolor(3); root.close(); } }
                Swatch { hue: #a855f7; picked => { root.recolor(4); root.close(); } }
                Swatch { hue: #ec4899; picked => { root.recolor(5); root.close(); } }
                Swatch { hue: #14b8a6; picked => { root.recolor(6); root.close(); } }
                Swatch { hue: #eab308; picked => { root.recolor(7); root.close(); } }
            }

            Rectangle { height: 1px; background: Theme.border; }

            // inline rename (Enter commits)
            Rectangle {
                height: 28px;
                border-radius: 5px;
                background: Theme.surface;
                border-width: 1px;
                border-color: Theme.accent;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    ri := TextInput {
                        text: root.pname;
                        color: Theme.text;
                        font-size: 12px;
                        vertical-alignment: center;
                        single-line: true;
                        init => { ri.select-all(); ri.focus(); }
                        accepted => { root.rename(self.text); root.close(); }
                    }
                }
            }

            // remove (danger)
            Rectangle {
                height: 28px;
                border-radius: 5px;
                background: rta.has-hover ? Theme.danger : transparent;
                HorizontalLayout {
                    padding-left: 9px;
                    Text {
                        text: "Remove";
                        color: rta.has-hover ? #ffffff : Theme.danger;
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }
                rta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.remove(); root.close(); }
                }
            }
        }
    }
}

// One worktree row under an expanded project: branch label + path (dim), with a trash icon
// on the right. The main checkout's trash is disabled (git refuses `worktree remove` on it).
component WorktreeRowView inherits Rectangle {
    in property <WorktreeRow> wt;
    callback request-delete();
    // Removable only when it's neither the main checkout NOR locked — git refuses a plain
    // (`--force`-less) `worktree remove` on both, so the trash is disabled rather than letting
    // a click fall into a swallowed error.
    property <bool> deletable: !root.wt.is-main && !root.wt.locked;
    height: 36px;
    border-radius: 5px;
    background: rowa.has-hover ? Theme.surface2 : transparent;

    // row-wide hover (purely visual); sits behind the trash button.
    rowa := TouchArea { mouse-cursor: default; }

    HorizontalLayout {
        padding-left: 26px;     // indent under the project's dot
        padding-right: 4px;
        spacing: 6px;

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: root.wt.branch
                    + (root.wt.is-main ? "  ·  main" : "")
                    + (root.wt.locked ? "  ·  locked" : "")
                    + (root.wt.prunable ? "  ·  prunable" : "");
                color: Theme.text;
                font-size: 12px;
                overflow: elide;
            }
            Text {
                text: root.wt.path;
                color: Theme.subtext;
                font-size: 10px;
                overflow: elide;
            }
        }

        // trash button
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 26px;
                height: 26px;
                border-radius: 6px;
                background: (root.deletable && tta.has-hover) ? Theme.danger : transparent;
                TrashGlyph {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    ink: !root.deletable ? Theme.faint : (tta.has-hover ? #ffffff : Theme.subtext);
                }
                tta := TouchArea {
                    mouse-cursor: root.deletable ? pointer : not-allowed;
                    clicked => { if (root.deletable) { root.request-delete(); } }
                }
            }
        }
    }
}

// One project node in the tree: a collapsible header (chevron + dot + name) plus, when
// expanded, its worktree rows. Left-click the name opens the repo; the chevron toggles;
// right-click pops the recolor/rename/remove menu.
component ProjectRow inherits Rectangle {
    in property <ProjectItem> proj;
    callback open();
    callback recolor(int);
    callback rename(string);
    callback remove();
    callback request-delete(int, string);   // (worktree index within this project, path)

    property <bool> expanded: false;

    VerticalLayout {
        spacing: 1px;

        // ---- header ----
        Rectangle {
            height: 30px;
            border-radius: 5px;
            background: ta.has-hover ? Theme.surface2 : transparent;

            // full-row click target (open / right-click menu); declared FIRST so the
            // chevron's own TouchArea sits on top of it.
            ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.open(); }
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                        menu.show();
                    }
                }
            }

            HorizontalLayout {
                padding-left: 2px;
                padding-right: 8px;
                spacing: 4px;

                // chevron (toggles expand/collapse)
                Rectangle {
                    width: 20px;
                    Text {
                        text: root.expanded ? "▾" : "▸";
                        // visible by default (was a dim 11px Theme.subtext): bright, larger,
                        // bold; the accent on hover makes the toggle target obvious.
                        color: cta.has-hover ? Theme.accent : Theme.text;
                        font-size: 13px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    cta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.expanded = !root.expanded; }
                    }
                }

                // color dot
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 10px;
                        height: 10px;
                        border-radius: 5px;
                        background: root.proj.color;
                    }
                }

                // name
                Text {
                    text: root.proj.name;
                    color: Theme.text;
                    font-size: 13px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }

                // worktree count chip
                if root.proj.worktrees.length > 1 : VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 18px;
                        height: 15px;
                        border-radius: 7px;
                        background: Theme.surface2;
                        Text {
                            text: root.proj.worktrees.length;
                            color: Theme.subtext;
                            font-size: 9px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ---- worktrees (when expanded) ----
        if root.expanded : VerticalLayout {
            spacing: 1px;
            padding-bottom: 3px;

            if root.proj.worktrees.length == 0 : Text {
                text: "No worktrees found.";
                color: Theme.subtext;
                font-size: 11px;
                horizontal-alignment: left;
                height: 22px;
                vertical-alignment: center;
            }

            for w[j] in root.proj.worktrees : WorktreeRowView {
                wt: w;
                request-delete => { root.request-delete(j, w.path); }
            }
        }
    }

    menu := ProjectMenu {
        pname: root.proj.name;
        recolor(s) => { root.recolor(s); }
        rename(t) => { root.rename(t); }
        remove => { root.remove(); }
    }
}

export component SidebarRail inherits Rectangle {
    in property <[ProjectItem]> projects;
    in property <bool> projects-open: false;
    callback new-pane();
    callback open-new-pane();   // Shift+click → open the New Pane options dialog
    callback toggle-projects();
    callback open-project(int);
    callback recolor-project(int, int);   // row, swatch
    callback rename-project(int, string);
    callback remove-project(int);

    // ---- worktree-delete confirmation popup state (sidebar-local) ----
    property <bool> wt-del-visible: false;
    property <int> wt-del-proj;
    property <int> wt-del-wt;
    property <string> wt-del-name;     // worktree path, shown in the warning

    // Encoding for the worktree-delete signal smuggled through `open-project` (see header).
    property <int> DELETE-BASE: 1000000;
    property <int> DELETE-STRIDE: 1000;

    // TOCTOU guard. The delete travels as the (proj, wt) INDICES captured when the popup
    // opened, but the projects/worktrees models can change underneath us while it's open (a
    // background pane reporting a new cwd re-sorts projects newest-first; an enumeration
    // refresh reorders worktrees). Before dispatching we re-check that those indices STILL
    // address the exact path the user saw and confirmed (`wt-del-name`); if not — the list
    // moved — we abort rather than delete whatever now sits at that slot. Bounds-checked so a
    // shrunk model can't index out of range.
    pure function captured-still-valid() -> bool {
        if (root.wt-del-proj < 0 || root.wt-del-proj >= root.projects.length) {
            return false;
        }
        if (root.wt-del-wt < 0 || root.wt-del-wt >= root.projects[root.wt-del-proj].worktrees.length) {
            return false;
        }
        return root.projects[root.wt-del-proj].worktrees[root.wt-del-wt].path == root.wt-del-name;
    }

    // Width is driven by the single rail-width binding in app.slint (44px collapsed →
    // ~280px when `projects-open`); the pane area shrinks to match. Internal layout reads
    // `root.width` so the icon column anchors to the right edge and the projects section
    // fills the space to its left.
    background: Theme.mantle;

    // The fixed-width icon column on the RIGHT edge. The projects section (when open)
    // occupies everything to the left of this.
    property <length> rail-icons-w: 44px;

    // left hairline against the pane area
    Rectangle { x: 0; width: 1px; height: 100%; background: Theme.border; }

    // ＋ quick-pane
    plus-btn := Rectangle {
        x: root.width - root.rail-icons-w + 6px;   // anchored to the rail's right edge
        y: 6px;
        width: 32px;
        height: 32px;
        border-radius: 7px;
        background: pa.has-hover ? Theme.surface2 : transparent;
        PlusGlyph {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            ink: pa.has-hover ? Theme.text : Theme.subtext;
        }
        // Plain click adds a default pane immediately; Shift-click opens the New Pane
        // options dialog (mirrors Electron's Sidebar ＋). Shift is sampled on press and
        // consumed on the resulting click.
        property <bool> shift-down: false;
        pa := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                if (parent.shift-down) { root.open-new-pane(); } else { root.new-pane(); }
            }
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) { parent.shift-down = e.modifiers.shift; }
            }
        }
    }

    // 📁 projects + count badge
    folder-btn := Rectangle {
        x: root.width - root.rail-icons-w + 6px;   // anchored to the rail's right edge
        y: 42px;
        width: 32px;
        height: 32px;
        border-radius: 7px;
        background: (root.projects-open || fa.has-hover) ? Theme.surface2 : transparent;
        FolderGlyph {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            ink: root.projects-open ? Theme.accent : (fa.has-hover ? Theme.text : Theme.subtext);
        }
        if root.projects.length > 0 : Rectangle {
            x: parent.width - self.width - 1px;
            y: 1px;
            width: 15px;
            height: 14px;
            border-radius: 7px;
            background: Theme.accent;
            Text {
                text: root.projects.length;
                color: #11111b;
                font-size: 9px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }
        fa := TouchArea {
            mouse-cursor: pointer;
            clicked => { root.toggle-projects(); }
        }
    }

    // ===== projects section (IN-RAIL — fills the widened rail to the LEFT of the icons) =====
    // The rail's width (in app.slint) grows when `projects-open`, and this section fills
    // everything left of the fixed icon column. No scrim / shadow / float — it's part of
    // the rail, so the pane area to its left simply shrinks.
    if root.projects-open : Rectangle {
        x: 0;
        y: 0;
        width: root.width - root.rail-icons-w;
        height: root.height;
        background: Theme.mantle;
        clip: true;
        // eat stray clicks so they don't fall through to a pane behind the section
        TouchArea {}

        // divider hairline separating the projects section from the icon column
        Rectangle { x: parent.width - 1px; width: 1px; height: 100%; background: Theme.border; }

        VerticalLayout {
            padding: 8px;
            spacing: 4px;

            Text {
                text: "PROJECTS";
                color: Theme.subtext;
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 0.5px;
                height: 18px;
                vertical-alignment: center;
            }

            if root.projects.length == 0 : Text {
                text: "Projects you cd into show up here. Expand one to manage its git worktrees.";
                color: Theme.subtext;
                font-size: 12px;
                wrap: word-wrap;
            }

            // scrollable tree (projects + their expanded worktrees)
            Rectangle {
                vertical-stretch: 1;
                clip: true;
                Flickable {
                    width: 100%;
                    height: 100%;
                    viewport-width: self.width;
                    viewport-height: treebody.preferred-height;
                    treebody := VerticalLayout {
                    alignment: start;
                    spacing: 2px;

                    for p[i] in root.projects : ProjectRow {
                        proj: p;
                        open => { root.open-project(i); }
                        recolor(s) => { root.recolor-project(i, s); }
                        rename(t) => { root.rename-project(i, t); }
                        remove => { root.remove-project(i); }
                        request-delete(j, path) => {
                            root.wt-del-proj = i;
                            root.wt-del-wt = j;
                            root.wt-del-name = path;
                            root.wt-del-visible = true;
                        }
                    }
                    }
                }
            }
        }
    }

    // ===== worktree-delete confirmation popup (sidebar-local overlay) =====
    // Rendered at the rail root so it isn't clipped by the flyout; covers the pane area to
    // the left with a scrim and a centered card. A FocusScope grabs focus on appear so
    // Esc=Cancel / Enter=Confirm work without any app-level key wiring.
    if root.wt-del-visible : Rectangle {
        // span far to the left over the panes AND across the full (possibly widened) rail
        // so the scrim covers the open projects section too (the rail is at the window's
        // right edge).
        x: -2000px;
        width: root.width + 2000px;
        y: 0;
        height: root.height;

        // scrim — also swallows clicks outside the card (no dismissal on outside click;
        // use Cancel/Esc so a misclick can't silently delete).
        Rectangle {
            background: #0b0c12cc;
            // Swallow scrim clicks (no outside-click dismissal — use Cancel/Esc) AND, if the
            // click did land here, pull keyboard focus back to the FocusScope so Esc/Enter keep
            // working afterwards.
            TouchArea {
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down) { fs.focus(); }
                }
            }
        }

        // the card
        Rectangle {
            width: 340px;
            height: 168px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            // Any focus landing on the card delegates to the key-handling FocusScope, so a
            // click on the card chrome can't silently strand Esc/Enter.
            forward-focus: fs;
            background: Theme.mantle;
            border-radius: 10px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 40px;
            drop-shadow-color: Theme.scrim;
            drop-shadow-offset-y: 12px;

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                Text {
                    text: "Remove worktree?";
                    color: Theme.text;
                    font-size: 15px;
                    font-weight: 700;
                }
                Text {
                    text: "This deletes the working directory:\n" + root.wt-del-name;
                    color: Theme.subtext;
                    font-size: 12px;
                    wrap: word-wrap;
                    vertical-stretch: 1;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    // Cancel
                    Rectangle {
                        width: 90px;
                        height: 32px;
                        border-radius: 7px;
                        border-width: 1px;
                        border-color: Theme.border;
                        background: ca.has-hover ? Theme.surface2 : transparent;
                        Text {
                            text: "Cancel";
                            color: Theme.text;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        ca := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.wt-del-visible = false; }
                        }
                    }

                    // Confirm (danger)
                    Rectangle {
                        width: 110px;
                        height: 32px;
                        border-radius: 7px;
                        background: cfa.has-hover ? #ff5b60 : Theme.danger;
                        Text {
                            text: "Remove";
                            color: #ffffff;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        cfa := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                // TOCTOU guard: only dispatch if the captured indices still
                                // point at the confirmed path; otherwise abort (no delete).
                                if (root.captured-still-valid()) {
                                    root.open-project(root.DELETE-BASE + root.wt-del-proj * root.DELETE-STRIDE + root.wt-del-wt);
                                }
                                root.wt-del-visible = false;
                            }
                        }
                    }
                }
            }

            // key handling: grabs focus when the popup appears (the `if` recreates this on
            // each show, so `init` re-fires), traps Esc → cancel / Enter → confirm.
            fs := FocusScope {
                init => { fs.focus(); }
                key-pressed(e) => {
                    if (e.text == Key.Escape) {
                        root.wt-del-visible = false;
                        return EventResult.accept;
                    }
                    if (e.text == Key.Return) {
                        // Same TOCTOU guard as the Confirm button (see captured-still-valid).
                        if (root.captured-still-valid()) {
                            root.open-project(root.DELETE-BASE + root.wt-del-proj * root.DELETE-STRIDE + root.wt-del-wt);
                        }
                        root.wt-del-visible = false;
                        return EventResult.accept;
                    }
                    return EventResult.reject;
                }
            }
        }
    }
}
