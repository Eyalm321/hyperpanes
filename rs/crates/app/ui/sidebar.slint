// The right-edge sidebar rail — the native port of `components/Sidebar.tsx`.
//
//   ┌──┐  a slim (44px), PERSISTENT, icon-only rail living to the RIGHT of the pane
//   │＋│  area (a sibling, not an overlay — no scrim, never dims the panes). Gated by
//   │📁│  `show-sidebar` (and hidden in fullscreen) up in app.slint.
//   └──┘
//   ＋  quick-pane: opens a default pane.
//   📁  projects: a count badge + an IN-RAIL expansion. Clicking widens the whole rail
//       (the width binding lives in app.slint) to reveal a projects section to the LEFT of
//       the icon column — in-place, NOT a floating overlay. The section is a TWO-LEVEL
//       TREE: project rows (chevron ▸/▾ + color dot + name) → expand to show
//       that project's git worktrees, each with a trash icon. Trash → an in-sidebar
//       Cancel/Confirm popup (Esc=cancel / Enter=confirm). Project rows also: left-click the
//       name opens the repo in a pane; right-click → recolor / rename / remove (from history).
//
// All project/worktree data is computed by the Rust controller and pushed via `projects`
// (each `ProjectItem` carries its `worktrees`). Expand/collapse is local UI state per row.
// The worktree-delete request travels back through the existing `open-project(int)` callback
// with an out-of-range encoded index (DELETE_BASE + proj*STRIDE + wt) so the sidebar stays
// self-contained — no new app-level wiring.

import { Theme } from "theme.slint";
import { ProjectItem, WorktreeRow, ClaudeSessionItem, HistoryUi, ReminderItem, RemindersAdapter } from "types.slint";

// "+" quick-pane glyph (two crossed bars — font-independent). `bar` sets the cross size
// (13px rail default; smaller for inline/submenu buttons like the PROJECTS-header ＋).
component PlusGlyph inherits Rectangle {
    in property <color> ink;
    in property <length> bar: 13px;
    width: self.bar + 3px;
    height: self.bar + 3px;
    Rectangle { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; width: 1.7px; height: root.bar; border-radius: 1px; background: ink; }
    Rectangle { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; height: 1.7px; width: root.bar; border-radius: 1px; background: ink; }
}

// New-pane icon, simplified: a window frame with a plus inside. Composed from Rectangles
// (Slint's Path garbled the raw Material path data — relative q/v + negative viewbox).
component NewPaneGlyph inherits Rectangle {
    in property <color> ink;
    width: 18px;
    height: 18px;
    // window frame
    Rectangle { x: 1px; y: 2px; width: 16px; height: 14px; border-width: 1.6px; border-color: ink; border-radius: 2.5px; background: transparent; }
    // centered plus
    Rectangle { x: 8.2px; y: 5.5px; width: 1.6px; height: 7px; border-radius: 1px; background: ink; }
    Rectangle { x: 5.5px; y: 8.2px; width: 7px; height: 1.6px; border-radius: 1px; background: ink; }
}

// A folder silhouette (stroked).
component FolderGlyph inherits Path {
    in property <color> ink;
    width: 18px;
    height: 18px;
    viewbox-width: 18;
    viewbox-height: 18;
    stroke: ink;
    stroke-width: 1.5px;
    fill: transparent;
    commands: "M 2.5 14 L 2.5 5 L 7 5 L 8.6 6.8 L 15.5 6.8 L 15.5 14 Z";
}

// A trash-can glyph (stroked): lid + handle + can body. Font-independent.
component TrashGlyph inherits Path {
    in property <color> ink;
    width: 14px;
    height: 14px;
    viewbox-width: 14;
    viewbox-height: 14;
    stroke: ink;
    stroke-width: 1.3px;
    fill: transparent;
    // lid line, handle, then the can body with two inner streaks.
    commands: "M 2 3.5 L 12 3.5 M 5.3 3.5 L 5.6 2 L 8.4 2 L 8.7 3.5 M 3.2 3.5 L 3.9 12.5 L 10.1 12.5 L 10.8 3.5 M 5.7 5.6 L 5.9 10.4 M 8.3 5.6 L 8.1 10.4";
}

// One recolor swatch in the project context menu.
component Swatch inherits Rectangle {
    in property <color> hue;
    callback picked();
    width: 18px;
    height: 18px;
    border-radius: 4px;
    background: hue;
    border-width: sa.has-hover ? 2px : 0px;
    border-color: Theme.text;
    sa := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.picked(); }
    }
}

// The project row right-click menu: recolor swatches + an inline rename field + remove.
component ProjectMenu inherits PopupWindow {
    in property <string> pname;
    callback recolor(int);       // palette swatch index 0..7
    callback rename(string);
    callback remove();
    // anchored just below-left of the row's left edge. Height tracks the content (a fixed
    // height over-allocates, and Slint distributes the surplus into the gaps — which is
    // exactly what made "Change Color" drift away from its swatches).
    x: 10px;
    y: 26px;
    width: 220px;
    height: mbody.preferred-height;

    Rectangle {
        background: Theme.mantle;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-blur: 30px;
        drop-shadow-color: Theme.scrim;
        drop-shadow-offset-y: 10px;

        mbody := VerticalLayout {
            padding: 8px;
            spacing: 7px;

            // label + swatches read as ONE group (2px between them; 7px stays between groups).
            VerticalLayout {
                spacing: 2px;
                Text { text: "Change Color"; color: Theme.subtext; font-size: 10px; font-weight: 700; }
                HorizontalLayout {
                    // tight, cohesive swatch group, left-aligned to match the menu's other rows
                    // (the default `stretch` would spread the fixed-width swatches apart).
                    spacing: 3px;
                    alignment: start;
                    Swatch { hue: #e5484d; picked => { root.recolor(0); root.close(); } }
                    Swatch { hue: #f5a623; picked => { root.recolor(1); root.close(); } }
                    Swatch { hue: #30a46c; picked => { root.recolor(2); root.close(); } }
                    Swatch { hue: #3b82f6; picked => { root.recolor(3); root.close(); } }
                    Swatch { hue: #a855f7; picked => { root.recolor(4); root.close(); } }
                    Swatch { hue: #ec4899; picked => { root.recolor(5); root.close(); } }
                    Swatch { hue: #14b8a6; picked => { root.recolor(6); root.close(); } }
                    Swatch { hue: #eab308; picked => { root.recolor(7); root.close(); } }
                }
            }

            Rectangle { height: 1px; background: Theme.border; }

            // inline rename (Enter commits)
            Rectangle {
                height: 28px;
                border-radius: 5px;
                background: Theme.surface;
                border-width: 1px;
                border-color: Theme.accent;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    ri := TextInput {
                        text: root.pname;
                        color: Theme.text;
                        font-size: 12px;
                        vertical-alignment: center;
                        single-line: true;
                        init => { ri.select-all(); ri.focus(); }
                        accepted => { root.rename(self.text); root.close(); }
                    }
                }
            }

            // remove (danger)
            Rectangle {
                height: 28px;
                border-radius: 5px;
                background: rta.has-hover ? Theme.danger : transparent;
                HorizontalLayout {
                    padding-left: 9px;
                    Text {
                        text: "Remove";
                        color: rta.has-hover ? #ffffff : Theme.danger;
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }
                rta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.remove(); root.close(); }
                }
            }
        }
    }
}

// One worktree row under an expanded project: branch label + path (dim), with a trash icon
// on the right. The main checkout's trash is disabled (git refuses `worktree remove` on it).
component WorktreeRowView inherits Rectangle {
    in property <WorktreeRow> wt;
    callback request-delete();
    // Removable only when it's neither the main checkout NOR locked — git refuses a plain
    // (`--force`-less) `worktree remove` on both, so the trash is disabled rather than letting
    // a click fall into a swallowed error.
    property <bool> deletable: !root.wt.is-main && !root.wt.locked;
    height: 36px;
    border-radius: 5px;
    background: rowa.has-hover ? Theme.surface2 : transparent;

    // row-wide hover (purely visual); sits behind the trash button.
    rowa := TouchArea { mouse-cursor: default; }

    HorizontalLayout {
        padding-left: 26px;     // indent under the project's dot
        padding-right: 4px;
        spacing: 6px;

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: root.wt.branch
                    + (root.wt.is-main ? "  ·  main" : "")
                    + (root.wt.locked ? "  ·  locked" : "")
                    + (root.wt.prunable ? "  ·  prunable" : "");
                color: Theme.text;
                font-size: 12px;
                overflow: elide;
            }
            Text {
                text: root.wt.path;
                color: Theme.subtext;
                font-size: 10px;
                overflow: elide;
            }
        }

        // trash button
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 26px;
                height: 26px;
                border-radius: 6px;
                background: (root.deletable && tta.has-hover) ? Theme.danger : transparent;
                TrashGlyph {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    ink: !root.deletable ? Theme.faint : (tta.has-hover ? #ffffff : Theme.subtext);
                }
                tta := TouchArea {
                    mouse-cursor: root.deletable ? pointer : not-allowed;
                    clicked => { if (root.deletable) { root.request-delete(); } }
                }
            }
        }
    }
}

// A bell glyph (stroked dome + lip + clapper) for the reminders rail button. Drawn geometry,
// NOT a font glyph: the previous "\u{E7ED}" (Segoe MDL2 Assets "Ringer") lives in the Unicode
// Private-Use Area, so when the icon font fails to resolve it falls back to a font with no
// glyph there and renders INVISIBLE — the same failure df73005 fixed for the project chevron.
component BellGlyph inherits Path {
    in property <color> ink;
    width: 16px;
    height: 16px;
    viewbox-width: 16;
    viewbox-height: 16;
    stroke: ink;
    stroke-width: 1.4px;
    fill: transparent;
    // dome (left lip → arc over the top → right lip), the bottom lip line, then the clapper.
    commands: "M 4.3 11 L 4.3 7.2 A 3.7 3.7 0 0 1 11.7 7.2 L 11.7 11 M 3 11 L 13 11 M 6.6 13 A 1.5 1.5 0 0 0 9.4 13";
}

// A magnifier glyph (stroked circle + handle) for the history search box. Font-independent,
// matching the Folder/Trash glyphs above.
component SearchGlyph inherits Path {
    in property <color> ink;
    width: 11px;
    height: 11px;
    viewbox-width: 12;
    viewbox-height: 12;
    stroke: ink;
    stroke-width: 1.3px;
    fill: transparent;
    commands: "M 5 1.5 A 3.5 3.5 0 1 0 5 8.5 A 3.5 3.5 0 1 0 5 1.5 M 7.6 7.6 L 11 11";
}

// One segment of the flat Worktrees|History control: a pill that brightens when active.
component Segment inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback pick();
    horizontal-stretch: 1;
    border-radius: 4px;
    background: root.active ? Theme.surface2 : (ta.has-hover ? Theme.surface : transparent);
    Text {
        text: root.label;
        color: root.active ? Theme.text : Theme.subtext;
        font-size: 10px;
        font-weight: root.active ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.pick(); }
    }
}

// The compact Xcode-style segmented bar inside an expanded project: Worktrees | History.
// Only rendered when the project has any history (`proj.has-history`); with none the
// expanded body just shows the worktrees, bar-less, as before.
component SegmentedBar inherits Rectangle {
    in property <int> selected;
    callback select(int);
    height: 22px;
    border-radius: 5px;
    background: Theme.mantle;
    border-width: 1px;
    border-color: Theme.border;
    HorizontalLayout {
        padding: 2px;
        spacing: 2px;
        Segment {
            label: "Worktrees";
            active: root.selected == 0;
            pick => { root.select(0); }
        }
        Segment {
            label: "History";
            active: root.selected == 1;
            pick => { root.select(1); }
        }
    }
}

// A small play/resume triangle (filled) — "resume this session in a new pane". Drawn as a
// Path so it's font-independent, matching the Folder/Trash glyphs above.
component ResumeGlyph inherits Path {
    in property <color> ink;
    width: 11px;
    height: 11px;
    viewbox-width: 12;
    viewbox-height: 12;
    fill: ink;
    commands: "M 3 2 L 10 6 L 3 10 Z";
}

// One Claude-session row under an expanded project's "Claude history" list: a play glyph, the
// session summary, and a dim "relative-time · N msgs" meta line. Clicking resumes the session
// (`claude --resume <id>`) in a new pane in the project's cwd. Mirrors the worktree row idiom.
component ClaudeSessionRowView inherits Rectangle {
    in property <ClaudeSessionItem> session;
    callback resume();
    height: 34px;
    border-radius: 5px;
    background: sa.has-hover ? Theme.surface2 : transparent;

    HorizontalLayout {
        padding-left: 26px;     // indent to align under the project's dot, like worktree rows
        padding-right: 6px;
        spacing: 7px;

        // play / resume glyph
        VerticalLayout {
            alignment: center;
            ResumeGlyph {
                ink: sa.has-hover ? Theme.accent : Theme.subtext;
            }
        }

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: root.session.summary;
                color: Theme.text;
                font-size: 12px;
                overflow: elide;
            }
            // meta: "Claude · 2h ago · 42 msgs". The count is its own Text (an int
            // auto-converts on assignment), avoiding int+string concatenation (which Slint
            // does not do). The leading source label keeps the harness generic (#26).
            HorizontalLayout {
                alignment: start;
                spacing: 4px;
                if root.session.source != "" : Text {
                    text: root.session.source;
                    color: Theme.subtext;
                    font-size: 10px;
                }
                if root.session.source != "" && root.session.when != "" : Text {
                    text: "·";
                    color: Theme.faint;
                    font-size: 10px;
                }
                if root.session.when != "" : Text {
                    text: root.session.when;
                    color: Theme.subtext;
                    font-size: 10px;
                }
                if root.session.when != "" && root.session.count > 0 : Text {
                    text: "·";
                    color: Theme.faint;
                    font-size: 10px;
                }
                if root.session.count > 0 : Text {
                    text: root.session.count;
                    color: Theme.subtext;
                    font-size: 10px;
                }
                if root.session.count > 0 : Text {
                    text: "msgs";
                    color: Theme.subtext;
                    font-size: 10px;
                }
            }
        }
    }

    sa := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.resume(); }
    }
}

// One project node in the tree: a collapsible header (chevron + dot + name) plus, when
// expanded, its worktree rows. Left-click the name opens the repo; the chevron toggles;
// right-click pops the recolor/rename/remove menu.
component ProjectRow inherits Rectangle {
    in property <ProjectItem> proj;
    // This project's recent Claude Code sessions (newest-first), rendered as a collapsible
    // "Claude history" list under the worktrees. Fed by the controller; empty hides the list.
    in property <[ClaudeSessionItem]> sessions;
    callback open();
    callback recolor(int);
    callback rename(string);
    callback remove();
    callback request-delete(int, string);   // (worktree index within this project, path)
    callback resume-session(string);         // resume Claude session <id> in a new pane
    callback segment-changed(int);           // Worktrees|History segment picked (0 / 1)
    callback query-edited(string);           // history search text edited

    property <bool> expanded: false;

    VerticalLayout {
        spacing: 1px;

        // ---- header ----
        Rectangle {
            height: 30px;
            border-radius: 5px;
            background: ta.has-hover ? Theme.surface2 : transparent;

            // full-row click target (open / right-click menu); declared FIRST so the
            // chevron's own TouchArea sits on top of it.
            ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.open(); }
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                        menu.show();
                    }
                }
            }

            HorizontalLayout {
                padding-left: 2px;
                padding-right: 8px;
                spacing: 4px;

                // expand toggle — Material "unfold" icon as DRAWN geometry (not a font
                // glyph; the df73005 failure class): collapsed = unfold_more (chevrons
                // pointing apart), expanded = unfold_less (chevrons pointing together).
                Rectangle {
                    width: 20px;
                    Path {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 9px;
                        height: 10px;
                        viewbox-width: 10;
                        viewbox-height: 10;
                        stroke: cta.has-hover ? Theme.accent : Theme.text;
                        stroke-width: 1.7px;
                        fill: transparent;
                        commands: root.expanded
                            ? "M 2.5 0.8 L 5 3.3 L 7.5 0.8 M 2.5 9.2 L 5 6.7 L 7.5 9.2"
                            : "M 2.5 3.3 L 5 0.8 L 7.5 3.3 M 2.5 6.7 L 5 9.2 L 7.5 6.7";
                    }
                    cta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.expanded = !root.expanded; }
                    }
                }

                // color dot
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 10px;
                        height: 10px;
                        border-radius: 5px;
                        background: root.proj.color;
                    }
                }

                // name
                Text {
                    text: root.proj.name;
                    color: Theme.text;
                    font-size: 13px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }

                // worktree count chip
                if root.proj.worktrees.length > 1 : VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 18px;
                        height: 15px;
                        border-radius: 7px;
                        background: Theme.surface2;
                        Text {
                            text: root.proj.worktrees.length;
                            color: Theme.subtext;
                            font-size: 9px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ---- expanded body: [Worktrees | History] segments (bar only with history) ----
        if root.expanded : VerticalLayout {
            spacing: 1px;
            padding-bottom: 3px;

            // segmented bar — rendered only when the project has any history at all
            // (`has-history` is the UNFILTERED gate, so an unmatched query can't collapse
            // the bar and strand the user). Without history the body is just the worktrees.
            if root.proj.has-history : HorizontalLayout {
                padding-left: 22px;     // nest just inside the row content, like the rows
                padding-right: 6px;
                padding-bottom: 3px;
                SegmentedBar {
                    selected: root.proj.segment;
                    select(s) => { root.segment-changed(s); }
                }
            }

            // ---- Worktrees segment (also the bar-less default) ----
            if !root.proj.has-history || root.proj.segment == 0 : VerticalLayout {
                spacing: 1px;

                if root.proj.worktrees.length == 0 : Text {
                    text: "No worktrees found.";
                    color: Theme.subtext;
                    font-size: 11px;
                    horizontal-alignment: left;
                    height: 22px;
                    vertical-alignment: center;
                }

                for w[j] in root.proj.worktrees : WorktreeRowView {
                    wt: w;
                    request-delete => { root.request-delete(j, w.path); }
                }
            }

            // ---- History segment: search box + (filtered) session rows ----
            if root.proj.has-history && root.proj.segment == 1 : VerticalLayout {
                spacing: 1px;

                // search input (#25): filters the sessions, case-insensitively, on the Rust
                // side. The text is row-local while typing (restored from `proj.query` when
                // the row is recreated); each edit travels up via `query-edited`.
                HorizontalLayout {
                    padding-left: 26px;
                    padding-right: 6px;
                    padding-bottom: 2px;
                    Rectangle {
                        height: 24px;
                        border-radius: 5px;
                        background: Theme.mantle;
                        border-width: 1px;
                        border-color: qi.has-focus ? Theme.accent : Theme.border;
                        HorizontalLayout {
                            padding-left: 7px;
                            padding-right: 7px;
                            spacing: 5px;
                            VerticalLayout {
                                alignment: center;
                                SearchGlyph { ink: Theme.subtext; }
                            }
                            Rectangle {
                                horizontal-stretch: 1;
                                clip: true;
                                if qi.text == "" : Text {
                                    x: 0;
                                    width: 100%;
                                    height: 100%;
                                    text: "Search history…";
                                    color: Theme.faint;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                                qi := TextInput {
                                    width: 100%;
                                    height: 100%;
                                    color: Theme.text;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    single-line: true;
                                    init => { self.text = root.proj.query; }
                                    edited => { root.query-edited(self.text); }
                                }
                            }
                        }
                    }
                }

                if root.sessions.length == 0 : Text {
                    text: "No matching sessions.";
                    color: Theme.subtext;
                    font-size: 11px;
                    horizontal-alignment: left;
                    height: 22px;
                    vertical-alignment: center;
                }

                for s[k] in root.sessions : ClaudeSessionRowView {
                    session: s;
                    resume => { root.resume-session(s.id); }
                }
            }
        }
    }

    menu := ProjectMenu {
        pname: root.proj.name;
        recolor(s) => { root.recolor(s); }
        rename(t) => { root.rename(t); }
        remove => { root.remove(); }
    }
}

// ===== reminder panes (Track F) =====
// One parked pane in the bell's reminder list: color dot + title + due label, with a
// resume arrow on hover. Clicking anywhere re-docks the pane into the active tab and
// clears the reminder. An overdue (fired) row gets an accent ring + accent due text.
component ReminderRowView inherits Rectangle {
    in property <ReminderItem> rem;
    callback restore();
    height: 40px;
    border-radius: 5px;
    background: ra.has-hover ? Theme.surface2 : (root.rem.overdue ? Theme.surface : transparent);
    border-width: root.rem.overdue ? 1px : 0px;
    border-color: Theme.accent;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 7px;

        // pane tint dot (project color / accent)
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: root.rem.tint;
            }
        }

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: root.rem.title;
                color: Theme.text;
                font-size: 12px;
                overflow: elide;
            }
            Text {
                text: (root.rem.overdue ? "overdue · " : "due ") + root.rem.due;
                color: root.rem.overdue ? Theme.accent : Theme.subtext;
                font-size: 10px;
                overflow: elide;
            }
        }

        // restore affordance (the same play/resume glyph idiom as the Claude rows)
        VerticalLayout {
            alignment: center;
            ResumeGlyph {
                ink: ra.has-hover ? Theme.accent : Theme.subtext;
            }
        }
    }

    ra := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.restore(); }
    }
}

export component SidebarRail inherits Rectangle {
    in property <[ProjectItem]> projects;
    in property <bool> projects-open: false;
    callback new-pane();
    callback open-new-pane();   // Shift+click → open the New Pane options dialog
    callback toggle-projects();
    callback open-project(int);
    callback recolor-project(int, int);   // row, swatch
    callback rename-project(int, string);
    callback remove-project(int);
    // Resume Claude session <session-id> for project row <int> in a new pane. NOTE: this is
    // an EXISTING-style sidebar callback ready for fan-in; binding it (app.slint) + handling
    // it (app.rs → State::add_pane_opts with the resume command + project cwd) is the only
    // out-of-scope hop for this track. Until bound it's an inert no-op. See the project loop.
    callback resume-session(int, string);
    // The ＋ on the PROJECTS header — opens the Add-Project dialog (overlay kind 4).
    callback add-project();

    // ---- worktree-delete confirmation popup state (sidebar-local) ----
    property <bool> wt-del-visible: false;
    property <int> wt-del-proj;
    property <int> wt-del-wt;
    property <string> wt-del-name;     // worktree path, shown in the warning

    // Encoding for the worktree-delete signal smuggled through `open-project` (see header).
    property <int> DELETE-BASE: 1000000;
    property <int> DELETE-STRIDE: 1000;

    // TOCTOU guard. The delete travels as the (proj, wt) INDICES captured when the popup
    // opened, but the projects/worktrees models can change underneath us while it's open (a
    // background pane reporting a new cwd re-sorts projects newest-first; an enumeration
    // refresh reorders worktrees). Before dispatching we re-check that those indices STILL
    // address the exact path the user saw and confirmed (`wt-del-name`); if not — the list
    // moved — we abort rather than delete whatever now sits at that slot. Bounds-checked so a
    // shrunk model can't index out of range.
    pure function captured-still-valid() -> bool {
        if (root.wt-del-proj < 0 || root.wt-del-proj >= root.projects.length) {
            return false;
        }
        if (root.wt-del-wt < 0 || root.wt-del-wt >= root.projects[root.wt-del-proj].worktrees.length) {
            return false;
        }
        return root.projects[root.wt-del-proj].worktrees[root.wt-del-wt].path == root.wt-del-name;
    }

    // Width is driven by the single rail-width binding in app.slint (44px collapsed →
    // ~280px when `projects-open`); the pane area shrinks to match. Internal layout reads
    // `root.width` so the icon column anchors to the right edge and the projects section
    // fills the space to its left.
    background: Theme.mantle;

    // The fixed-width icon column on the RIGHT edge. The projects section (when open)
    // occupies everything to the left of this.
    property <length> rail-icons-w: 44px;

    // left hairline against the pane area
    Rectangle { x: 0; width: 1px; height: 100%; background: Theme.border; }

    // ＋ quick-pane
    plus-btn := Rectangle {
        x: root.width - root.rail-icons-w + 6px;   // anchored to the rail's right edge
        y: 6px;
        width: 32px;
        height: 32px;
        border-radius: 7px;
        background: pa.has-hover ? Theme.surface2 : transparent;
        NewPaneGlyph {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            ink: pa.has-hover ? Theme.text : Theme.subtext;
        }
        // Plain click adds a default pane immediately; Shift-click opens the New Pane
        // options dialog (mirrors Electron's Sidebar ＋). Shift is sampled on press and
        // consumed on the resulting click.
        property <bool> shift-down: false;
        pa := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                if (parent.shift-down) { root.open-new-pane(); } else { root.new-pane(); }
            }
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) { parent.shift-down = e.modifiers.shift; }
            }
        }
    }

    // 📁 projects + count badge
    folder-btn := Rectangle {
        x: root.width - root.rail-icons-w + 6px;   // anchored to the rail's right edge
        y: 42px;
        width: 32px;
        height: 32px;
        border-radius: 7px;
        background: (root.projects-open || fa.has-hover) ? Theme.surface2 : transparent;
        FolderGlyph {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            ink: root.projects-open ? Theme.accent : (fa.has-hover ? Theme.text : Theme.subtext);
        }
        if root.projects.length > 0 : Rectangle {
            x: parent.width - self.width - 1px;
            y: 1px;
            width: 15px;
            height: 14px;
            border-radius: 7px;
            background: Theme.accent;
            Text {
                text: root.projects.length;
                color: #11111b;
                font-size: 9px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }
        fa := TouchArea {
            mouse-cursor: pointer;
            // One expanded section at a time: opening Projects while Reminders is open
            // switches to it (the reverse direction lives in State::toggle_reminders,
            // which collapses the projects flyout when the bell opens).
            clicked => {
                if (RemindersAdapter.open) { RemindersAdapter.toggle(); }
                root.toggle-projects();
            }
        }
    }

    // ===== reminder panes (Track F): 🔔 bell + count badge + in-rail REMINDERS section =====
    // Data + callbacks ride the RemindersAdapter global (see types.slint). The bell expands
    // the rail in place — the SAME width mechanic as the 📁 projects button (app.slint widens
    // the rail when either section is open); Projects and Reminders are mutually exclusive
    // sections of the expanded rail (opening one switches to it).
    bell-btn := Rectangle {
        x: root.width - root.rail-icons-w + 6px;   // anchored to the rail's right edge
        y: 78px;                                    // below the 📁 projects button
        width: 32px;
        height: 32px;
        border-radius: 7px;
        background: (RemindersAdapter.open || ba.has-hover) ? Theme.surface2 : transparent;
        BellGlyph {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            ink: RemindersAdapter.alert ? Theme.accent
               : RemindersAdapter.open ? Theme.accent
               : (ba.has-hover ? Theme.text : Theme.subtext);
        }
        // count badge — accent normally, danger once any reminder has fired.
        if RemindersAdapter.rows.length > 0 : Rectangle {
            x: parent.width - self.width - 1px;
            y: 1px;
            width: 15px;
            height: 14px;
            border-radius: 7px;
            background: RemindersAdapter.alert ? Theme.danger : Theme.accent;
            Text {
                text: RemindersAdapter.rows.length;
                color: #11111b;
                font-size: 9px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }
        ba := TouchArea {
            mouse-cursor: pointer;
            clicked => { RemindersAdapter.toggle(); }
        }
    }

    // The REMINDERS section (IN-RAIL — fills the widened rail to the LEFT of the icons,
    // exactly like the projects section below; was a floating popup anchored at the bell).
    // The rail's width (in app.slint) grows when `RemindersAdapter.open`, and this section
    // fills everything left of the fixed icon column. Gated on `!projects-open` so a stray
    // both-open state (e.g. via the palette) can't draw the two sections on top of each other.
    if RemindersAdapter.open && !root.projects-open : Rectangle {
        x: 0;
        y: 0;
        width: root.width - root.rail-icons-w;
        height: root.height;
        background: Theme.mantle;
        clip: true;
        // eat stray clicks so they don't fall through to a pane behind the section
        TouchArea {}

        // divider hairline separating the reminders section from the icon column
        Rectangle { x: parent.width - 1px; width: 1px; height: 100%; background: Theme.border; }

        VerticalLayout {
            padding: 8px;
            spacing: 4px;

            Text {
                text: "REMINDERS";
                color: Theme.subtext;
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 0.5px;
                height: 18px;
                vertical-alignment: center;
            }

            if RemindersAdapter.rows.length == 0 : Text {
                text: "No parked panes. Right-click a pane header and pick a \"Remind…\" time to park it here.";
                color: Theme.subtext;
                font-size: 12px;
                wrap: word-wrap;
            }

            Rectangle {
                vertical-stretch: 1;
                clip: true;
                Flickable {
                    width: 100%;
                    height: 100%;
                    viewport-width: self.width;
                    viewport-height: rembody.preferred-height;
                    rembody := VerticalLayout {
                        alignment: start;
                        spacing: 2px;
                        for r[i] in RemindersAdapter.rows : ReminderRowView {
                            rem: r;
                            restore => { RemindersAdapter.restore(r.uid); }
                        }
                    }
                }
            }
        }
    }

    // ===== projects section (IN-RAIL — fills the widened rail to the LEFT of the icons) =====
    // The rail's width (in app.slint) grows when `projects-open`, and this section fills
    // everything left of the fixed icon column. No scrim / shadow / float — it's part of
    // the rail, so the pane area to its left simply shrinks.
    if root.projects-open : Rectangle {
        x: 0;
        y: 0;
        width: root.width - root.rail-icons-w;
        height: root.height;
        background: Theme.mantle;
        clip: true;
        // eat stray clicks so they don't fall through to a pane behind the section
        TouchArea {}

        // divider hairline separating the projects section from the icon column
        Rectangle { x: parent.width - 1px; width: 1px; height: 100%; background: Theme.border; }

        VerticalLayout {
            padding: 8px;
            spacing: 4px;

            // header row: "PROJECTS" left, the add-project ＋ right-aligned (same drawn
            // PlusGlyph + hover affordance as the rail's quick-pane button, scaled down).
            HorizontalLayout {
                spacing: 4px;
                Text {
                    text: "PROJECTS";
                    color: Theme.subtext;
                    font-size: 10px;
                    font-weight: 700;
                    letter-spacing: 0.5px;
                    height: 22px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                add-proj-btn := Rectangle {
                    width: 16px;
                    height: 16px;
                    y: (22px - self.height) / 2;
                    border-radius: 4px;
                    background: apa.has-hover ? Theme.surface2 : transparent;
                    PlusGlyph {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        bar: 8px;
                        ink: apa.has-hover ? Theme.text : Theme.subtext;
                    }
                    apa := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.add-project(); }
                    }
                }
            }

            if root.projects.length == 0 : Text {
                text: "Projects you cd into show up here. Expand one to manage its git worktrees.";
                color: Theme.subtext;
                font-size: 12px;
                wrap: word-wrap;
            }

            // scrollable tree (projects + their expanded worktrees)
            Rectangle {
                vertical-stretch: 1;
                clip: true;
                Flickable {
                    width: 100%;
                    height: 100%;
                    viewport-width: self.width;
                    viewport-height: treebody.preferred-height;
                    treebody := VerticalLayout {
                    alignment: start;
                    spacing: 2px;

                    for p[i] in root.projects : ProjectRow {
                        proj: p;
                        // Per-project Claude sessions: populated by the projection (paneview.rs)
                        // from `sidebar::claude_sessions_for(path)`. Empty hides the list.
                        sessions: p.sessions;
                        open => { root.open-project(i); }
                        recolor(s) => { root.recolor-project(i, s); }
                        rename(t) => { root.rename-project(i, t); }
                        remove => { root.remove-project(i); }
                        resume-session(id) => { root.resume-session(i, id); }
                        // History-UI edits go through the polled `HistoryUi` global (the
                        // controller folds them into its per-project map keyed by path) —
                        // no app-level callback needed. Each edit records the row's FULL
                        // (segment, query) pair, so one global slot can't tear state
                        // between two expanded projects.
                        segment-changed(s) => {
                            HistoryUi.proj = i;
                            HistoryUi.segment = s;
                            HistoryUi.query = p.query;
                            HistoryUi.seq += 1;
                        }
                        query-edited(q) => {
                            HistoryUi.proj = i;
                            HistoryUi.segment = p.segment;
                            HistoryUi.query = q;
                            HistoryUi.seq += 1;
                        }
                        request-delete(j, path) => {
                            root.wt-del-proj = i;
                            root.wt-del-wt = j;
                            root.wt-del-name = path;
                            root.wt-del-visible = true;
                        }
                    }
                    }
                }
            }
        }
    }

    // ===== worktree-delete confirmation popup (sidebar-local overlay) =====
    // Rendered at the rail root so it isn't clipped by the flyout; covers the pane area to
    // the left with a scrim and a centered card. A FocusScope grabs focus on appear so
    // Esc=Cancel / Enter=Confirm work without any app-level key wiring.
    if root.wt-del-visible : Rectangle {
        // span far to the left over the panes AND across the full (possibly widened) rail
        // so the scrim covers the open projects section too (the rail is at the window's
        // right edge).
        x: -2000px;
        width: root.width + 2000px;
        y: 0;
        height: root.height;

        // scrim — also swallows clicks outside the card (no dismissal on outside click;
        // use Cancel/Esc so a misclick can't silently delete).
        Rectangle {
            background: #0b0c12cc;
            // Swallow scrim clicks (no outside-click dismissal — use Cancel/Esc) AND, if the
            // click did land here, pull keyboard focus back to the FocusScope so Esc/Enter keep
            // working afterwards.
            TouchArea {
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down) { fs.focus(); }
                }
            }
        }

        // the card
        Rectangle {
            width: 340px;
            height: 168px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            // Any focus landing on the card delegates to the key-handling FocusScope, so a
            // click on the card chrome can't silently strand Esc/Enter.
            forward-focus: fs;
            background: Theme.mantle;
            border-radius: 10px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 40px;
            drop-shadow-color: Theme.scrim;
            drop-shadow-offset-y: 12px;

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                Text {
                    text: "Remove worktree?";
                    color: Theme.text;
                    font-size: 15px;
                    font-weight: 700;
                }
                Text {
                    text: "This deletes the working directory:\n" + root.wt-del-name;
                    color: Theme.subtext;
                    font-size: 12px;
                    wrap: word-wrap;
                    vertical-stretch: 1;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    // Cancel
                    Rectangle {
                        width: 90px;
                        height: 32px;
                        border-radius: 7px;
                        border-width: 1px;
                        border-color: Theme.border;
                        background: ca.has-hover ? Theme.surface2 : transparent;
                        Text {
                            text: "Cancel";
                            color: Theme.text;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        ca := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.wt-del-visible = false; }
                        }
                    }

                    // Confirm (danger)
                    Rectangle {
                        width: 110px;
                        height: 32px;
                        border-radius: 7px;
                        background: cfa.has-hover ? #ff5b60 : Theme.danger;
                        Text {
                            text: "Remove";
                            color: #ffffff;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        cfa := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                // TOCTOU guard: only dispatch if the captured indices still
                                // point at the confirmed path; otherwise abort (no delete).
                                if (root.captured-still-valid()) {
                                    root.open-project(root.DELETE-BASE + root.wt-del-proj * root.DELETE-STRIDE + root.wt-del-wt);
                                }
                                root.wt-del-visible = false;
                            }
                        }
                    }
                }
            }

            // key handling: grabs focus when the popup appears (the `if` recreates this on
            // each show, so `init` re-fires), traps Esc → cancel / Enter → confirm.
            fs := FocusScope {
                init => { fs.focus(); }
                key-pressed(e) => {
                    if (e.text == Key.Escape) {
                        root.wt-del-visible = false;
                        return EventResult.accept;
                    }
                    if (e.text == Key.Return) {
                        // Same TOCTOU guard as the Confirm button (see captured-still-valid).
                        if (root.captured-still-valid()) {
                            root.open-project(root.DELETE-BASE + root.wt-del-proj * root.DELETE-STRIDE + root.wt-del-wt);
                        }
                        root.wt-del-visible = false;
                        return EventResult.accept;
                    }
                    return EventResult.reject;
                }
            }
        }
    }
}
